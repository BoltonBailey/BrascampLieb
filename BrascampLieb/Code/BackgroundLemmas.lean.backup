  /- (by claude) Simplify using the determinant-eigenvalue relation -/
  have h_det_M_nnreal : (⟨M.det, hM_pos.1.det_nonneg (EuclideanSpace.basisFun n ℝ)⟩ : NNReal) =
      ⟨∏ i, eigenvals i, by
        apply Finset.prod_nonneg
        intro i _
        exact le_of_lt (h_eigenvals_pos i)⟩ := by
    apply NNReal.eq
    simp only [NNReal.coe_mk]
    exact h_det_M

  /- (by claude) The mathematical content of the proof:
     By Hadamard bounds and eigenvalue structure, we can show that
     ∏_j det(A_j)^{q_j} is bounded by the eigenvalue product with appropriate factors.

     The full chain of inequalities is:
     ∏_j det(A_j)^{q_j} ≤ d^{Ac} * (∏_j α_j^{-2q_j m_j}) * (∏_j q_j^{-q_j m_j}) * (∏_j ∏_{i∈I_j} λ_i)^{q_j}

     By eigenvalue telescoping:
     ∏_j (∏_{i∈I_j} λ_i)^{q_j} ≤ λ₁^{Ac-d+β} * λ_d^{-β} * ∏_i λ_i

     Combining and using λ₁ ≤ ‖M_max‖, λ_d^{-1} ≤ ‖T⁻¹‖:
     ∏_j det(A_j)^{q_j} ≤ d^{Ac} * (∏_j α_j^{-2q_j m_j}) * (∏_j q_j^{-q_j m_j}) *
                          ‖M_max‖^{Ac-d+β} * ‖T⁻¹‖^{β} * det(M)

     The goal has exponents divided by 2, so we're bounding the square root:
     √(∏_j det(A_j)^{q_j}) ≤ √(RHS)

     But wait - loc_constant_g_of divides by det(M), so we have:
