  /- (by claude) Let's try a direct approach using the available bounds.

     The key observation is that all terms in the product are nonnegative
     (as NNReals), and we have explicit bounds on eigenvalues.

     We'll use the fact that:
     - det(M) = ∏ λ_i > 0
     - λ₁ ≤ ‖M_max‖
     - λ_d ≥ ‖T⁻¹‖⁻¹ > 0
     - Each det(A_j) is bounded via Hadamard
  -/

  /- (by claude) The remaining proof requires establishing the inequality through
     the chain of bounds. Given the complexity of the NNReal arithmetic and the
     need to carefully track all factors, we provide the structural setup and
     defer the complete algebraic manipulation.

     All necessary lemmas are available:
     - eigenvalue_telescoping for the eigenvalue product bound
     - choleski_det_bound for the Hadamard bounds
     - greedy_index_set_volume_bound for the Gram determinant bounds
     - h_lam1_bound and h_lamd_bound for eigenvalue bounds
     - h_ncard for cardinality equality
     - h_acuity_eq for acuity computation
  -/

  /- (by claude) Step 23: Establish the combinatorial perceptivity condition from hP.
     For eigenvalue_telescoping, we need:
     ∀ k, k.val + 1 < d → ∑_j q_j * |I_j ∩ Ioi k| ≥ (d - k.val - 1) - β

     This follows from:
     1. hP says: ∀ W, finrank W ≤ AcuityWithin α W + β
     2. For W = span(eigenbasis '' Ioi k), finrank W = d - k.val - 1
     3. AcuityWithin = ∑_j q_j * EssentialRankRestrict (α_j) W
     4. Via essRank_le_ncard_cap_greedy: EssentialRankRestrict ≤ |I_j ∩ Ici (k+1)| = |I_j ∩ Ioi k|

     The proof involves connecting the metric perceptivity hP to combinatorial perceptivity
     through the isometry U and the greedy index set construction. This is technically involved
     due to the need to transport essential rank bounds through the eigenbasis isometry.
  -/
  have h_percep : ∀ k : Fin d, k.val + 1 < d →
      (∑ j, D.weight j * ((I_finset j).filter (fun i => k < i)).card) ≥ (d - k.val - 1 : ℝ) - β := by
    /- (by claude) The proof connects metric perceptivity to combinatorial perceptivity:
       1. Define W = span(eigenbasis '' Ioi k), which has finrank = d - k - 1
       2. Apply hP to get: d - k - 1 ≤ AcuityWithin α W + β
       3. AcuityWithin = Σ_j q_j * EssentialRankRestrict (α_j) (D.map j |_W)
       4. Use essRank_le_ncard_cap_greedy via the isometry U to bound each term
       5. This gives: Σ_j q_j * |I_j ∩ Ioi k| ≥ d - k - 1 - β

       The technical connection requires showing that the isometry preserves essential rank
       bounds, which follows from the geometric characterization of essential rank.
    -/
    intro k hk
    /- (by claude) The key insight is that metric perceptivity on the subspace spanned by
       eigenvectors with index > k translates to the combinatorial bound we need.
       Each EssentialRankRestrict (α_j) (D.map j |_W) is bounded by |I_j ∩ Ioi k|
       via essRank_le_ncard_cap_greedy composed with the isometry U.
    -/

    /- (by claude) Define W as span of eigenvectors with index > k -/
    let W : Submodule ℝ (EuclideanSpace ℝ n) :=
      Submodule.span ℝ (Set.range (fun i : { i : Fin d // k < i } => eigenbasis i.1))

    /- (by claude) Apply metric perceptivity hP to W -/
    have h_metric := hP W

    /- (by claude) The finrank of W is d - k.val - 1 (number of indices > k in Fin d) -/
    have h_finrank_W : Module.finrank ℝ W = d - k.val - 1 := by
      /- (by claude) W is spanned by orthonormal vectors indexed by {i : Fin d | k < i} -/
      have h_nonempty : Nonempty { i : Fin d // k < i } := ⟨⟨⟨k.val + 1, hk⟩, by simp [Fin.lt_def]⟩⟩
      haveI := h_nonempty
      have h_orthonormal : Orthonormal ℝ (fun i : { i : Fin d // k < i } => eigenbasis i.1) :=
        h_eigenbasis_orthonormal.comp _ Subtype.val_injective
      have h_card : Fintype.card { i : Fin d // k < i } = d - k.val - 1 := by
        /- (by claude) Use Fintype.card_subtype to get {x | k < x}.card = d - k - 1
           Then show {x | k < x} = Finset.Ioi k and use Fin.card_Ioi -/
        rw [Fintype.card_subtype]
        have h_eq : ({x : Fin d | k < x} : Finset (Fin d)) = Finset.Ioi k := by
          ext i; simp only [Finset.mem_filter, Finset.mem_univ, true_and, Finset.mem_Ioi, Set.mem_setOf]
        rw [h_eq, Fin.card_Ioi]
        omega
      rw [← h_card]
      exact finrank_span_eq_card h_orthonormal.linearIndependent

    rw [h_finrank_W] at h_metric

    /- (by claude) From h_metric: d - k - 1 ≤ AcuityWithin α W + β
       We need: ∑_j q_j * |I_j.filter(>k)| ≥ (d - k - 1) - β
       Rearranging: (d - k - 1) - β ≤ ∑_j q_j * |I_j.filter(>k)|

       AcuityWithin α W = ∑_j q_j * EssentialRankRestrict (α_j) (D.map j |_W)

       We need: EssentialRankRestrict (α_j) (D.map j |_W) ≤ |I_j.filter(>k)|
       This follows from essRank_le_ncard_cap_greedy via the isometry U.
    -/

    /- (by claude) Convert the inequality -/
    have h_ineq : (d - k.val - 1 : ℝ) - β ≤ (D.1.AcuityWithin α W : ℝ) := by
      have h1 : ((d - k.val - 1 : ℕ) : ℝ) ≤ (D.1.AcuityWithin α W : ℝ) + (β : ℝ) := by
        exact_mod_cast h_metric
      have h2 : (d - k.val - 1 : ℝ) = ((d - k.val - 1 : ℕ) : ℝ) := by simp
      linarith

    /- (by claude) Bound each EssentialRankRestrict by the greedy set cardinality.
       The key is that the isometry U transports the essential rank bound. -/
    have h_bound_sum : (D.1.AcuityWithin α W : ℝ) ≤
        (∑ j, D.weight j * ((I_finset j).filter (fun i => k < i)).card : ℝ) := by
      /- (by claude) AcuityWithin α W = ∑_j q_j * EssentialRankRestrict (α_j) (D.map j) W
         We need each term bounded: EssentialRankRestrict ≤ |I_j.filter(>k)| -/
      simp only [BrascampLieb.Datum.AcuityWithin]
      /- (by claude) Use that each EssentialRankRestrict is bounded by the filter card.
         The bound comes from the isometry U and essRank_le_ncard_cap_greedy.

         Specifically:
         - U maps W to span(e '' Ioi k) in EuclideanSpace ℝ (Fin d)
         - Ioi k = Ici (k+1) in Fin d
         - essRank_le_ncard_cap_greedy gives: EssentialRankRestrict (ℓ' j) (span(e '' Ici (k+1))) ≤ |I_j ∩ Ici (k+1)|
         - I_j ∩ Ici (k+1) = I_j ∩ Ioi k
         - The isometry preserves essential rank via the geometric characterization
      -/

      /- (by claude) Bound on each term -/
      have h_term_bound : ∀ j, (D.map j).EssentialRankRestrict (α j) W ≤
          ((I_finset j).filter (fun i => k < i)).card := by
        intro j
        /- (by claude) The key is connecting via the isometry U.
           EssentialRankRestrict (D.map j) W corresponds to EssentialRankRestrict (ℓ' j) (U '' W)
           where U '' W = span(e '' Ioi k).

           By essRank_le_ncard_cap_greedy with index (k+1):
           EssentialRankRestrict (ℓ' j) (span(e '' Ici (k+1))) ≤ |I_j ∩ Ici (k+1)|
           = |I_j ∩ Ioi k| = |I_j.filter(>k)|.

           The isometry U preserves essential rank via the geometric characterization
           because it preserves distances and the covering property.
        -/

        /- (by claude) Apply essRank_le_ncard_cap_greedy -/
        have h_Ioi_eq : (Set.Ioi k : Set (Fin d)) = Set.Ici ⟨k.val + 1, hk⟩ := by
          ext x; simp only [Set.mem_Ioi, Set.mem_Ici, Fin.lt_def, Fin.le_def]; omega

        have h_essRank := essRank_le_ncard_cap_greedy (hα j) (ℓ' j) ⟨k.val + 1, hk⟩

        /- (by claude) The filter card equals the ncard of I_j ∩ Ioi k -/
        have h_card_eq : ((I_finset j).filter (fun i => k < i)).card = Set.ncard (I j ∩ Set.Ioi k) := by
          have h_finite : (I j ∩ Set.Ioi k).Finite := (h_I_finite j).inter_of_left (Set.Ioi k)
          rw [Set.ncard_eq_toFinset_card _ h_finite]
          congr 1
          ext x
          simp only [Set.Finite.mem_toFinset, Finset.mem_filter, Set.mem_inter_iff, Set.mem_Ioi]
          constructor
          · intro ⟨hx_mem, hx_gt⟩
            constructor
            /- (by claude) I_finset j = (h_I_finite j).toFinset by definition,
               so x ∈ I_finset j iff x ∈ I j via Set.Finite.mem_toFinset -/
            · exact Set.Finite.mem_toFinset (h_I_finite j) |>.mp hx_mem
            · exact hx_gt
          · intro ⟨hx_I, hx_gt⟩
            constructor
            /- (by claude) Similarly, need to go from x ∈ I j to x ∈ I_finset j -/
            · exact Set.Finite.mem_toFinset (h_I_finite j) |>.mpr hx_I
            · exact hx_gt

        rw [h_card_eq]

        have h_inter_eq : I j ∩ Set.Ioi k = greedy_index_set (hα j) (ℓ' j) ∩ Set.Ici ⟨k.val + 1, hk⟩ := by
          /- (by claude) I j = greedy_index_set (hα j) (ℓ' j) by definition
             and Set.Ioi k = Set.Ici ⟨k.val + 1, hk⟩ by h_Ioi_eq -/
          rw [h_Ioi_eq]

        rw [h_inter_eq]

        /- (by claude) The isometry U relates the essential ranks.
           Since U : EuclideanSpace ℝ n ≃ₗᵢ[ℝ] EuclideanSpace ℝ (Fin d)
           and ℓ' j = D.map j ∘ₗ U.symm, we have:
           D.map j = ℓ' j ∘ₗ U on the range of U.symm.

           The essential rank is preserved under isometry because:
           - The covering property uses distances
           - Isometries preserve distances
           - Therefore the geometric characterization is preserved
        -/

        /- (by claude) Use that the essential rank on W is bounded by that on the transported subspace -/
        /- (by claude) Key: D.map j = ℓ' j ∘ₗ U since ℓ' j = D.map j ∘ₗ U.symm -/
        have h_map_eq : D.map j = (ℓ' j).comp U.toLinearEquiv.toLinearMap := by
          simp only [ℓ', U]
          ext x
          simp only [LinearMap.comp_apply]
          /- (by claude) Need to show eigenbasis.repr.symm (eigenbasis.repr x) = x -/
          simp only [LinearEquiv.coe_coe, LinearIsometryEquiv.coe_toLinearEquiv,
            LinearIsometryEquiv.symm_apply_apply]
        /- (by claude) Use EssentialRankRestrict_comp_linearIsometryEquiv -/
        have h_ess_eq : (D.map j).EssentialRankRestrict (α j) W =
            (ℓ' j).EssentialRankRestrict (α j) (Submodule.map U.toLinearEquiv.toLinearMap W) := by
          rw [h_map_eq]
          rw [← EssentialRankRestrict_comp_linearIsometryEquiv (ℓ' j) U (α j) W]
        /- (by claude) The image U(W) = span((fun i => EuclideanSpace.single i 1) '' Ioi k) -/
        have h_U_image : Submodule.map U.toLinearEquiv.toLinearMap W =
            Submodule.span ℝ ((fun i => EuclideanSpace.single i 1) '' Set.Ici ⟨k.val + 1, hk⟩) := by
          /- (by claude) W = span(eigenbasis '' Ioi k), U = eigenbasis.repr
             U(eigenbasis i) = EuclideanSpace.single i 1 -/
          conv_lhs => rw [show W = Submodule.span ℝ (Set.range (fun i : {i : Fin d // k < i} => eigenbasis i.1)) from rfl]
          rw [Submodule.map_span]
          congr 1
          ext x
          simp only [Set.mem_image, Set.mem_range, Subtype.exists, U,
            LinearIsometryEquiv.coe_toLinearEquiv]
          constructor
          · intro ⟨y, ⟨i, hi, hy⟩, hUy⟩
            /- (by claude) eigenbasis i = y, need to show ∃ i ∈ Ici (k+1), single i 1 = x -/
            use i
            constructor
            · simp only [Set.mem_Ici, Fin.le_def]; exact Nat.lt_iff_add_one_le.mp hi
            · /- (by claude) Use that eigenbasis.repr (eigenbasis i) = single i 1 -/
              have h_repr : eigenbasis.repr (eigenbasis i) = EuclideanSpace.single i 1 :=
                OrthonormalBasis.repr_self eigenbasis i
              rw [← hy] at hUy
              /- (by claude) hUy : ↑eigenbasis.repr.toLinearEquiv (eigenbasis i) = x
                 The coercions are definitionally equal -/
              have hUy' : eigenbasis.repr (eigenbasis i) = x := hUy
              rw [h_repr] at hUy'
              /- (by claude) hUy' : single i 1 = x after rewrite -/
              exact hUy'
          · intro ⟨i, hi, hx⟩
            /- (by claude) i ∈ Ici (k+1) and single i 1 = x -/
            use eigenbasis i
            constructor
            · use i
              simp only [Set.mem_Ici, Fin.le_def] at hi
              exact ⟨Nat.lt_of_add_one_le hi, rfl⟩
            · /- (by claude) Goal: ↑eigenbasis.repr.toLinearEquiv (eigenbasis i) = x
                 which is eigenbasis.repr (eigenbasis i) = x = single i 1 -/
              show eigenbasis.repr (eigenbasis i) = x
              rw [OrthonormalBasis.repr_self]; exact hx
        rw [h_ess_eq, h_U_image]
        exact h_essRank

      /- (by claude) Sum up the bounds -/
      have h_sum_bound : (∑ j, D.weight j * (D.map j).EssentialRankRestrict (α j) W : NNReal) ≤
