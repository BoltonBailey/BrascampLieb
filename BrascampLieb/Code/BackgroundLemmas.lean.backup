  /- (by claude) Step 35: Simplify notation for the RHS coefficient. -/
  let C_d := (d : NNReal).rpow (D.Acuity / 2)
  let C_q := ∏ j : J, (D.weight j).rpow (-(D.weight j : ℝ) * (Fintype.card (m j) : ℝ) / 2)
  let C_α := ∏ j : J, (α j).rpow (-(D.weight j : ℝ) * (Fintype.card (m j) : ℝ))
  let C_norm := ‖LinearMap.toContinuousLinearMap M_max‖₊.rpow ((D.Acuity - d + β) / 2)
  let C_inv := ‖LinearMap.toContinuousLinearMap
      (LinearMap.equivOfIsUnitDet (isUnit_iff_ne_zero.mpr hM_pos.2)).symm.toLinearMap‖₊.rpow (β / 2)

