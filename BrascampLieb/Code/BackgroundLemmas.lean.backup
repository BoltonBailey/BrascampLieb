  /- (by claude) The approach is to show the NNReal inequality directly.
     We use that for NNReal a/b ≤ c iff a ≤ b * c (when b ≠ 0). -/

  /- (by claude) First establish that the denominator is positive as NNReal -/
  have h_denom_ne_zero : (⟨M.det, hM_pos.1.det_nonneg (EuclideanSpace.basisFun n ℝ)⟩ : NNReal) ≠ 0 := by
    intro h
    have h' : (⟨M.det, hM_pos.1.det_nonneg (EuclideanSpace.basisFun n ℝ)⟩ : NNReal).val = (0 : NNReal).val := by
      rw [h]
    simp only [NNReal.val_eq_coe, NNReal.coe_zero] at h'
    exact hM_pos.2 h'

  /- (by claude) Use NNReal.div_le_of_le_mul to convert to multiplication form -/
  /- (by claude) a / b ≤ c iff a ≤ c * b for NNReal when b ≠ 0 -/

  /- (by claude) The goal now has form: numerator ≤ denominator * RHS
     That is: ∏ det(A_j)^{q_j} ≤ det(M) * (d^{Ac/2} * ℰ(D) * ... * ‖T⁻¹‖^{β/2})

     This is the squared version of the Brascamp-Lieb bound.
  -/

  /- (by claude) The remaining proof requires careful tracking of all factors.
     We use the eigenvalue product formula and bounds. -/

  /- (by claude) Convert the goal to a form where we can apply the eigenvalue bounds.
     The key insight is that det(M) = ∏_i eigenvals i, and we can bound
     the numerator using eigenvalue structure via Hadamard and telescoping.
