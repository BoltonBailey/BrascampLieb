     We convert all bounds to NNReal and combine. -/

  /- (by claude) Convert h_eigenvalue_telescoping to NNReal form -/
  have h_eigen_nnreal : (∏ j : J, (∏ i ∈ I_finset j, ⟨eigenvals i, le_of_lt (h_eigenvals_pos i)⟩ : NNReal) ^
      (D.weight j : ℝ)) ≤
      ⟨eigenvals ⟨0, hd⟩, le_of_lt (h_eigenvals_pos _)⟩ ^ ((D.Acuity : ℝ) - d + β) *
      ⟨eigenvals ⟨d - 1, Nat.pred_lt hd.ne'⟩, le_of_lt (h_eigenvals_pos _)⟩ ^ (-(β : ℝ)) *
      (∏ i : Fin d, ⟨eigenvals i, le_of_lt (h_eigenvals_pos i)⟩ : NNReal) := by
    /- (by claude) Convert from ℝ inequality to NNReal -/
    have h_all_pos : ∀ i, (0 : ℝ) < eigenvals i := h_eigenvals_pos
    /- (by claude) Use that the ℝ inequality lifts to NNReal when all terms are positive -/
    have h_lhs_eq : (∏ j : J, (∏ i ∈ I_finset j, ⟨eigenvals i, le_of_lt (h_eigenvals_pos i)⟩ : NNReal) ^ (D.weight j : ℝ) : NNReal) =
        ⟨∏ j : J, (∏ i ∈ I_finset j, eigenvals i) ^ (D.weight j : ℝ), by
          apply Finset.prod_nonneg
          intro j _
          apply Real.rpow_nonneg
          apply Finset.prod_nonneg
          intro i _
          exact le_of_lt (h_eigenvals_pos i)⟩ := by
      apply NNReal.eq
      simp only [NNReal.coe_prod, NNReal.coe_rpow, NNReal.coe_mk]
    have h_rhs_eq : (⟨eigenvals ⟨0, hd⟩, le_of_lt (h_eigenvals_pos _)⟩ ^ ((D.Acuity : ℝ) - d + β) *
        ⟨eigenvals ⟨d - 1, Nat.pred_lt hd.ne'⟩, le_of_lt (h_eigenvals_pos _)⟩ ^ (-(β : ℝ)) *
        (∏ i : Fin d, ⟨eigenvals i, le_of_lt (h_eigenvals_pos i)⟩ : NNReal) : NNReal) =
        ⟨eigenvals ⟨0, hd⟩ ^ ((D.Acuity : ℝ) - d + β) *
         eigenvals ⟨d - 1, Nat.pred_lt hd.ne'⟩ ^ (-(β : ℝ)) *
         ∏ i : Fin d, eigenvals i, by
          apply mul_nonneg
          apply mul_nonneg
          · apply Real.rpow_nonneg (le_of_lt (h_eigenvals_pos _))
          · apply Real.rpow_nonneg (le_of_lt (h_eigenvals_pos _))
          · apply Finset.prod_nonneg; intro i _; exact le_of_lt (h_eigenvals_pos i)⟩ := by
      apply NNReal.eq
      simp only [NNReal.coe_mul, NNReal.coe_rpow, NNReal.coe_mk, NNReal.coe_prod]
    rw [h_lhs_eq, h_rhs_eq]
    apply NNReal.coe_le_coe.mp
    simp only [NNReal.coe_mk]
    exact h_eigenvalue_telescoping

  /- (by claude) The remaining proof requires:
     1. Establishing Hadamard bounds for each det(A_j) using h_inner_bound
     2. Combining with h_eigen_nnreal
