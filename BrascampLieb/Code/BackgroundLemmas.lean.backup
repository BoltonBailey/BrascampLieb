import BrascampLieb.Code.Defs
import BrascampLieb.Code.LogicLemmas
import BrascampLieb.Code.LinearLemmas
import BrascampLieb.ToMathlib.LinearAlgebra.Eigenspace.Basic

set_option pp.numericTypes true
set_option pp.funBinderTypes true

/-!
# Background Lemmas for Brascamp-Lieb Upper Bound

This file contains helper lemmas needed for the Brascamp-Lieb upper bound theorem.
-/

namespace LinearMap

open BrascampLieb

/-! ## Section 1: Positive Definiteness Lemmas -/

/-- Adding a positive semidefinite operator to a positive definite operator
    preserves positive definiteness. -/
lemma IsPosDef.add_IsPositive {n : Type*} [Fintype n] [DecidableEq n]
    {T S : EuclideanSpace ℝ n →ₗ[ℝ] EuclideanSpace ℝ n}
    (hT : T.IsPosDef) (hS : S.IsPositive) : (T + S).IsPosDef := by
  constructor
  · exact LinearMap.IsPositive.add hT.1 hS
  · let b : OrthonormalBasis n ℝ (EuclideanSpace ℝ n) := EuclideanSpace.basisFun n ℝ
    have hTpsd : (LinearMap.toMatrix b.toBasis b.toBasis T).PosSemidef :=
      LinearMap.posSemidef_toMatrix_iff b |>.mpr hT.1
    have hTdet : (LinearMap.toMatrix b.toBasis b.toBasis T).det ≠ 0 := by
      rw [LinearMap.det_toMatrix b.toBasis T]
      exact hT.2
    have hTisUnit : IsUnit (LinearMap.toMatrix b.toBasis b.toBasis T) := by
      rw [Matrix.isUnit_iff_isUnit_det]
      exact Ne.isUnit hTdet
    have hTpd : (LinearMap.toMatrix b.toBasis b.toBasis T).PosDef :=
      hTpsd.posDef_iff_isUnit.mpr hTisUnit
    have hSpsd : (LinearMap.toMatrix b.toBasis b.toBasis S).PosSemidef :=
      LinearMap.posSemidef_toMatrix_iff b |>.mpr hS
    have hTSpd : (LinearMap.toMatrix b.toBasis b.toBasis (T + S)).PosDef := by
      simp only [map_add]
      exact hTpd.add_posSemidef hSpsd
    have hdetTS : 0 < (LinearMap.toMatrix b.toBasis b.toBasis (T + S)).det := hTSpd.det_pos
    have hdetTS' : 0 < LinearMap.det (T + S) := by
      rw [← LinearMap.det_toMatrix b.toBasis (T + S)]
      exact hdetTS
    exact hdetTS'.ne'

end LinearMap

namespace BrascampLieb

/-! ## Section 2: Main Structural Lemmas -/

/-- The aggregate operator M = T + ∑_j q_j ℓ_j^* A_j ℓ_j is positive definite
    when T is positive definite and each A_j is positive definite. -/
lemma M_is_pos_def {J : Type*} [Fintype J]
    {n : Type*} [Fintype n] [DecidableEq n]
    {m : J → Type*} [(j : J) → Fintype (m j)]
    (D : locRegDatum (EuclideanSpace ℝ n) (fun j ↦ EuclideanSpace ℝ (m j)))
    (A : (j : J) → EuclideanSpace ℝ (m j) →ₗ[ℝ] EuclideanSpace ℝ (m j))
    (hA : ∀ j, (A j).IsPosDef) :
    (D.loc + ∑ j, (D.weight j : ℝ) • (D.map j).adjoint ∘ₗ A j ∘ₗ D.map j).IsPosDef := by
  apply LinearMap.IsPosDef.add_IsPositive D.pos_loc
  apply LinearMap.IsPositive.sum
  intro j
  apply LinearMap.IsPositive.smul_of_nonneg
  · exact LinearMap.IsPositive.adjoint_conj (hA j).1 (D.map j)
  · exact NNReal.zero_le_coe

/-! ## Section 3: Utility lemmas for NNReal and ENNReal -/

/-- ENNReal.coe distributes over products with inequalities -/
lemma ENNReal.coe_prod_le_prod_coe {ι : Type*} [Fintype ι] (f g : ι → NNReal)
    (h : ∀ i, f i ≤ g i) : (↑(∏ i, f i) : ENNReal) ≤ ∏ i, (g i : ENNReal) := by
  simp only [ENNReal.coe_finset_prod]
  exact Finset.prod_le_prod (fun i _ => zero_le _) (fun i _ => ENNReal.coe_le_coe.mpr (h i))

/-- A key coercion lemma for NNReal division to ENNReal -/
lemma ENNReal.coe_div_le' {a b c d : NNReal} (hb : b ≠ 0) (hd : d ≠ 0)
    (ha : a ≤ c) (hbd : d ≤ b) : (↑(a / b) : ENNReal) ≤ ↑(c / d) := by
  simp only [ENNReal.coe_div hb, ENNReal.coe_div hd]
  exact ENNReal.div_le_div (ENNReal.coe_le_coe.mpr ha) (ENNReal.coe_le_coe.mpr hbd)

/-- Product of NNReal.rpow distributes -/
lemma NNReal.rpow_prod_le {J : Type*} [Fintype J] (f : J → NNReal) (c : J → ℝ)
    (g : J → NNReal) (h : ∀ j, f j ≤ g j) (hc : ∀ j, 0 ≤ c j) :
    ∏ j, NNReal.rpow (f j) (c j) ≤ ∏ j, NNReal.rpow (g j) (c j) := by
  apply Finset.prod_le_prod
  · intro j _
    exact zero_le _
  · intro j _
    exact NNReal.rpow_le_rpow (h j) (hc j)

/-! ## Section 4: Positive definiteness det lemmas -/

/-- Positive definite linear maps have positive determinant -/
lemma IsPosDef_det_pos {n : Type*} [Fintype n] [DecidableEq n]
    {T : EuclideanSpace ℝ n →ₗ[ℝ] EuclideanSpace ℝ n} (hT : LinearMap.IsPosDef T) :
    0 < T.det := by
  cases' hT with hpos hdet
  have h1 : 0 ≤ T.det := hpos.det_nonneg (EuclideanSpace.basisFun n ℝ)
  exact h1.lt_of_ne' hdet

/-- For a positive operator, all eigenvalues are non-negative -/
lemma LinearMap.IsPositive.eigenvalues_nonneg {n : Type*} [Fintype n] [DecidableEq n]
    {k : ℕ} {T : EuclideanSpace ℝ n →ₗ[ℝ] EuclideanSpace ℝ n}
    (hT : T.IsPositive) (hk : Module.finrank ℝ (EuclideanSpace ℝ n) = k) :
    ∀ i : Fin k, 0 ≤ hT.isSymmetric.eigenvalues hk i :=
  hT.nonneg_eigenvalues hk

/-! ## Section 5: Spectral Theory Lemmas -/

/-- For a symmetric operator, the matrix with respect to the eigenvector basis is diagonal.
    This follows from the spectral theorem - the eigenvector basis diagonalizes the operator. -/
lemma LinearMap.IsSymmetric.toMatrix_eigenvectorBasis_diagonal {n : Type*} [Fintype n] [DecidableEq n]
    {T : EuclideanSpace ℝ n →ₗ[ℝ] EuclideanSpace ℝ n}
    (hT : T.IsSymmetric)
    (hk : Module.finrank ℝ (EuclideanSpace ℝ n) = Fintype.card n) :
    LinearMap.toMatrix (hT.eigenvectorBasis hk).toBasis (hT.eigenvectorBasis hk).toBasis T =
    Matrix.diagonal (hT.eigenvalues hk) := by
  ext i j
  simp only [LinearMap.toMatrix_apply, Matrix.diagonal, Matrix.of_apply]
  split_ifs with hij
  · -- Case i = j: diagonal entries
    subst hij
    -- T(e_i) = λ_i * e_i, so the i-th coordinate is λ_i
    have : T ((hT.eigenvectorBasis hk).toBasis i) = (hT.eigenvalues hk i : ℝ) • (hT.eigenvectorBasis hk).toBasis i :=
      hT.apply_eigenvectorBasis hk i
    rw [this]
    simp
  · -- Case i ≠ j: off-diagonal entries are 0
    -- T(e_j) = λ_j * e_j, so the i-th coordinate (i ≠ j) is 0
    have : T ((hT.eigenvectorBasis hk).toBasis j) = (hT.eigenvalues hk j : ℝ) • (hT.eigenvectorBasis hk).toBasis j :=
      hT.apply_eigenvectorBasis hk j
    rw [this]
    simp [hij]

lemma LinearMap.IsPositive.det_eq_prod_eigenvalues {n : Type*} [Fintype n] [DecidableEq n]
    {T : EuclideanSpace ℝ n →ₗ[ℝ] EuclideanSpace ℝ n}
    (hT : T.IsPositive)
    (hk : Module.finrank ℝ (EuclideanSpace ℝ n) = Fintype.card n) :
    T.det = ∏ i : Fin (Fintype.card n), hT.isSymmetric.eigenvalues hk i := by
  -- Use the eigenvector basis for T
  let b := hT.isSymmetric.eigenvectorBasis hk
  -- Express det T using this basis
  rw [← LinearMap.det_toMatrix b.toBasis T]
  -- The matrix of T with respect to its eigenvector basis is diagonal
  rw [LinearMap.IsSymmetric.toMatrix_eigenvectorBasis_diagonal hT.isSymmetric hk]
  rw [Matrix.det_diagonal]

/- Section 6 moved to LinearLemmas.lean -/

/- Section 7 moved to LinearLemmas.lean -/

/-! ## Section 8: Greedy Index Set Construction -/


/-- Greedy index set construction.
    Given a basis (e₁,...,eₐ) and threshold ε, construct I_j by processing indices
    from d down to 1, including i if dist(ℓ_j eᵢ, span{ℓ_j eₖ : k ∈ I_j, k > i}) ≥ ε.

    Algorithm:
    1. Start with I = ∅
    2. For i from d down to 1:
       - Let S = {ℓ(e_k) : k ∈ I, k > i}
       - If dist(ℓ(e_i), span(S)) ≥ ε, add i to I
    3. Return I
    -/
lemma greedy_index_set_exists {n : ℕ} {m : Type*} [Fintype m]
    {α : NNReal} (hα : 0 < α)
    (ℓ : EuclideanSpace ℝ (Fin n) →ₗ[ℝ] EuclideanSpace ℝ m) :
    let e := fun i ↦ EuclideanSpace.single i 1
    let E := fun (I : Set (Fin n)) ↦ Submodule.span ℝ (e '' I)
    ∃ I : Set (Fin n),
    (∀ i ∈ I, Metric.infDist (ℓ <| e i) (ℓ '' (E <| I ∩ Set.Ioi i)) ≥ α / NNReal.sqrt n) ∧
    (∀ i, Metric.infDist (ℓ <| e i) (ℓ '' (E <| I ∩ Set.Ici i)) < α / NNReal.sqrt n) := by

  -- The case where n = 0 is trivial
  by_cases hn : n = 0
  · use ∅
    simp
    apply IsEmpty.elim
    convert Fin.isEmpty

  set ε := (α : ℝ) / (NNReal.sqrt n : ℝ)
  have hε : 0 < ε  := by
    positivity

  let e := fun (i : Fin n) ↦ (EuclideanSpace.single i 1 : EuclideanSpace ℝ (Fin n))
  let E := fun (I : Set (Fin n)) ↦ Submodule.span ℝ (e '' I)
  -- Use Fin.greedyIndexSet to construct the greedy index set
  convert Fin.greedyIndexSet (fun i I ↦ Metric.infDist (ℓ <| e i) (ℓ '' (E I)) < ε) ?_
  · simp [e, E]
  · intro i I hi
    suffices Metric.infDist (ℓ (e i)) (ℓ '' (E I)) = 0 by
      rwa [this]
    · apply Metric.infDist_zero_of_mem
      /- (by claude) Show ℓ (e i) ∈ ℓ '' (E I)
         Since i ∈ I and E I = span (e '' I), we have e i ∈ E I
         Therefore ℓ (e i) ∈ ℓ '' (E I) -/
      use e i
      constructor
      · /- (by claude) Show e i ∈ E I -/
        apply Submodule.subset_span
        exact Set.mem_image_of_mem e hi
      · /- (by claude) Show ℓ (e i) = ℓ (e i) -/
        rfl
      -- Priority : 1


noncomputable def greedy_index_set {n : ℕ} {m : Type*} [Fintype m]
    {α : NNReal} (hα : 0 < α)
    (ℓ : EuclideanSpace ℝ (Fin n) →ₗ[ℝ] EuclideanSpace ℝ m) : Set (Fin n) :=
  Classical.choose <| greedy_index_set_exists hα ℓ

/-- Auxillary lemma
  to express the first of the two properties of greedy index set -/
lemma greedy_index_far {n : ℕ} {m : Type*} [Fintype m]
    {α : NNReal} (hα : 0 < α)
    (ℓ : EuclideanSpace ℝ (Fin n) →ₗ[ℝ] EuclideanSpace ℝ m) :
    let e := fun i ↦ EuclideanSpace.single i 1
    let E := fun (I : Set (Fin n)) ↦ Submodule.span ℝ (e '' I)
    ∀ i ∈ greedy_index_set hα ℓ,
    Metric.infDist (ℓ <| e i) (ℓ '' (E <| greedy_index_set hα ℓ ∩ Set.Ioi i)) ≥ α / NNReal.sqrt n :=
  And.left <| Classical.choose_spec (greedy_index_set_exists hα ℓ)

/-- Auxillary lemma
  to express the second of the two properties of greedy index set -/
lemma greedy_index_close {n : ℕ} {m : Type*} [Fintype m]
    {α : NNReal} (hα : 0 < α)
    (ℓ : EuclideanSpace ℝ (Fin n) →ₗ[ℝ] EuclideanSpace ℝ m) :
    let e := fun i ↦ EuclideanSpace.single i 1
    let E := fun (I : Set (Fin n)) ↦ Submodule.span ℝ (e '' I)
    ∀ i : Fin n,
    Metric.infDist (ℓ <| e i) (ℓ '' (E <| greedy_index_set hα ℓ ∩ Set.Ici i)) < α / NNReal.sqrt n :=
  And.right <| Classical.choose_spec (greedy_index_set_exists hα ℓ)


lemma essRank_le_ncard_cap_greedy {n : ℕ} {m : Type*} [Fintype m]
    {α : NNReal} (hα : 0 < α)
    (ℓ : EuclideanSpace ℝ (Fin n) →ₗ[ℝ] EuclideanSpace ℝ m) :
    let e := fun i ↦ EuclideanSpace.single i 1
    let E := fun (I : Set (Fin n)) ↦ Submodule.span ℝ (e '' I)
    ∀ i,
    ℓ.EssentialRankRestrict α (E <| Set.Ici i) ≤
    Set.ncard (greedy_index_set hα ℓ ∩ Set.Ici i) := by
  -- Priority : 3
  intro e E i

  /- (by claude) Strategy: Use geometric characterization of essential rank
     1. Apply EssentialRankRestrict_eq_geometric to rewrite LHS as sInf
     2. Show that S := span(ℓ(e '' (greedy_index_set ∩ Ici i))) satisfies the covering property
     3. The dimension of S equals ncard(greedy_index_set ∩ Ici i) by linear independence
  -/

  /- (by claude) Apply the geometric characterization -/
  rw [LinearMap.EssentialRankRestrict_eq_geometric]

  /- (by claude) Define the candidate covering subspace S -/
  let I := greedy_index_set hα ℓ ∩ Set.Ici i
  let S := Submodule.span ℝ (ℓ '' (e '' I))

  /- (by claude) Show S achieves the bound: sInf ≤ finrank S = ncard I -/
  apply Nat.sInf_le

  /- (by claude) We need to show: ncard I ∈ {d | ∃ S, finrank S = d ∧ covering_property} -/
  use S
  constructor

  /- (by claude) Part 1: finrank S = ncard I
     This follows from linear independence of {ℓ(e j) : j ∈ I} by greedy_index_far
  -/
  · /- (by claude) The images ℓ(e j) for j ∈ greedy_index_set are linearly independent
       by the greedy_index_far property (they are far from previous spans).
       This gives finrank S = ncard I.
    -/
    /- (by claude) S = span (ℓ '' (e '' I)) where I = greedy_index_set ∩ Ici i
       We need to show finrank S = ncard I.
       First, note that ℓ '' (e '' I) = {ℓ(e j) : j ∈ I}.
       We'll show these images are linearly independent using greedy_index_far.
       The key insight is that for each j ∈ I, ℓ(e j) is at positive distance from
       the span of {ℓ(e k) : k ∈ I, k > j}. -/

    /- (by claude) Handle the case when I is empty -/
    by_cases hI_empty : I.toFinite.toFinset = ∅
    · /- (by claude) If I is empty, then S = span ∅ = ⊥, which has finrank 0.
         Also ncard I = 0. -/
      have h_I_empty_set : I = ∅ := by
        rw [← Set.Finite.toFinset_eq_empty]
        exact hI_empty
      have h_S_bot : S = ⊥ := by
        simp only [S]
        rw [h_I_empty_set, Set.image_empty, Set.image_empty, Submodule.span_empty]
      rw [h_S_bot]
      have h_ncard_zero : Set.ncard I = 0 := by rw [Set.ncard_eq_zero]; exact h_I_empty_set
      rw [h_ncard_zero]
      exact finrank_bot ℝ (EuclideanSpace ℝ m)

    /- (by claude) I is nonempty, so n > 0 (since I ⊆ Fin n) -/
    have hI_nonempty : I.toFinite.toFinset.Nonempty := Finset.nonempty_iff_ne_empty.mpr hI_empty
    have hn_pos : 0 < n := by
      by_contra hn0
      push_neg at hn0
      interval_cases n
      simp only [I] at hI_nonempty
      have : (greedy_index_set hα ℓ ∩ Set.Ici i).toFinite.toFinset = ∅ := by
        ext x
        simp only [Set.Finite.mem_toFinset, Set.mem_inter_iff, Set.mem_Ici, Finset.notMem_empty,
          iff_false]
        exact Fin.elim0 x
      exact Finset.Nonempty.ne_empty hI_nonempty this

    /- (by claude) Define the vector function on I.toFinite.toFinset -/
    let v_I : I.toFinite.toFinset → EuclideanSpace ℝ m := fun j => ℓ (e j)

    /- (by claude) The Gram determinant equals product of squared infDists by det_gram_eq_prod_infDist -/
    have h_gram_det := Matrix.det_gram_eq_prod_infDist v_I

    /- (by claude) Each infDist is ≥ α/√n by greedy_index_far -/
    have h_infDist_bound : ∀ j : I.toFinite.toFinset,
        Metric.infDist (v_I j) (Submodule.span ℝ (v_I '' Set.Ioi j)) ≥ (α : ℝ) / Real.sqrt n := by
      intro ⟨j, hj⟩
      have hj_I : j ∈ I := (Set.Finite.mem_toFinset _).1 hj
      /- (by claude) j ∈ I means j ∈ greedy_index_set ∩ Ici i, so j ∈ greedy_index_set -/
      have hj_greedy : j ∈ greedy_index_set hα ℓ := hj_I.1
      /- (by claude) Apply greedy_index_far -/
      have h_far := greedy_index_far hα ℓ j hj_greedy
      simp only [v_I]
      /- (by claude) Need to show: span(v_I '' Ioi ⟨j, hj⟩) ⊆ ℓ '' ↑(E (greedy_index_set ∩ Ioi j))
         Note: E S = span(e '' S), so ℓ '' ↑(E S) is the image of a submodule by ℓ.
         The goal is that span of the smaller image set is contained in the image of the larger span.

         Key insight: For any k ∈ I.toFinite.toFinset with k > j, we have k ∈ greedy_index_set ∩ Ioi j,
         so ℓ(e k) ∈ ℓ '' ↑(E (greedy_index_set ∩ Ioi j)).
         Therefore v_I '' Ioi ⟨j, hj⟩ ⊆ ℓ '' ↑(E (greedy_index_set ∩ Ioi j)).
         Taking spans and using that ℓ '' ↑(E S) is a submodule, we get the containment. -/

      /- (by claude) First show the generators are in the target set -/
      have h_gens_in_target : ∀ k ∈ Set.Ioi ⟨j, hj⟩,
          (fun a : I.toFinite.toFinset => ℓ (e a)) k ∈ ℓ '' ↑(E (greedy_index_set hα ℓ ∩ Set.Ioi j)) := by
        intro ⟨k, hk_mem⟩ hk_gt
        simp only [Set.mem_Ioi] at hk_gt
        have hk_I : k ∈ I := (Set.Finite.mem_toFinset _).1 hk_mem
        simp only [Set.mem_image, SetLike.mem_coe]
        use e k
        constructor
        · exact Submodule.subset_span ⟨k, ⟨hk_I.1, hk_gt⟩, rfl⟩
        · rfl

      /- (by claude) The image of ℓ on E S is a submodule (it's ℓ.range.comap ...) which contains 0 -/
      have h_zero_in_target : (0 : EuclideanSpace ℝ m) ∈ ℓ '' ↑(E (greedy_index_set hα ℓ ∩ Set.Ioi j)) := by
        use 0
        exact ⟨Submodule.zero_mem _, map_zero ℓ⟩

      /- (by claude) The span of generators is contained in the target iff the target contains
         all linear combinations. Since ℓ '' ↑(E S) = Submodule.map ℓ (E S), it's a submodule. -/
      let T := Submodule.map ℓ (E (greedy_index_set hα ℓ ∩ Set.Ioi j))

      have hT : (T : Set (EuclideanSpace ℝ m)) = ℓ '' ↑(E (greedy_index_set hα ℓ ∩ Set.Ioi j)) := by
        ext x
        simp only [SetLike.mem_coe, Set.mem_image]
        constructor
        · rintro ⟨y, hy, rfl⟩
          exact ⟨y, hy, rfl⟩
        · rintro ⟨y, hy, rfl⟩
          exact ⟨y, hy, rfl⟩

      /- (by claude) Now we can show the span is contained in T -/
      have h_span_le_T : Submodule.span ℝ ((fun k : I.toFinite.toFinset => ℓ (e ↑k)) '' Set.Ioi ⟨j, hj⟩) ≤ T := by
        rw [Submodule.span_le]
        intro x hx
        simp only [Set.mem_image] at hx
        obtain ⟨k, hk_mem, rfl⟩ := hx
        have : (fun a : I.toFinite.toFinset => ℓ (e ↑a)) k ∈ ℓ '' ↑(E (greedy_index_set hα ℓ ∩ Set.Ioi j)) :=
          h_gens_in_target k hk_mem
        rw [← hT] at this
        exact this

      /- (by claude) Use infDist monotonicity: larger set → smaller infDist -/
      calc Metric.infDist (ℓ (e j)) ↑(Submodule.span ℝ ((fun k : I.toFinite.toFinset => ℓ (e ↑k)) '' Set.Ioi ⟨j, hj⟩))
          ≥ Metric.infDist (ℓ (e j)) ↑T := by
            apply Metric.infDist_le_infDist_of_subset
            · exact h_span_le_T
            · use 0; exact Submodule.zero_mem _
        _ = Metric.infDist (ℓ (e j)) (ℓ '' ↑(E (greedy_index_set hα ℓ ∩ Set.Ioi j))) := by rw [hT]
        _ ≥ (α : ℝ) / (NNReal.sqrt n : ℝ) := h_far
        _ = (α : ℝ) / Real.sqrt n := by
            congr 1
            rw [Real.coe_sqrt, NNReal.coe_natCast]

    /- (by claude) Each squared infDist is positive since infDist ≥ α/√n > 0 -/
    have h_sq_pos : ∀ j : I.toFinite.toFinset,
        (Metric.infDist (v_I j) (Submodule.span ℝ (v_I '' Set.Ioi j)))^2 > 0 := by
      intro j
      have hbound := h_infDist_bound j
      have h_pos : (0 : ℝ) < (α : ℝ) / Real.sqrt n := by
        apply div_pos (NNReal.coe_pos.mpr hα)
        exact Real.sqrt_pos_of_pos (Nat.cast_pos.mpr hn_pos)
      have h_infDist_pos : 0 < Metric.infDist (v_I j) (Submodule.span ℝ (v_I '' Set.Ioi j)) :=
        lt_of_lt_of_le h_pos hbound
      exact sq_pos_of_pos h_infDist_pos

    /- (by claude) The Gram determinant is positive (product of positive terms) -/
    have h_gram_pos : (Matrix.gram ℝ v_I).det > 0 := by
      rw [h_gram_det]
      apply Finset.prod_pos
      intro j _
      exact h_sq_pos j

    /- (by claude) Positive Gram determinant implies linear independence -/
    have h_lin_indep : LinearIndependent ℝ v_I := by
      /- (by claude) Use the fact that gram is PSD and has positive determinant, hence positive definite -/
      have h_gram_ne_zero : (Matrix.gram ℝ v_I).det ≠ 0 := ne_of_gt h_gram_pos
      have h_gram_psd : (Matrix.gram ℝ v_I).PosSemidef := Matrix.posSemidef_gram ℝ v_I
      have h_gram_pd : (Matrix.gram ℝ v_I).PosDef := by
        rw [h_gram_psd.posDef_iff_isUnit, Matrix.isUnit_iff_isUnit_det]
        exact isUnit_iff_ne_zero.mpr h_gram_ne_zero
      exact Matrix.posDef_gram_iff_linearIndependent.mp h_gram_pd

    /- (by claude) finrank S = finrank (span (range v_I)) = card (I.toFinite.toFinset) = ncard I -/
    have h_finrank := finrank_span_eq_card h_lin_indep
    /- (by claude) Convert range v_I to the set ℓ '' (e '' I) -/
    simp only [v_I, I, S] at h_finrank ⊢
    /- (by claude) Set.range (fun j : I.toFinite.toFinset => ℓ (e j)) = ℓ '' (e '' I.toFinite.toFinset) -/
    have h_range_eq : Set.range (fun j : I.toFinite.toFinset => ℓ (e ↑j)) =
        ℓ '' (e '' (I.toFinite.toFinset : Set (Fin n))) := by
      ext x
      simp only [Set.mem_range, Set.mem_image]
      constructor
      · rintro ⟨⟨j, hj⟩, rfl⟩
        use e j
        constructor
        · use j; exact ⟨hj, rfl⟩
        · rfl
      · rintro ⟨y, ⟨j, hj, rfl⟩, rfl⟩
        use ⟨j, hj⟩
    /- (by claude) I.toFinite.toFinset = I as sets -/
    have h_toFinset_eq : (I.toFinite.toFinset : Set (Fin n)) = I := Set.Finite.coe_toFinset I.toFinite
    rw [h_range_eq, h_toFinset_eq] at h_finrank
    /- (by claude) Fintype.card I.toFinite.toFinset = ncard I -/
    have h_card_eq : Fintype.card I.toFinite.toFinset = Set.ncard I := by
      rw [Fintype.card_coe, Set.ncard_eq_toFinset_card I I.toFinite]
    rw [← h_card_eq]
    exact h_finrank

  /- (by claude) Part 2: Covering property
     For x ∈ E(Ici i) with ‖x‖ ≤ 1, we need to find y ∈ S with ‖ℓ x - y‖ ≤ α
  -/
  · intro x hx_mem hx_norm
    /- (by claude) The key strategy is:
       1. For each j ≥ i, greedy_index_close gives an approximation in ℓ '' E(I ∩ Ici j)
       2. Construct y from these approximations weighted by coordinates of x
       3. Bound the error using Cauchy-Schwarz

       For simplicity, we use ℓ x itself when x ∈ E(Ici i) ⊆ E I in the case where ℓ
       restricted to this subspace lands in S. Otherwise, we use the linear combination approach.
    -/

    /- (by claude) Handle degenerate cases first -/
    by_cases hn_zero : n = 0
    · /- (by claude) When n = 0, Fin n is empty, so x = 0 (unique element of EuclideanSpace ℝ (Fin 0)) -/
      subst hn_zero
      /- (by claude) Fin 0 is empty, so EuclideanSpace ℝ (Fin 0) has a unique element (all vectors are 0) -/
      have hx_eq_zero : x = 0 := by
        ext j
        exact j.elim0
      use 0
      constructor
      · exact Submodule.zero_mem S
      · simp only [hx_eq_zero, map_zero, sub_zero, norm_zero]
        exact NNReal.coe_nonneg α

    have hn_pos : 0 < n := Nat.pos_of_ne_zero hn_zero

    /- (by claude) For each j, greedy_index_close gives infDist(ℓ(e j), ℓ '' E(I ∩ Ici j)) < α/√n -/
    have h_close := greedy_index_close hα ℓ

    /- (by claude) The threshold α/√n is positive -/
    have h_threshold_pos : (0 : ℝ) < (α : ℝ) / Real.sqrt n := by
      apply div_pos (NNReal.coe_pos.mpr hα)
      exact Real.sqrt_pos_of_pos (Nat.cast_pos.mpr hn_pos)

    /- (by claude) For each j ≥ i, the set ℓ '' E(I ∩ Ici j) is nonempty (contains 0) -/
    have h_nonempty : ∀ j : Fin n, (ℓ '' ↑(E (greedy_index_set hα ℓ ∩ Set.Ici j))).Nonempty := by
      intro j
      use 0
      exact ⟨0, Submodule.zero_mem _, map_zero ℓ⟩

    /- (by claude) Get the approximation for each basis vector e j -/
    have h_approx : ∀ j : Fin n, ∃ approx ∈ ℓ '' ↑(E (greedy_index_set hα ℓ ∩ Set.Ici j)),
        dist (ℓ (e j)) approx < (α : ℝ) / Real.sqrt n := by
      intro j
      have h_close_j := h_close j
      simp only [Real.coe_sqrt, NNReal.coe_natCast] at h_close_j
      exact Metric.infDist_lt_iff (h_nonempty j) |>.mp h_close_j

    /- (by claude) Choose approximations for each j -/
    choose approx h_approx_mem h_approx_dist using h_approx

    /- (by claude) For j ≥ i, the approximation approx j is in S because
       I ∩ Ici j ⊆ I (since j ≥ i means Ici j ⊆ Ici i, so I ∩ Ici j ⊆ I ∩ Ici i = I) -/
    have h_approx_in_S : ∀ j : Fin n, i ≤ j → approx j ∈ S := by
      intro j hij
      obtain ⟨z, hz_mem, hz_eq⟩ := h_approx_mem j
      rw [← hz_eq]
      /- (by claude) z ∈ E(greedy_index_set ∩ Ici j) = span(e '' (greedy_index_set ∩ Ici j)).
         Since j ≥ i, we have greedy_index_set ∩ Ici j ⊆ greedy_index_set ∩ Ici i = I.
         Hence ℓ z ∈ ℓ '' E(greedy_index_set ∩ Ici j) ⊆ ℓ '' E(I).
         But S = span(ℓ '' (e '' I)), and ℓ '' E(I) ⊆ S since E(I) = span(e '' I). -/
      /- (by claude) Strategy: show z ∈ span(e '' I), then use image under ℓ -/
      have hz_in_EI : z ∈ E I := by
        apply Submodule.span_mono _ hz_mem
        apply Set.image_mono
        intro k hk
        exact ⟨hk.1, le_trans hij hk.2⟩
      /- (by claude) Now show ℓ z ∈ S = span(ℓ '' (e '' I)).
         Since z ∈ E I = span(e '' I), and ℓ is linear,
         ℓ z ∈ span(ℓ '' (e '' I)) = S. -/
      /- (by claude) Use Submodule.map_span: ℓ '' span(e '' I) = span(ℓ '' (e '' I)) -/
      have h_map_span : Submodule.map ℓ (E I) = S := by
        simp only [S, E]
        exact Submodule.map_span ℓ (e '' I)
      rw [← h_map_span]
      exact Submodule.mem_map_of_mem hz_in_EI

    /- (by claude) x ∈ E(Ici i) = span(e '' Ici i), express x in coordinates.
       The key insight is that in EuclideanSpace, x = ∑_j (x j) • e_j for all j,
       and when x ∈ span(e '' Ici i), we have x j = 0 for j < i.
       We construct y = ∑_{j≥i} (x j) • approx j -/

    /- (by claude) Define y as the approximation in S -/
    let c : Fin n → ℝ := fun j => x j  -- x j is the j-th coordinate (via WithLp/EuclideanSpace equiv)

    /- (by claude) Show that c j = 0 for j < i using span membership -/
    have h_c_zero : ∀ j : Fin n, j < i → c j = 0 := by
      intro j hji
      /- (by claude) x ∈ E(Ici i) = span(e '' Ici i). Since the e k for k ≥ i form an orthonormal
         set (a subset of the standard basis), we have ⟪x, e j⟫ = c j. But if j < i, then
         e j is orthogonal to all e k with k ≥ i, so ⟪x, e j⟫ = 0.

         Mathematical proof:
         - For y = e k with k ∈ Ici i, we have ⟪e k, e j⟫ = δ_{kj} by orthonormality.
         - Since j < i means k ≠ j for all k ≥ i, we get ⟪e k, e j⟫ = 0.
         - By linearity of inner product, ⟪x, e j⟫ = 0 for any x ∈ span(e '' Ici i).
         - Finally, ⟪x, e j⟫ = 1 * x_j = c j by EuclideanSpace.inner_single_right.

         The full formalization requires span_induction with the correct Lean 4 API.
      -/
      /- (by claude) x ∈ span(e '' Ici i), we show c j = x j = 0 using orthogonality.
         Key: for j < i, e j is orthogonal to span(e '' Ici i).
         We use inner product: c j = x j = ⟪x, e j⟫ = 0. -/
      have h_inner_zero : @inner ℝ _ _ x (e j) = 0 := by
        refine Submodule.span_induction (p := fun y _ => @inner ℝ _ _ y (e j) = 0) ?_ ?_ ?_ ?_ hx_mem
        · /- mem case: for y = e k with k ∈ Ici i, show ⟪e k, e j⟫ = 0 -/
          intro y hy
          simp only [Set.mem_image] at hy
          obtain ⟨k, hk_mem, rfl⟩ := hy
          simp only [Set.mem_Ici] at hk_mem
          /- (by claude) ⟪e k, e j⟫ = δ_{kj}, and since k ≥ i > j, we have k ≠ j -/
          rw [EuclideanSpace.inner_single_left, EuclideanSpace.single_apply]
          simp only [starRingEnd_apply, star_one, one_mul, ite_eq_right_iff, one_ne_zero]
          intro h_eq
          subst h_eq
          exact absurd hk_mem (not_le.mpr hji)
        · /- zero case -/
          simp only [inner_zero_left]
        · /- add case -/
          intro y z _ _ hy hz
          simp only [inner_add_left, hy, hz, add_zero]
        · /- smul case -/
          intro r y _ hy
          simp only [inner_smul_left, hy, mul_zero]
      /- (by claude) Now show c j = ⟪x, e j⟫ = 0 -/
      have h_inner_eq : @inner ℝ _ _ x (e j) = c j := by
        rw [EuclideanSpace.inner_single_right, one_mul]
        rfl
      rw [← h_inner_eq, h_inner_zero]

    /- (by claude) Define y = ∑_{j : Fin n} c j • approx j (where c j = 0 for j < i) -/
    let y : EuclideanSpace ℝ m := ∑ j : Fin n, c j • approx j

    /- (by claude) Show y ∈ S -/
    have hy_mem : y ∈ S := by
      apply Submodule.sum_mem
      intro j _
      by_cases hij : i ≤ j
      · exact Submodule.smul_mem S (c j) (h_approx_in_S j hij)
      · simp only [not_le] at hij
        simp only [h_c_zero j hij, zero_smul]
        exact Submodule.zero_mem S

    /- (by claude) The error bound ‖ℓ x - y‖ ≤ α follows from:
       1. x = ∑_j c_j • e_j (standard basis decomposition)
       2. ℓ x = ∑_j c_j • ℓ(e_j) (linearity)
       3. ‖ℓ x - y‖ = ‖∑_j c_j • (ℓ(e_j) - approx_j)‖
       4. ≤ ∑_j |c_j| • ‖ℓ(e_j) - approx_j‖  (triangle inequality)
       5. < ∑_j |c_j| • (α/√n)  (by h_approx_dist)
       6. = (∑_j |c_j|) • (α/√n)
       7. ≤ √(∑_j c_j²) • √n • (α/√n)  (Cauchy-Schwarz)
       8. = √(∑_j c_j²) • α = ‖x‖ • α ≤ 1 • α = α

       This proof is mathematically complete. The remaining steps require:
       - Standard basis decomposition in EuclideanSpace
       - Cauchy-Schwarz for finite sums
       - Norm characterization of EuclideanSpace
       These are all well-established results in Mathlib but require careful API navigation. -/
    use y
    constructor
    · exact hy_mem
    · /- (by claude) Prove ‖ℓ x - y‖ ≤ α using:
         1. Express x as sum of basis vectors: x = ∑ j, c j • e j
         2. Use linearity: ℓ x = ∑ j, c j • ℓ(e j)
         3. Bound the difference: ‖ℓ x - y‖ ≤ ∑ j, |c j| • ‖ℓ(e j) - approx j‖
         4. Apply Cauchy-Schwarz: ∑ |c j| ≤ √n • ‖x‖
         5. Conclude using hx_norm : ‖x‖ ≤ 1 -/

      /- (by claude) First, express x as sum of coordinates times basis vectors -/
      have h_x_decomp : x = ∑ j : Fin n, c j • e j := by
        /- Use the fact that EuclideanSpace.basisFun is the standard basis and
           Basis.sum_repr gives x = ∑ i, (b.repr x i) • b i.
           For EuclideanSpace, basisFun.repr x i = x i. -/
        conv_lhs => rw [← (EuclideanSpace.basisFun (Fin n) ℝ).sum_repr x]
        congr 1
        ext j
        /- (by claude) basisFun j = single j 1 = e j, and repr gives coordinates -/
        rw [EuclideanSpace.basisFun_apply]
        /- (by claude) Need: (basisFun.repr x).ofLp j • single j 1 = c j • single j 1
           where c j = x.ofLp j. The basisFun.repr for EuclideanSpace is the identity equiv.
           So (basisFun.repr x) i = x i (as functions). -/
        rfl

      /- (by claude) ℓ x = ∑ j, c j • ℓ(e j) by linearity -/
      have h_ell_x : ℓ x = ∑ j : Fin n, c j • ℓ (e j) := by
        conv_lhs => rw [h_x_decomp]
        rw [map_sum]
        simp only [LinearMap.map_smul]

      /- (by claude) y = ∑ j, c j • approx j by definition -/
      have h_y_def : y = ∑ j : Fin n, c j • approx j := rfl

      /- (by claude) ℓ x - y = ∑ j, c j • (ℓ(e j) - approx j) -/
      have h_diff : ℓ x - y = ∑ j : Fin n, c j • (ℓ (e j) - approx j) := by
        rw [h_ell_x, h_y_def]
        rw [← Finset.sum_sub_distrib]
        simp only [smul_sub]

      /- (by claude) Triangle inequality: ‖ℓ x - y‖ ≤ ∑ j, ‖c j • (ℓ(e j) - approx j)‖ -/
      calc ‖ℓ x - y‖ = ‖∑ j : Fin n, c j • (ℓ (e j) - approx j)‖ := by rw [h_diff]
        _ ≤ ∑ j : Fin n, ‖c j • (ℓ (e j) - approx j)‖ := norm_sum_le _ _
        _ = ∑ j : Fin n, |c j| * ‖ℓ (e j) - approx j‖ := by
            congr 1; ext j
            rw [norm_smul, Real.norm_eq_abs]
        _ ≤ ∑ j : Fin n, |c j| * (↑α / Real.sqrt ↑n) := by
            apply Finset.sum_le_sum
            intro j _
            apply mul_le_mul_of_nonneg_left
            · /- (by claude) dist (ℓ (e j)) (approx j) < α / √n, so ≤ also holds -/
              rw [← dist_eq_norm]
              exact le_of_lt (h_approx_dist j)
            · exact abs_nonneg _
        _ = (∑ j : Fin n, |c j|) * (↑α / Real.sqrt ↑n) := by
            rw [Finset.sum_mul]
        _ ≤ (Real.sqrt (∑ j : Fin n, (c j)^2) * Real.sqrt ↑n) * (↑α / Real.sqrt ↑n) := by
            /- (by claude) Apply Cauchy-Schwarz: ∑ |c j| ≤ √(∑ c j²) * √n
               Use Real.sum_mul_le_sqrt_mul_sqrt with f j = |c j| and g j = 1 -/
            apply mul_le_mul_of_nonneg_right
            · have hCS := Real.sum_mul_le_sqrt_mul_sqrt Finset.univ
                (fun j => |c j|) (fun _ => (1 : ℝ))
              simp only [mul_one, one_pow, Finset.sum_const, Finset.card_fin,
                nsmul_eq_mul, mul_one, sq_abs] at hCS
              exact hCS
            · positivity
        _ = Real.sqrt (∑ j : Fin n, (c j)^2) * ↑α := by
            /- (by claude) Simplify: √(∑ c j²) * √n * (α / √n) = √(∑ c j²) * α (when n > 0) -/
            have h_sqrt_n_pos : Real.sqrt ↑n > 0 := Real.sqrt_pos.mpr (Nat.cast_pos.mpr hn_pos)
            have h_sqrt_n_ne_zero : Real.sqrt ↑n ≠ 0 := ne_of_gt h_sqrt_n_pos
            rw [mul_assoc]
            congr 1
            rw [mul_comm, div_mul_cancel₀ _ h_sqrt_n_ne_zero]
        _ = ‖x‖ * ↑α := by
            /- (by claude) ‖x‖ = √(∑ |x j|²) = √(∑ (c j)²) for real EuclideanSpace -/
            congr 1
            rw [EuclideanSpace.norm_eq x]
            /- (by claude) Show √(∑ (c j)²) = √(∑ ‖x j‖²) using that c j = x.ofLp j and Real.norm_eq_abs -/
            /- Note: c j = x.ofLp j by definition, and ‖x j‖ = |x.ofLp j| for reals -/
            congr 1
            apply Finset.sum_congr rfl
            intro j _
            /- (by claude) c j = x.ofLp j by definition, so c j ^ 2 = |x.ofLp j|² = ‖x.ofLp j‖² -/
            rw [Real.norm_eq_abs, sq_abs]
        _ ≤ 1 * ↑α := by
            apply mul_le_mul_of_nonneg_right hx_norm
            exact NNReal.coe_nonneg α
        _ = ↑α := one_mul _


/- Volume bound for greedy sets (Lemma 2.3 in blueprint, line 164)
   The tex file states: ‖∧_{i∈I_j} ℓ_j e_i‖ ≥ d^{-|I_j|/2}
   With threshold α/√n, this gives: det(Gram) ≥ (α/√n)^{2|I|} = (α²/n)^|I| -/

lemma greedy_index_set_volume_bound {n : ℕ} {m : Type*} [Fintype m]
    {α : NNReal} (hα : 0 < α)
    (ℓ : EuclideanSpace ℝ (Fin n) →ₗ[ℝ] EuclideanSpace ℝ m) :
    let I := greedy_index_set hα ℓ
    (Matrix.gram ℝ
    (fun (i : I.toFinite.toFinset) ↦ ℓ <| EuclideanSpace.single (i : Fin n) 1)).det ≥
    ((α : ℝ) / Real.sqrt n)^(2 * Set.ncard I) := by
  -- Priority : 2
  -- ! Use : Matrix.det_gram_eq_prod_infDist from the file LinearLemmas.lean
  intro I
  /- (by claude) Strategy: Use det_gram_eq_prod_infDist to write det as product of squared distances,
     then bound each distance using greedy_index_far -/
  let e : Fin n → EuclideanSpace ℝ (Fin n) := fun i ↦ EuclideanSpace.single i (1 : ℝ)
  let v : I.toFinite.toFinset → EuclideanSpace ℝ m := fun i ↦ ℓ (e i)

  /- (by claude) Apply the determinant-distance formula (Priority 3 lemma) -/
  rw [Matrix.det_gram_eq_prod_infDist v]

  /- (by claude) First establish that α/√n ≥ 0 for positivity arguments -/
  have h_div_nonneg : 0 ≤ (α : ℝ) / Real.sqrt n := by positivity

  /- (by claude) Show the product of squared distances is at least (α/√n)^{2|I|} -/
  have h_bound : ∀ i : I.toFinite.toFinset,
      Metric.infDist (v i) (Submodule.span ℝ (v '' Set.Ioi i)) ≥ (α : ℝ) / Real.sqrt n := by
    intro ⟨i, hi⟩

    have hI_mem : i ∈ I := by
      simp only [Set.Finite.mem_toFinset] at hi
      exact hi

    /- (by claude) Get the bound from greedy_index_far -/
    have h_far := greedy_index_far hα ℓ i hI_mem

    /- (by claude) Convert NNReal.sqrt to Real.sqrt -/
    have h_sqrt_eq : (NNReal.sqrt n : ℝ) = Real.sqrt n := Real.coe_sqrt

    /- (by claude) The key: span(ℓ '' S) ⊆ ℓ '' (span S) for linear maps
       and infDist to a larger set is smaller -/
    have h_subset : (Submodule.span ℝ (v '' Set.Ioi ⟨i, hi⟩) : Set (EuclideanSpace ℝ m)) ⊆
        (ℓ '' (Submodule.span ℝ ((fun j ↦ e j) '' (I ∩ Set.Ioi i))) : Set (EuclideanSpace ℝ m)) := by
      /- (by claude) For linear ℓ: span(ℓ '' S) ⊆ ℓ '' (span S). Actually they're equal,
         but we only need the subset direction -/
      intro y hy
      rw [SetLike.mem_coe] at hy
      /- (by claude) y ∈ span(v '' Set.Ioi ⟨i, hi⟩), so y is a linear combination of
         v j = ℓ(e j) for j > i in I -/
      induction hy using Submodule.span_induction with
      | mem x hx =>
        simp only [Set.mem_image, Set.mem_Ioi, Subtype.exists] at hx
        obtain ⟨j, hj_mem, hj_gt, rfl⟩ := hx
        simp only [v, e, Set.mem_image]
        use EuclideanSpace.single j 1
        constructor
        · apply Submodule.subset_span
          simp only [Set.mem_image, Set.mem_inter_iff, Set.mem_Ioi]
          use j
          constructor
          · constructor
            · simp only [Set.Finite.mem_toFinset] at hj_mem
              exact hj_mem
            · exact hj_gt
          · rfl
        · rfl
      | zero =>
        simp only [Set.mem_image]
        use 0
        constructor
        · exact Submodule.zero_mem _
        · exact map_zero ℓ
      | add x y _ _ hx hy =>
        simp only [Set.mem_image] at hx hy ⊢
        obtain ⟨x', hx'_mem, rfl⟩ := hx
        obtain ⟨y', hy'_mem, rfl⟩ := hy
        use x' + y'
        constructor
        · exact Submodule.add_mem _ hx'_mem hy'_mem
        · exact map_add ℓ x' y'
      | smul c x _ hx =>
        simp only [Set.mem_image] at hx ⊢
        obtain ⟨x', hx'_mem, rfl⟩ := hx
        use c • x'
        constructor
        · exact Submodule.smul_mem _ c hx'_mem
        · exact map_smul ℓ c x'

    /- (by claude) Apply infDist monotonicity: infDist to larger set is ≤ infDist to smaller set -/
    have h_nonempty : (Submodule.span ℝ (v '' Set.Ioi ⟨i, hi⟩) : Set (EuclideanSpace ℝ m)).Nonempty := by
      use 0
      exact Submodule.zero_mem _

    calc Metric.infDist (v ⟨i, hi⟩) ↑(Submodule.span ℝ (v '' Set.Ioi ⟨i, hi⟩))
        ≥ Metric.infDist (v ⟨i, hi⟩) (ℓ '' (Submodule.span ℝ ((fun j ↦ e j) '' (I ∩ Set.Ioi i)))) := by
          exact Metric.infDist_le_infDist_of_subset h_subset h_nonempty
      _ ≥ (α : ℝ) / (NNReal.sqrt n : ℝ) := h_far
      _ = (α : ℝ) / Real.sqrt n := by rw [h_sqrt_eq]

  /- (by claude) Now use the bound to estimate the product -/
  have h_prod : ∏ i : I.toFinite.toFinset,
      (Metric.infDist (v i) (Submodule.span ℝ (v '' Set.Ioi i)))^2 ≥
      ((α : ℝ) / Real.sqrt n)^(2 * Fintype.card I.toFinite.toFinset) := by
    calc ∏ i : I.toFinite.toFinset, (Metric.infDist (v i) (Submodule.span ℝ (v '' Set.Ioi i)))^2
        ≥ ∏ _i : I.toFinite.toFinset, ((α : ℝ) / Real.sqrt n)^2 := by
          apply Finset.prod_le_prod
          · intro i _; exact sq_nonneg _
          · intro i _
            have hi := h_bound i
            have h_infDist_nonneg : 0 ≤ Metric.infDist (v i) ↑(Submodule.span ℝ (v '' Set.Ioi i)) :=
              Metric.infDist_nonneg
            nlinarith [sq_nonneg (Metric.infDist (v i) ↑(Submodule.span ℝ (v '' Set.Ioi i)) - (α : ℝ) / Real.sqrt n)]
      _ = (((α : ℝ) / Real.sqrt n)^2) ^ Fintype.card I.toFinite.toFinset := by
          rw [Finset.prod_const, Finset.card_univ]
      _ = ((α : ℝ) / Real.sqrt n)^(2 * Fintype.card I.toFinite.toFinset) := by
          rw [← pow_mul]

  /- (by claude) Connect Fintype.card I.toFinite.toFinset with Set.ncard I -/
  have h_card : Fintype.card I.toFinite.toFinset = Set.ncard I := by
    rw [Fintype.card_coe, Set.ncard_eq_toFinset_card I I.toFinite]

  rw [h_card] at h_prod
  exact h_prod


/-- Cardinality of greedy_index_set is equal to the dimension of the image -/
lemma ncard_greedy_eq_of_essRank_eq {n : ℕ} {m : Type*} [Fintype m]
    {α : NNReal} (hα : 0 < α)
    {ℓ : EuclideanSpace ℝ (Fin n) →ₗ[ℝ] EuclideanSpace ℝ m}
    (hℓ : ℓ.EssentialRank α = Fintype.card m) :
    Set.ncard (greedy_index_set hα ℓ) = Fintype.card m := by
  /- (by claude) Strategy:
     1. Lower bound: Use essRank_le_ncard_cap_greedy with i = 0 (if n > 0)
        This gives EssentialRankRestrict α (span (e '' Fin n)) ≤ ncard(greedy_index_set ∩ Fin n) = ncard(greedy_index_set)
        Since span (e '' Fin n) = ⊤ (full space), EssentialRankRestrict α ⊤ relates to EssentialRank
        Combined with hℓ, we get Fintype.card m ≤ ncard(greedy_index_set)

     2. Upper bound: The images {ℓ(e i) : i ∈ greedy_index_set} are linearly independent
        (by greedy_index_far and positive Gram determinant argument)
        Since they live in EuclideanSpace ℝ m of dimension Fintype.card m,
        we have ncard(greedy_index_set) ≤ Fintype.card m

     3. Combining gives equality.

     The full formalization requires relating EssentialRankRestrict on the full space to
     EssentialRank, and establishing the linear independence upper bound argument.
     Both require infrastructure around domRestrict and Submodule.topEquiv.
  -/
  -- Priority : 4
  -- Use essRank_le_ncard_cap_greedy

  /- (by claude) Handle the trivial case n = 0 first -/
  by_cases hn : n = 0
  · /- (by claude) When n = 0, greedy_index_set is empty, so ncard = 0.
       Also, EssentialRank on an empty domain is 0, so Fintype.card m = 0. -/
    subst hn
    /- (by claude) greedy_index_set for Fin 0 is empty -/
    have h_greedy_empty : greedy_index_set hα ℓ = ∅ := by
      apply Set.eq_empty_of_forall_notMem
      intro x
      exact x.elim0
    rw [h_greedy_empty, Set.ncard_empty]
    /- (by claude) EssentialRank on Fin 0 → m is 0 because there are no singular values -/
    have h_essRank_zero : ℓ.EssentialRank α = 0 := by
      unfold LinearMap.EssentialRank
      simp only [Finset.card_eq_zero, Finset.filter_eq_empty_iff, Finset.mem_univ, true_implies]
      intro i
      /- (by claude) Module.finrank ℝ (EuclideanSpace ℝ (Fin 0)) = 0, so Fin 0 is the index type -/
      have h_finrank : Module.finrank ℝ (EuclideanSpace ℝ (Fin 0)) = 0 := by simp
      rw [h_finrank] at i
      exact i.elim0
    rw [h_essRank_zero] at hℓ
    exact hℓ

  /- (by claude) Now handle n > 0 -/
  have hn_pos : 0 < n := Nat.pos_of_ne_zero hn

  /- (by claude) LOWER BOUND: Fintype.card m ≤ ncard(greedy_index_set) -/
  have h_lower : Fintype.card m ≤ Set.ncard (greedy_index_set hα ℓ) := by
    /- (by claude) Use essRank_le_ncard_cap_greedy with i = ⟨0, hn_pos⟩ -/
    haveI : NeZero n := ⟨hn⟩
    let i₀ : Fin n := ⟨0, hn_pos⟩
    have h_essRank := essRank_le_ncard_cap_greedy hα ℓ i₀
    /- (by claude) For Fin n, Set.Ici ⟨0, hn_pos⟩ = Set.univ -/
    have h_Ici_eq_univ : Set.Ici i₀ = Set.univ := by
      ext i
      simp only [Set.mem_Ici, Set.mem_univ, iff_true]
      exact Fin.zero_le i
    /- (by claude) greedy_index_set ∩ Ici 0 = greedy_index_set -/
    have h_inter_univ : greedy_index_set hα ℓ ∩ Set.Ici i₀ = greedy_index_set hα ℓ := by
      rw [h_Ici_eq_univ, Set.inter_univ]
    rw [h_inter_univ] at h_essRank
    /- (by claude) The span of e '' Set.Ici 0 is span (e '' univ) = ⊤ (full space) -/
    let e : Fin n → EuclideanSpace ℝ (Fin n) := fun i ↦ EuclideanSpace.single i (1 : ℝ)
    let E := fun (I : Set (Fin n)) ↦ Submodule.span ℝ (e '' I)
    have h_E_top : E (Set.Ici i₀) = ⊤ := by
      rw [h_Ici_eq_univ]
      /- (by claude) E Set.univ = span (e '' univ). Unfold E to get the span form -/
      show Submodule.span ℝ (e '' Set.univ) = ⊤
      rw [Set.image_univ]
      /- (by claude) The goal is now Submodule.span ℝ (Set.range e) = ⊤ -/
      /- (by claude) e = EuclideanSpace.single · 1 equals the standard basis -/
      have h_e_range : Set.range e = Set.range (EuclideanSpace.basisFun (Fin n) ℝ) := by
        congr 1
        funext i
        simp only [EuclideanSpace.basisFun_apply, EuclideanSpace.single, e]
      rw [h_e_range]
      /- (by claude) span (range (basisFun)) = ⊤ -/
      exact (EuclideanSpace.basisFun (Fin n) ℝ).toBasis.span_eq
    /- (by claude) Connect EssentialRankRestrict on ⊤ to EssentialRank -/
    simp only at h_essRank
    /- (by claude) Now we need EssentialRankRestrict α ℓ ⊤ = EssentialRank α ℓ -/
    have h_essRank_restrict_top : ℓ.EssentialRankRestrict α (E (Set.Ici i₀)) = ℓ.EssentialRankRestrict α ⊤ := by
      rw [h_E_top]
    rw [h_essRank_restrict_top] at h_essRank
    /- (by claude) EssentialRankRestrict α ℓ ⊤ = EssentialRank α ℓ -/
    /- (by claude) The key insight is that singular values are preserved under the isomorphism
       Submodule.topEquiv : ⊤ ≃ₗ[ℝ] EuclideanSpace ℝ (Fin n). Since this is an isometry,
       the eigenvalues of (domRestrict ⊤)^* ∘ (domRestrict ⊤) equal those of ℓ^* ∘ ℓ.

       This is a standard result in spectral theory but proving it formally requires
       infrastructure about singular values being preserved under unitary equivalence.
       For the formalization, we axiomatize this as a helper lemma. -/
    have h_restrict_eq : ℓ.EssentialRankRestrict α ⊤ = ℓ.EssentialRank α := by
      /- (by claude) Use geometric characterizations to prove equality.
         EssentialRankRestrict α ℓ ⊤ = sInf {d | ∃ S, ... ∀ x ∈ ⊤, ...}
         EssentialRank α ℓ = sInf {d | ∃ S, ... ∀ x, ...}
         Since x ∈ ⊤ is always true, these sets are equal. -/
      rw [LinearMap.EssentialRankRestrict_eq_geometric, LinearMap.EssentialRank_eq_geometric]
      congr 1
      ext d
      simp only [Set.mem_setOf_eq]
      constructor
      · intro ⟨S, hS_rank, hS_cover⟩
        exact ⟨S, hS_rank, fun x hx_norm => hS_cover x (Submodule.mem_top) hx_norm⟩
      · intro ⟨S, hS_rank, hS_cover⟩
        exact ⟨S, hS_rank, fun x _ hx_norm => hS_cover x hx_norm⟩
    rw [h_restrict_eq, hℓ] at h_essRank
    exact h_essRank

  /- (by claude) UPPER BOUND: ncard(greedy_index_set) ≤ Fintype.card m -/
  have h_upper : Set.ncard (greedy_index_set hα ℓ) ≤ Fintype.card m := by
    /- (by claude) The images {ℓ(e i) : i ∈ greedy_index_set} are linearly independent
       by the Gram determinant argument (positive Gram matrix). -/
    let I := greedy_index_set hα ℓ
    let e : Fin n → EuclideanSpace ℝ (Fin n) := fun i ↦ EuclideanSpace.single i (1 : ℝ)
    let v : I.toFinite.toFinset → EuclideanSpace ℝ m := fun i ↦ ℓ (e i)

    /- (by claude) Handle the case when I is empty -/
    by_cases hI_empty : I.toFinite.toFinset = ∅
    · /- (by claude) If I.toFinite.toFinset = ∅, then I is empty.
         Use Set.ncard_eq_toFinset_card to connect ncard with toFinset.card = 0. -/
      have h_ncard_zero : Set.ncard I = 0 := by
        rw [Set.ncard_eq_toFinset_card I I.toFinite]
        rw [hI_empty]
        simp
      rw [h_ncard_zero]
      exact Nat.zero_le _

    /- (by claude) I is nonempty -/
    have hI_nonempty : I.toFinite.toFinset.Nonempty := Finset.nonempty_iff_ne_empty.mpr hI_empty

    /- (by claude) Use greedy_index_set_volume_bound to show Gram determinant is positive -/
    have h_vol_bound := greedy_index_set_volume_bound hα ℓ

    /- (by claude) The Gram determinant is positive (≥ positive number raised to positive power) -/
    have h_gram_pos : (Matrix.gram ℝ v).det > 0 := by
      have h_bound : ((α : ℝ) / Real.sqrt n)^(2 * Set.ncard I) > 0 := by
        apply pow_pos
        apply div_pos (NNReal.coe_pos.mpr hα)
        exact Real.sqrt_pos_of_pos (Nat.cast_pos.mpr hn_pos)
      calc (Matrix.gram ℝ v).det ≥ ((α : ℝ) / Real.sqrt n)^(2 * Set.ncard I) := h_vol_bound
        _ > 0 := h_bound

    /- (by claude) Positive Gram determinant implies linear independence -/
    have h_gram_ne_zero : (Matrix.gram ℝ v).det ≠ 0 := ne_of_gt h_gram_pos
    have h_gram_psd : (Matrix.gram ℝ v).PosSemidef := Matrix.posSemidef_gram ℝ v
    have h_gram_pd : (Matrix.gram ℝ v).PosDef := by
      rw [h_gram_psd.posDef_iff_isUnit, Matrix.isUnit_iff_isUnit_det]
      exact isUnit_iff_ne_zero.mpr h_gram_ne_zero
    have h_lin_indep : LinearIndependent ℝ v := Matrix.posDef_gram_iff_linearIndependent.mp h_gram_pd

    /- (by claude) Linear independence of v implies card(v's index type) ≤ finrank.
       Use linearIndependent_fintype_of_le_finrank' to convert. -/
    /- (by claude) The cardinality of the index type of v equals ncard I -/
    have h_card_eq : Fintype.card I.toFinite.toFinset = Set.ncard I := by
      rw [Fintype.card_coe, Set.ncard_eq_toFinset_card I I.toFinite]
    /- (by claude) finrank of EuclideanSpace ℝ m = Fintype.card m -/
    have h_finrank : Module.finrank ℝ (EuclideanSpace ℝ m) = Fintype.card m := by
      rw [finrank_euclideanSpace]
    /- (by claude) Linear independence implies card ≤ finrank -/
    have h_card_le : Fintype.card I.toFinite.toFinset ≤ Module.finrank ℝ (EuclideanSpace ℝ m) := by
      exact h_lin_indep.fintype_card_le_finrank
    rw [h_finrank] at h_card_le
    rw [← h_card_eq]
    exact h_card_le

  /- (by claude) Combine lower and upper bounds to get equality -/
  exact Nat.le_antisymm h_upper h_lower

/-! ## Section 9: Eigenvalue Telescoping -/

/-- (by claude) Sum swap identity: ∑_x ∑_{i<x} g x i = ∑_y ∑_{j>y} g j y.
    This swaps the order of summation over pairs (x, i) with i < x.
    -- Priority : 4 (helper for telescoping) -/
lemma sum_swap_lt {α : Type*} [Fintype α] [DecidableEq α] [LinearOrder α]
    (g : α → α → ℝ) :
    ∑ x, ∑ i ∈ Finset.filter (fun i => i < x) Finset.univ, g x i =
    ∑ y, ∑ j ∈ Finset.filter (fun j => y < j) Finset.univ, g j y := by
  simp_rw [Finset.sum_filter]
  rw [Finset.sum_comm]

/-- (by claude) Telescoping identity for products of powers.
    For positive reals λ_i and exponents c_i:
    ∏_i λ_i^{c_i} = λ_1^{∑c_i} · ∏_{k< d-1} r_k^{tail_k}
    where r_k = λ_{k+1}/λ_k and tail_k = ∑_{m>k} c_m.

    This follows from:
    - Each λ_i = λ_1 · ∏_{j< i} r_j (telescoping)
    - Substituting and swapping sums gives the identity
    -- Priority : 4 (core mathematical content) -/
lemma prod_rpow_eq_first_times_ratio_prod {d : ℕ} (hd : 2 ≤ d)
    (lam : Fin d → ℝ) (hlam_pos : ∀ i, 0 < lam i)
    (c : Fin d → ℝ) :
    let r : Fin (d - 1) → ℝ := fun k => lam ⟨k.val + 1, by omega⟩ / lam ⟨k.val, by omega⟩
    let tail : Fin (d - 1) → ℝ := fun k =>
      ∑ i ∈ Finset.univ.filter (fun i : Fin d => ⟨k.val, by omega⟩ < i), c i
    ∏ i : Fin d, lam i ^ c i = lam ⟨0, by omega⟩ ^ (∑ i, c i) * ∏ k : Fin (d - 1), r k ^ tail k := by
  intro r tail
  /- (by claude) The proof uses logarithms:
     log(∏_i λ_i^{c_i}) = ∑_i c_i · log(λ_i)
                       = ∑_i c_i · (log(λ_1) + ∑_{j< i} log(r_j))
                       = S · log(λ_1) + ∑_i c_i · ∑_{j< i} log(r_j)
                       = S · log(λ_1) + ∑_j (∑_{i>j} c_i) · log(r_j)  [by sum_swap]
                       = S · log(λ_1) + ∑_k tail_k · log(r_k)
     Exponentiating gives the identity. -/
  /- (by claude) We prove equality by showing the logs are equal.
     Both sides are positive, so we use exp_injective and Real.exp_log. -/
  have hlam0_pos : 0 < lam ⟨0, by omega⟩ := hlam_pos _
  have hr_pos : ∀ k : Fin (d - 1), 0 < r k := by
    intro k
    simp only [r]
    exact div_pos (hlam_pos _) (hlam_pos _)
  /- (by claude) Key step: show log(lam i) = log(lam 0) + ∑_{k < i} log(r k)
     We prove by strong induction on i.val -/
  have h_log_lam : ∀ i : Fin d, Real.log (lam i) =
      Real.log (lam ⟨0, by omega⟩) + ∑ k ∈ Finset.univ.filter (fun k : Fin (d-1) => k.val < i.val),
        Real.log (r k) := by
    intro i
    /- (by claude) Induction on i.val -/
    induction' h_i : i.val with n ih generalizing i
    · /- (by claude) Base case: i.val = 0, so i = ⟨0, _⟩ -/
      have hi_eq : i = ⟨0, by omega⟩ := Fin.ext h_i
      /- (by claude) The sum over k with k.val < 0 is empty -/
      have h_empty : ∑ k ∈ Finset.univ.filter (fun k : Fin (d-1) => k.val < 0), Real.log (r k) = 0 := by
        apply Finset.sum_eq_zero
        intro k hk
        simp only [Finset.mem_filter, Finset.mem_univ, true_and] at hk
        exact (Nat.not_lt_zero k.val hk).elim
      rw [hi_eq, h_empty, add_zero]
    · /- (by claude) Inductive case: i.val = n + 1 -/
      have hn_lt : n < d - 1 := by omega
      have hn1_lt : n + 1 < d := by omega
      /- (by claude) Let i_pred be the predecessor: i_pred.val = n -/
      let i_pred : Fin d := ⟨n, by omega⟩
      have hi_pred_val : i_pred.val = n := rfl
      /- (by claude) Apply IH to i_pred -/
      have ih_pred := ih i_pred hi_pred_val
      /- (by claude) i equals ⟨n + 1, hn1_lt⟩ -/
      have hi_eq : i = ⟨n + 1, hn1_lt⟩ := Fin.ext h_i
      /- (by claude) Let k' be the index in Fin (d-1) corresponding to n -/
      let k' : Fin (d - 1) := ⟨n, hn_lt⟩
      /- (by claude) lam ⟨n+1, _⟩ = lam ⟨n, _⟩ * r k' -/
      have h_ratio : lam ⟨n + 1, hn1_lt⟩ = lam i_pred * r k' := by
        simp only [r, k', i_pred]
        rw [mul_div_cancel₀]
        exact (hlam_pos _).ne'
      rw [hi_eq, h_ratio, Real.log_mul (hlam_pos _).ne' (hr_pos k').ne', ih_pred]
      /- (by claude) Now we need: log(lam 0) + ∑_{k < n} log(r k) + log(r k') =
                                  log(lam 0) + ∑_{k < n+1} log(r k) -/
      /- (by claude) Need: ∑_{k < n} log(r k) + log(r k') = ∑_{k < n+1} log(r k) -/
      have h_sum_split : ∑ k ∈ Finset.univ.filter (fun k : Fin (d-1) => k.val < n + 1), Real.log (r k) =
          ∑ k ∈ Finset.univ.filter (fun k : Fin (d-1) => k.val < n), Real.log (r k) + Real.log (r k') := by
        have h_insert : Finset.univ.filter (fun k : Fin (d-1) => k.val < n + 1) =
            insert k' (Finset.univ.filter (fun k : Fin (d-1) => k.val < n)) := by
          ext x
          simp only [Finset.mem_filter, Finset.mem_univ, true_and, Finset.mem_insert, k']
          constructor
          · intro hx
            by_cases hxn : x.val < n
            · right; exact hxn
            · left
              have hxn' : x.val = n := by omega
              exact Fin.ext hxn'
          · intro hx
            rcases hx with rfl | hx
            · simp
            · omega
        have h_notin : k' ∉ Finset.univ.filter (fun k : Fin (d-1) => k.val < n) := by
          simp only [Finset.mem_filter, Finset.mem_univ, true_and, k', not_lt]
          exact Nat.le_refl n
        rw [h_insert, Finset.sum_insert h_notin]
        ring
      /- (by claude) Transform goal: we need LHS = RHS where
         LHS = log(lam 0) + ∑_{k < n} log(r k) + log(r k')
         RHS = log(lam 0) + ∑_{k < n+1} log(r k) -/
      rw [add_assoc, ← h_sum_split]
  /- (by claude) Now prove the main identity using logarithms -/
  have h_lhs_pos : 0 < ∏ i : Fin d, lam i ^ c i := by
    apply Finset.prod_pos
    intro i _
    exact Real.rpow_pos_of_pos (hlam_pos i) (c i)
  have h_rhs_pos : 0 < (lam ⟨0, by omega⟩ ^ ∑ i, c i) * ∏ k : Fin (d - 1), r k ^ tail k := by
    apply mul_pos
    · exact Real.rpow_pos_of_pos hlam0_pos _
    · apply Finset.prod_pos
      intro k _
      exact Real.rpow_pos_of_pos (hr_pos k) _
  /- (by claude) Use injectivity of log to prove equality -/
  have h_log_eq : Real.log (∏ i : Fin d, lam i ^ c i) =
      Real.log ((lam ⟨0, by omega⟩ ^ ∑ i, c i) * ∏ k : Fin (d - 1), r k ^ tail k) := by
    /- (by claude) Expand both sides using log properties -/
    have h_lhs_ne : ∀ i ∈ Finset.univ, lam i ^ c i ≠ 0 := by
      intro i _
      exact (Real.rpow_pos_of_pos (hlam_pos i) (c i)).ne'
    have h_rhs_ne : ∀ k ∈ Finset.univ, r k ^ tail k ≠ 0 := by
      intro k _
      exact (Real.rpow_pos_of_pos (hr_pos k) (tail k)).ne'
    rw [Real.log_prod h_lhs_ne]
    simp_rw [Real.log_rpow (hlam_pos _)]
    rw [Real.log_mul (Real.rpow_pos_of_pos hlam0_pos _).ne'
        (Finset.prod_pos (fun k _ => Real.rpow_pos_of_pos (hr_pos k) _)).ne']
    rw [Real.log_rpow hlam0_pos]
    rw [Real.log_prod h_rhs_ne]
    simp_rw [Real.log_rpow (hr_pos _)]
    /- (by claude) Now need: ∑_i c_i * log(lam i) = (∑_i c_i) * log(lam 0) + ∑_k tail_k * log(r k) -/
    /- (by claude) Substitute the log identity into LHS -/
    conv_lhs => rw [Finset.sum_congr rfl (fun i _ => by rw [h_log_lam i])]
    /- (by claude) Distribute multiplication: c_i * (A + B) = c_i * A + c_i * B -/
    simp_rw [mul_add]
    /- (by claude) Split the sum: ∑_i (c_i * log(lam 0) + c_i * ∑_{k< i} log(r k)) -/
    rw [Finset.sum_add_distrib]
    congr 1
    · /- (by claude) ∑_i c_i * log(lam 0) = (∑_i c_i) * log(lam 0) -/
      rw [← Finset.sum_mul]
    · /- (by claude) Main part: show ∑_i c_i * ∑_{k< i} log(r k) = ∑_k tail_k * log(r k)
         where i : Fin d, k : Fin (d-1), and tail k = ∑_{j : Fin d, ⟨↑k, _⟩ < j} c j -/
      /- (by claude) Distribute c_i into the inner sum: c_i * ∑_{k< i} f k = ∑_{k< i} c_i * f k -/
      simp_rw [Finset.mul_sum]
      /- (by claude) LHS: ∑_{i : Fin d} ∑_{k : Fin (d-1), ↑k < ↑i} c_i * log(r k)
         RHS: ∑_{k : Fin (d-1)} (∑_{j : Fin d, ⟨↑k, _⟩ < j} c_j) * log(r k)
            = ∑_{k : Fin (d-1)} ∑_{j : Fin d, ⟨↑k, _⟩ < j} c_j * log(r k)
         These are equal by the double sum swap identity (Fubini for finite sums) -/
      /- (by claude) Expand RHS by distributing the sum -/
      conv_rhs =>
        rw [Finset.sum_congr rfl (fun k _ => by rw [Finset.sum_mul])]
      /- (by claude) Use Finset.sum_comm' to swap the order of summation -/
      have h_bipartite : ∀ (x : Fin d) (y : Fin (d-1)),
          x ∈ Finset.univ ∧ y ∈ Finset.univ.filter (fun k : Fin (d-1) => k.val < x.val) ↔
          x ∈ Finset.univ.filter (fun i : Fin d => (⟨y.val, by omega⟩ : Fin d) < i) ∧ y ∈ Finset.univ := by
        intro x k
        simp only [Finset.mem_univ, Finset.mem_filter, true_and]
        constructor
        · intro hk
          constructor
          · simp only [Fin.lt_def]
            exact hk
          · trivial
        · intro ⟨hk, _⟩
          simp only [Fin.lt_def] at hk
          exact hk
      rw [Finset.sum_comm' (h := h_bipartite)]
  /- (by claude) Since logs are equal and both are positive, the values are equal -/
  exact Real.log_injOn_pos.eq_iff (Set.mem_Ioi.mpr h_lhs_pos) (Set.mem_Ioi.mpr h_rhs_pos) |>.mp h_log_eq

/- (by claude) Helper lemma: For sorted positive reals, the weighted product is bounded.
   If λ₁ ≥ λ₂ ≥ ... ≥ λₐ > 0 and cᵢ are real exponents with ∑cᵢ = S,
   then ∏ᵢ λᵢ^{cᵢ} can be bounded using λ₁ and λₐ based on the tail sum structure.

   The telescoping identity (from Finset.prod_range_div) gives:
   ∏ᵢ λᵢ^{cᵢ} = λ₁^{∑cᵢ} · ∏_{k< d-1} (λ_{k+1}/λₖ)^{tail_k}
   where tail_k = ∑_{m>k} cₘ.

   When tail_k ≥ -β for all k and λ_{k+1}/λₖ ≤ 1, we have:
   ∏_{k< d-1} (λ_{k+1}/λₖ)^{tail_k} ≤ ∏_{k< d-1} (λ_{k+1}/λₖ)^{-β} = (λₐ/λ₁)^{-β}

   Combined: ∏ᵢ λᵢ^{cᵢ} ≤ λ₁^S · λ₁^β · λₐ^{-β} = λ₁^{S+β} · λₐ^{-β}
-/

/-- Core telescoping bound: for sorted positive eigenvalues and exponents with bounded tail sums,
    the weighted product is bounded by the extreme eigenvalues raised to appropriate powers.
    -- Priority : 4 (derived from eigenvalue_telescoping) -/
lemma telescoping_product_bound {d : ℕ} (hd : 2 ≤ d)
    (lam : Fin d → ℝ) (hlam_sorted : ∀ i j : Fin d, i ≤ j → lam j ≤ lam i) (hlam_pos : ∀ i, 0 < lam i)
    (c : Fin d → ℝ)
    (S : ℝ) (h_sum : ∑ i : Fin d, c i = S)
    (β : ℝ) (hβ_nonneg : 0 ≤ β)
    (h_tail : ∀ k : Fin d, k.val + 1 < d →
        ∑ i ∈ Finset.univ.filter (fun i : Fin d => k < i), c i ≥ -β) :
    ∏ i : Fin d, lam i ^ c i ≤
      lam ⟨0, by omega⟩ ^ (S + β) *
      lam ⟨d - 1, by omega⟩ ^ (-β) := by
  /- (by claude) The proof uses the telescoping product identity combined with
     the monotonicity of rpow for ratios in (0,1] and the tail sum constraint.

     Step 1: Apply telescoping identity to express product in terms of ratios
     Step 2: Bound each ratio term using the tail sum constraint
     Step 3: Combine to get the final bound

     The full formalization requires careful handling of:
     - Real.rpow monotonicity (for base in (0,1] and varying exponents)
     - Finset product manipulations
     - The telescoping identity from Finset.prod_range_div
  -/
  /- (by claude) Define key values -/
  let lam₁ := lam ⟨0, by omega⟩
  let lamₐ := lam ⟨d - 1, by omega⟩

  /- (by claude) lam₁ is the largest (first) eigenvalue, lamₐ is the smallest (last) -/
  have hlam₁_pos : 0 < lam₁ := hlam_pos _
  have hlamₐ_pos : 0 < lamₐ := hlam_pos _
  have hlamₐ_le_lam₁ : lamₐ ≤ lam₁ := by
    apply hlam_sorted
    simp only [Fin.le_iff_val_le_val]
    omega

  /- (by claude) The telescoping identity:
     ∏ᵢ λᵢ^{cᵢ} = λ₁^{∑cᵢ} · ∏_{k=0}^{d-2} (λ_{k+1}/λₖ)^{∑_{m>k} cₘ}

     This follows from writing λᵢ = λ₁ · ∏_{j< i} (λ_{j+1}/λⱼ) and rearranging.

     Due to the complexity of formalizing the telescoping rearrangement,
     we proceed by establishing the bound directly through a series of inequalities. -/

  /- (by claude) The proof proceeds by establishing the telescoping identity and using
     the antitonicity of rpow for bases in (0,1].

     Key steps:
     1. For each k, define ratio r_k = lam_{k+1}/lam_k ∈ (0, 1]
     2. Use telescoping: ∏ᵢ λᵢ^{cᵢ} = λ₁^S · ∏_{k< d-1} r_k^{tail_k}
     3. Since r_k ≤ 1 and tail_k ≥ -β, we have r_k^{tail_k} ≤ r_k^{-β}
     4. Product of r_k^{-β} = (λ_d/λ₁)^{-β}
     5. Combine to get λ₁^S · (λ_d/λ₁)^{-β} = λ₁^{S+β} · λ_d^{-β}
  -/

  /- (by claude) Define ratio function r_k = lam_{k+1}/lam_k -/
  let r : Fin (d - 1) → ℝ := fun k =>
    lam ⟨k.val + 1, by omega⟩ / lam ⟨k.val, by omega⟩

  /- (by claude) Each ratio is in (0, 1] -/
  have hr_pos : ∀ k : Fin (d - 1), 0 < r k := by
    intro k
    apply div_pos (hlam_pos _) (hlam_pos _)

  have hr_le_one : ∀ k : Fin (d - 1), r k ≤ 1 := by
    intro k
    /- (by claude) Use div_le_one_of_le₀: a/b ≤ 1 when a ≤ b and 0 ≤ b -/
    apply div_le_one_of_le₀
    · apply hlam_sorted
      simp only [Fin.le_iff_val_le_val]
      omega
    · exact le_of_lt (hlam_pos _)

  /- (by claude) Define tail sum function: tail_k = ∑_{m > k} c_m -/
  let tail : Fin (d - 1) → ℝ := fun k =>
    ∑ i ∈ Finset.univ.filter (fun i : Fin d => ⟨k.val, by omega⟩ < i), c i

  /- (by claude) Tail sums are bounded below by -β -/
  have htail_bound : ∀ k : Fin (d - 1), tail k ≥ -β := by
    intro k
    /- (by claude) Need to apply h_tail with the right index -/
    have hk_bound : (k : ℕ) + 1 < d := by omega
    exact h_tail ⟨k.val, by omega⟩ hk_bound

  /- (by claude) Key bound: r_k^{tail_k} ≤ r_k^{-β} for each k -/
  have hratio_bound : ∀ k : Fin (d - 1), r k ^ tail k ≤ r k ^ (-β) := by
    intro k
    /- (by claude) Use antitone_rpow_of_base_le_one: since 0 < r k ≤ 1 and
       tail k ≥ -β, we have r k ^ tail k ≤ r k ^ (-β) -/
    apply Real.antitone_rpow_of_base_le_one (hr_pos k) (hr_le_one k)
    /- (by claude) Need to show -β ≤ tail k -/
    linarith [htail_bound k]

  /- (by claude) Product of ratios equals lam_d/lam_1 by telescoping -/
  have hprod_ratio : ∏ k : Fin (d - 1), r k = lamₐ / lam₁ := by
    /- (by claude) Prove by induction: ∏_{k< n} r_k = lam_n / lam_0 -/
    have h : ∀ n (hn : n ≤ d - 1),
        ∏ k ∈ Finset.filter (fun k : Fin (d - 1) => k.val < n) Finset.univ, r k =
        lam ⟨n, by omega⟩ / lam ⟨0, by omega⟩ := by
      intro n
      induction n with
      | zero =>
        intro _
        have hempty : Finset.filter (fun k : Fin (d - 1) => k.val < 0) Finset.univ = ∅ := by
          ext k
          simp only [Finset.mem_filter, Finset.mem_univ, true_and, Finset.notMem_empty, iff_false]
          omega
        rw [hempty, Finset.prod_empty]
        simp [ne_of_gt (hlam_pos _)]
      | succ n ih =>
        intro hn
        have hn' : n ≤ d - 1 := by omega
        have hfilt : Finset.filter (fun k : Fin (d - 1) => k.val < n + 1) Finset.univ =
            Finset.filter (fun k : Fin (d - 1) => k.val < n) Finset.univ ∪ {⟨n, by omega⟩} := by
          ext k
          simp only [Finset.mem_filter, Finset.mem_univ, true_and, Finset.mem_union,
            Finset.mem_singleton, Fin.ext_iff]
          constructor
          · intro h
            by_cases hkn : k.val < n
            · left; exact hkn
            · right; omega
          · intro h
            rcases h with h | h
            · omega
            · omega
        rw [hfilt, Finset.prod_union]
        · simp only [Finset.prod_singleton]
          rw [ih hn']
          have hf0_ne : lam ⟨0, by omega⟩ ≠ 0 := ne_of_gt (hlam_pos _)
          have hfn_ne : lam ⟨n, by omega⟩ ≠ 0 := ne_of_gt (hlam_pos _)
          simp only [r]
          field_simp
        · simp only [Finset.disjoint_singleton_right, Finset.mem_filter, Finset.mem_univ, true_and,
            not_lt]
          omega
    have hfull : Finset.filter (fun k : Fin (d - 1) => k.val < d - 1) Finset.univ = Finset.univ := by
      ext k
      simp only [Finset.mem_filter, Finset.mem_univ, true_and, iff_true]
      exact k.isLt
    specialize h (d - 1) (le_refl _)
    rw [hfull] at h
    convert h using 2

  /- (by claude) Product bound: ∏_k r_k^{tail_k} ≤ ∏_k r_k^{-β} = (lam_d/lam_1)^{-β} -/
  have hprod_bound : ∏ k : Fin (d - 1), r k ^ tail k ≤ (lamₐ / lam₁) ^ (-β) := by
    calc ∏ k : Fin (d - 1), r k ^ tail k
        ≤ ∏ k : Fin (d - 1), r k ^ (-β) := by
          apply Finset.prod_le_prod
          · intro k _; exact Real.rpow_nonneg (le_of_lt (hr_pos k)) _
          · intro k _; exact hratio_bound k
      _ = (∏ k : Fin (d - 1), r k) ^ (-β) := by
          /- (by claude) Use Real.finset_prod_rpow: ∏ x^c = (∏ x)^c for nonneg reals -/
          exact Real.finset_prod_rpow _ _ (fun k _ => le_of_lt (hr_pos k)) _
      _ = (lamₐ / lam₁) ^ (-β) := by rw [hprod_ratio]

  /- (by claude) Apply the telescoping identity to express the product -/
  have htelescope := prod_rpow_eq_first_times_ratio_prod hd lam hlam_pos c
  /- (by claude) htelescope already has the right form -/
  rw [h_sum] at htelescope

  /- (by claude) Use the identity: ∏ λ_i^{c_i} = λ_1^S · ∏_k r_k^{tail_k} -/
  calc ∏ i : Fin d, lam i ^ c i
      = lam₁ ^ S * ∏ k : Fin (d - 1), r k ^ tail k := by
        convert htelescope using 2
    _ ≤ lam₁ ^ S * (lamₐ / lam₁) ^ (-β) := by
        apply mul_le_mul_of_nonneg_left hprod_bound
        exact Real.rpow_nonneg (le_of_lt hlam₁_pos) _
    _ = lam₁ ^ S * (lam₁ ^ β * lamₐ ^ (-β)) := by
        /- (by claude) (lamₐ / lam₁)^{-β} = lam₁^β · lamₐ^{-β} -/
        congr 1
        rw [Real.div_rpow (le_of_lt hlamₐ_pos) (le_of_lt hlam₁_pos)]
        rw [Real.rpow_neg (le_of_lt hlamₐ_pos), Real.rpow_neg (le_of_lt hlam₁_pos)]
        rw [div_eq_mul_inv, inv_inv]
        ring
    _ = lam₁ ^ (S + β) * lamₐ ^ (-β) := by
        /- (by claude) Algebra: lam₁^S * (lam₁^β * lamₐ^{-β}) = lam₁^{S+β} * lamₐ^{-β} -/
        calc lam₁ ^ S * (lam₁ ^ β * lamₐ ^ (-β))
            = (lam₁ ^ S * lam₁ ^ β) * lamₐ ^ (-β) := by ring
          _ = lam₁ ^ (S + β) * lamₐ ^ (-β) := by rw [Real.rpow_add hlam₁_pos]
  -- Priority : 4 (helper for eigenvalue_telescoping)

/-- Telescoping product inequality (Lemma lem:telescoping_eigenvalues in blueprint).
    Given eigenvalues λ₁ ≥ ... ≥ λₐ > 0 and index sets I_j satisfying the perceptivity condition,
    we can bound ∏_j (∏_{i∈I_j} λᵢ)^{q_j} using telescoping.
    -/
lemma eigenvalue_telescoping {d : ℕ} (hd : 0 < d) {J : Type*} [Fintype J]
    (lam : Fin d → ℝ) (hlam_sorted : ∀ i j : Fin d, i ≤ j → lam j ≤ lam i) (hlam_pos : ∀ i, 0 < lam i)
    (I : J → Finset (Fin d))
    (q : J → NNReal)
    (β : NNReal)
    (Ac : NNReal)
    (h_card : ∑ j, q j * (I j).card = Ac)
    (h_percep : ∀ k : Fin d, k.val + 1 < d →
      (∑ j, q j * ((I j).filter (fun i => k < i)).card) ≥ (d - k.val - 1 : ℝ) - β) :
    ∏ j, (∏ i ∈ I j, lam i) ^ (q j : ℝ) ≤
      lam ⟨0, Nat.zero_lt_of_lt hd⟩ ^ (Ac - d + β : ℝ) * (lam ⟨d - 1, Nat.pred_lt hd.ne'⟩) ^ (-(β : ℝ)) * ∏ i, lam i := by
  /- (by claude) Proof Strategy (from blueprint Lemma 4.2):
     1. Rewrite LHS as ∏ₖ λₖ^{pₖ} where pₖ = ∑ⱼ qⱼ 𝟙_{k∈Iⱼ}
        This follows from swapping products: ∏ⱼ (∏_{i∈Iⱼ} λᵢ)^{qⱼ} = ∏ₖ λₖ^{∑ⱼ qⱼ 𝟙_{k∈Iⱼ}}

     2. Divide both sides by ∏ₖ λₖ = det(M) to get: ∏ₖ λₖ^{pₖ - 1}
        Note: ∑ₖ (pₖ - 1) = Ac - d by h_card

     3. Apply telescoping: For any sequence cₖ with ∑ₖ cₖ = C,
        ∏ₖ λₖ^{cₖ} = λ₁^C · ∏_{k< d-1} (λ_{k+1}/λₖ)^{∑_{m>k} cₘ}

     4. Use the perceptivity constraint h_percep:
        ∑_{m>k} (pₘ - 1) = ∑ⱼ qⱼ |Iⱼ ∩ (k,d]| - (d - k - 1) ≥ -β

     5. Since λ_{k+1} ≤ λₖ (hlam_sorted), the ratio λ_{k+1}/λₖ ≤ 1.
        Combined with exponent ≥ -β, we get (λ_{k+1}/λₖ)^{∑_{m>k} cₘ} ≤ (λ_{k+1}/λₖ)^{-β}

     6. Taking the product: ∏_{k< d-1} (λ_{k+1}/λₖ)^{-β} = (λ_d/λ₁)^{-β}
        So: ∏ₖ λₖ^{pₖ-1} ≤ λ₁^{Ac-d} · (λ_d/λ₁)^{-β} = λ₁^{Ac-d+β} · λ_d^{-β}

     7. Multiplying both sides by ∏ₖ λₖ = det(M):
        ∏ₖ λₖ^{pₖ} ≤ λ₁^{Ac-d+β} · λ_d^{-β} · det(M)

     The formalization requires careful handling of:
     - Product swapping and index manipulation
     - The telescoping identity with tail sums
     - Combining geometric bounds with the perceptivity constraint
     - Converting between Finset and Fin arithmetic

     The proof uses telescoping_product_bound as the core, but requires additional
     infrastructure for swapping products over dependent index sets.
  -/
  /- (by claude) Handle the case d = 1 separately -/
  by_cases hd1 : d = 1
  · /- (by claude) When d = 1, both sides simplify considerably -/
    subst hd1
    /- (by claude) When d = 1, Fin 1 has only one element: ⟨0, _⟩ -/
    have hfin1 : (Finset.univ : Finset (Fin 1)) = {⟨0, Nat.zero_lt_one⟩} := by
      ext x
      simp only [Finset.mem_univ, Finset.mem_singleton, true_iff]
      exact Fin.eq_zero x
    /- (by claude) RHS simplification -/
    simp only [hfin1, Finset.prod_singleton]
    have hlam0_pos : 0 < lam ⟨0, Nat.zero_lt_one⟩ := hlam_pos _
    /- (by claude) The RHS exponent simplifies -/
    have h_rhs_exp : ((Ac : ℝ) - (1 : ℝ) + (β : ℝ)) + (-(β : ℝ)) + 1 = (Ac : ℝ) := by ring
    /- (by claude) Show each term in the inner product -/
    have h_inner : ∀ j, ∏ i ∈ I j, lam i =
        if ⟨0, Nat.zero_lt_one⟩ ∈ I j then lam ⟨0, Nat.zero_lt_one⟩ else 1 := by
      intro j
      by_cases h : ⟨0, Nat.zero_lt_one⟩ ∈ I j
      · simp only [h, ↓reduceIte]
        have hIj : I j = {⟨0, Nat.zero_lt_one⟩} := by
          ext x
          constructor
          · intro hx; simp only [Finset.mem_singleton]; exact Fin.eq_zero x
          · intro hx; simp only [Finset.mem_singleton] at hx; rw [hx]; exact h
        rw [hIj, Finset.prod_singleton]
      · simp only [h, ↓reduceIte]
        have hIj : I j = ∅ := by
          ext x
          constructor
          · intro hx; have hx0 : x = ⟨0, Nat.zero_lt_one⟩ := Fin.eq_zero x; rw [hx0] at hx; exact absurd hx h
          · intro hx; exact absurd hx (Finset.notMem_empty x)
        rw [hIj, Finset.prod_empty]
    /- (by claude) h_card for d=1 gives ∑_j q_j * |I_j| = Ac where |I_j| ∈ {0, 1} -/
    have h_card_eq : ∀ j, (I j).card = if ⟨0, Nat.zero_lt_one⟩ ∈ I j then 1 else 0 := by
      intro j
      by_cases h : ⟨0, Nat.zero_lt_one⟩ ∈ I j
      · simp only [h, ↓reduceIte]
        have hIj : I j = {⟨0, Nat.zero_lt_one⟩} := by
          ext x; constructor
          · intro _; simp only [Finset.mem_singleton]; exact Fin.eq_zero x
          · intro hx; simp only [Finset.mem_singleton] at hx; rw [hx]; exact h
        rw [hIj]; simp
      · simp only [h, ↓reduceIte]
        have hIj : I j = ∅ := by
          ext x; constructor
          · intro hx; have := Fin.eq_zero x; rw [this] at hx; exact absurd hx h
          · intro hx; exact absurd hx (Finset.notMem_empty x)
        rw [hIj]; simp
    /- (by claude) Show Ac = ∑_{j:0∈I_j} q_j -/
    have h_Ac_eq : (Ac : ℝ) = ∑ j ∈ Finset.univ.filter (fun j => ⟨0, Nat.zero_lt_one⟩ ∈ I j), (q j : ℝ) := by
      have hc := h_card
      simp_rw [h_card_eq] at hc
      /- (by claude) hc is now: ∑ x, q x * ↑(if ⟨0, _⟩ ∈ I x then 1 else 0) = Ac
         Need to convert to ∑ x with ⟨0, _⟩ ∈ I x, q x = Ac -/
      have h_rewrite : ∀ j, q j * (if ⟨0, Nat.zero_lt_one⟩ ∈ I j then (1 : ℕ) else 0 : ℕ) =
          if ⟨0, Nat.zero_lt_one⟩ ∈ I j then q j else 0 := by
        intro j
        split_ifs with h
        · simp
        · simp
      conv at hc => lhs; arg 2; ext j; rw [h_rewrite]
      have hc' : (∑ j ∈ Finset.filter (fun j => ⟨0, Nat.zero_lt_one⟩ ∈ I j) Finset.univ, q j) = Ac := by
        rw [← hc]
        exact Finset.sum_filter (fun j => ⟨0, Nat.zero_lt_one⟩ ∈ I j) (fun j => q j)
      rw [← NNReal.coe_inj] at hc'
      push_cast at hc'
      exact hc'.symm
    /- (by claude) Convert goal to simpler form -/
    /- (by claude) Goal: LHS ≤ RHS where RHS has (1-1) in the index which is 0 -/
    have h_idx_eq : (⟨1 - 1, Nat.pred_lt (Nat.one_ne_zero)⟩ : Fin 1) = ⟨0, Nat.zero_lt_one⟩ := rfl
    simp only [h_idx_eq]
    /- (by claude) Simplify the goal: RHS is lam0^(Ac-1+β) * lam0^(-β) * lam0 -/
    /- (by claude) We show this equals lam0^Ac, then prove LHS = lam0^Ac -/
    suffices h_lhs_eq_Ac : ∏ j, (∏ i ∈ I j, lam i) ^ (q j : ℝ) = lam ⟨0, Nat.zero_lt_one⟩ ^ (Ac : ℝ) by
      calc ∏ j, (∏ i ∈ I j, lam i) ^ (q j : ℝ)
          = lam ⟨0, Nat.zero_lt_one⟩ ^ (Ac : ℝ) := h_lhs_eq_Ac
        _ = lam ⟨0, Nat.zero_lt_one⟩ ^ ((Ac : ℝ) - 1 + (β : ℝ) + (-(β : ℝ)) + 1) := by ring_nf
        _ = lam ⟨0, Nat.zero_lt_one⟩ ^ ((Ac : ℝ) - 1 + (β : ℝ)) *
            lam ⟨0, Nat.zero_lt_one⟩ ^ (-(β : ℝ)) * lam ⟨0, Nat.zero_lt_one⟩ := by
          rw [Real.rpow_add hlam0_pos, Real.rpow_add hlam0_pos, Real.rpow_one]
        _ ≤ lam ⟨0, Nat.zero_lt_one⟩ ^ ((Ac : ℝ) - (1 : ℕ) + (β : ℝ)) *
            lam ⟨0, Nat.zero_lt_one⟩ ^ (-(β : ℝ)) * lam ⟨0, Nat.zero_lt_one⟩ := by
          simp only [Nat.cast_one, le_refl]
    /- (by claude) LHS manipulation: ∏_j (∏_{i∈I_j} lam_i)^{q_j} = lam0^{∑_{j:0∈I_j} q_j} = lam0^Ac -/
    simp_rw [h_inner]
    /- (by claude) Transform product of ite^q to rpow of sum -/
    have h_lhs_eq : ∏ j, (if ⟨0, Nat.zero_lt_one⟩ ∈ I j then lam ⟨0, Nat.zero_lt_one⟩ else 1) ^ (q j : ℝ) =
        lam ⟨0, Nat.zero_lt_one⟩ ^ (Ac : ℝ) := by
      /- (by claude) Split by membership -/
      have h_term : ∀ j, (if ⟨0, Nat.zero_lt_one⟩ ∈ I j then lam ⟨0, Nat.zero_lt_one⟩ else 1) ^ (q j : ℝ) =
          lam ⟨0, Nat.zero_lt_one⟩ ^ (if ⟨0, Nat.zero_lt_one⟩ ∈ I j then (q j : ℝ) else 0) := by
        intro j
        by_cases h : ⟨0, Nat.zero_lt_one⟩ ∈ I j
        · simp only [h, ↓reduceIte]
        · simp only [h, ↓reduceIte, Real.rpow_zero, Real.one_rpow]
      simp_rw [h_term]
      rw [← Real.rpow_sum_of_pos hlam0_pos]
      congr 1
      /- (by claude) ∑_j (if ... then q_j else 0) = ∑_{j∈filter} q_j -/
      rw [← Finset.sum_filter_add_sum_filter_not (s := Finset.univ) (p := fun j => ⟨0, Nat.zero_lt_one⟩ ∈ I j)]
      have h1 : ∑ j ∈ Finset.filter (fun j => ⟨0, Nat.zero_lt_one⟩ ∈ I j) Finset.univ,
          (if ⟨0, Nat.zero_lt_one⟩ ∈ I j then (q j : ℝ) else 0) =
          ∑ j ∈ Finset.filter (fun j => ⟨0, Nat.zero_lt_one⟩ ∈ I j) Finset.univ, (q j : ℝ) := by
        apply Finset.sum_congr rfl
        intro j hj
        simp only [Finset.mem_filter, Finset.mem_univ, true_and] at hj
        simp only [hj, ↓reduceIte]
      have h2 : ∑ j ∈ Finset.filter (fun j => ⟨0, Nat.zero_lt_one⟩ ∉ I j) Finset.univ,
          (if ⟨0, Nat.zero_lt_one⟩ ∈ I j then (q j : ℝ) else 0) = 0 := by
        apply Finset.sum_eq_zero
        intro j hj
        simp only [Finset.mem_filter, Finset.mem_univ, true_and] at hj
        simp only [hj, ↓reduceIte]
      rw [h1, h2, add_zero, h_Ac_eq]
    rw [h_lhs_eq]

  /- (by claude) For d ≥ 2, we use telescoping_product_bound -/
  have hd2 : 2 ≤ d := by omega

  /- (by claude) Step 1: Define p_i = ∑_j q_j * 𝟙_{i∈I_j} -/
  let p : Fin d → ℝ := fun i => ∑ j, (q j : ℝ) * if i ∈ I j then (1 : ℝ) else 0

  /- (by claude) Step 2: Show ∏_j (∏_{i∈I_j} λ_i)^{q_j} = ∏_i λ_i^{p_i} -/
  have h_prod_swap : ∏ j, (∏ i ∈ I j, lam i) ^ (q j : ℝ) = ∏ i, lam i ^ p i := by
    /- (by claude) Use: (∏_{i∈I_j} λ_i)^{q_j} = ∏_{i∈I_j} λ_i^{q_j}
       Then swap: ∏_j ∏_{i∈I_j} = ∏_i ∏_{j:i∈I_j}
       Finally: ∏_{j:i∈I_j} λ_i^{q_j} = λ_i^{∑_{j:i∈I_j} q_j} = λ_i^{p_i} -/
    have h_rpow_prod : ∀ j, (∏ i ∈ I j, lam i) ^ (q j : ℝ) = ∏ i ∈ I j, lam i ^ (q j : ℝ) := by
      intro j
      exact (Real.finset_prod_rpow (I j) _ (fun i _ => le_of_lt (hlam_pos i)) _).symm
    simp_rw [h_rpow_prod]
    /- (by claude) Now LHS = ∏_j ∏_{i∈I_j} λ_i^{q_j}
       Use Finset.prod_comm' to swap -/
    have h_bipartite : ∀ (x : J) (y : Fin d),
        x ∈ Finset.univ ∧ y ∈ I x ↔ x ∈ Finset.univ.filter (fun j => y ∈ I j) ∧ y ∈ Finset.univ := by
      intro j i
      simp only [Finset.mem_univ, Finset.mem_filter, true_and]
      tauto
    rw [Finset.prod_comm' h_bipartite]
    /- (by claude) Now LHS = ∏_{i∈univ} ∏_{j : i∈I_j} λ_i^{q_j}
       For fixed i: ∏_{j:i∈I_j} λ_i^{q_j} = λ_i^{∑_{j:i∈I_j} q_j} -/
    apply Finset.prod_congr rfl
    intro i _
    rw [← Real.rpow_sum_of_pos (hlam_pos i)]
    congr 1
    /- (by claude) Need: ∑_{j:i∈I_j} q_j = p i = ∑_j q_j * 𝟙_{i∈I_j} -/
    simp only [p]
    rw [← Finset.sum_filter_add_sum_filter_not (s := Finset.univ) (p := fun j => i ∈ I j)]
    have h_not_sum : ∑ j ∈ Finset.univ.filter (fun j => i ∉ I j), (q j : ℝ) * (if i ∈ I j then (1 : ℝ) else 0) = 0 := by
      apply Finset.sum_eq_zero
      intro j hj
      simp only [Finset.mem_filter, Finset.mem_univ, true_and] at hj
      simp only [hj, ↓reduceIte, mul_zero]
    have h_filter_eq : ∑ j ∈ Finset.univ.filter (fun j => i ∈ I j), (q j : ℝ) * (if i ∈ I j then (1 : ℝ) else 0) =
        ∑ j ∈ Finset.univ.filter (fun j => i ∈ I j), (q j : ℝ) := by
      apply Finset.sum_congr rfl
      intro j hj
      simp only [Finset.mem_filter, Finset.mem_univ, true_and] at hj
      simp only [hj, ↓reduceIte, mul_one]
    rw [h_filter_eq, h_not_sum, add_zero]

  rw [h_prod_swap]

  /- (by claude) Step 3: Define c_i = p_i - 1 -/
  let c : Fin d → ℝ := fun i => p i - 1

  /- (by claude) Step 4: Show ∏_i λ_i^{p_i} = ∏_i λ_i^{c_i} * ∏_i λ_i -/
  have h_prod_split : ∏ i, lam i ^ p i = (∏ i, lam i ^ c i) * ∏ i, lam i := by
    have h_add : ∀ i, lam i ^ p i = lam i ^ c i * lam i := by
      intro i
      have hp_eq : p i = c i + 1 := by simp only [c]; ring
      rw [hp_eq, Real.rpow_add (hlam_pos i), Real.rpow_one]
    simp_rw [h_add]
    rw [Finset.prod_mul_distrib]

  rw [h_prod_split]

  /- (by claude) Step 5: Verify the hypotheses for telescoping_product_bound -/
  /- (by claude) First, compute S = ∑_i c_i = Ac - d -/
  have h_sum_c : ∑ i : Fin d, c i = (Ac : ℝ) - d := by
    simp only [c]
    rw [Finset.sum_sub_distrib, Finset.sum_const, Finset.card_fin, nsmul_eq_mul, mul_one]
    congr 1
    /- (by claude) ∑_i p_i = ∑_i ∑_j q_j * 𝟙_{i∈I_j} = ∑_j q_j * |I_j| = Ac -/
    simp only [p]
    rw [Finset.sum_comm]
    have h_inner : ∀ j, ∑ i : Fin d, (q j : ℝ) * (if i ∈ I j then (1 : ℝ) else 0) = (q j : ℝ) * ((I j).card : ℝ) := by
      intro j
      rw [← Finset.mul_sum]
      congr 1
      rw [← Finset.sum_filter_add_sum_filter_not (s := Finset.univ) (p := fun i => i ∈ I j)]
      have h1 : ∑ i ∈ Finset.filter (fun i => i ∈ I j) Finset.univ, (if i ∈ I j then (1 : ℝ) else 0) =
          (Finset.filter (fun i => i ∈ I j) Finset.univ).card := by
        rw [Finset.sum_ite_mem, Finset.filter_mem_eq_inter, Finset.sum_const, nsmul_eq_mul, mul_one]
        congr 1
        rw [Finset.inter_assoc, Finset.inter_self]
      have h2 : ∑ i ∈ Finset.filter (fun i => i ∉ I j) Finset.univ, (if i ∈ I j then (1 : ℝ) else 0) = 0 := by
        apply Finset.sum_eq_zero
        intro i hi
        simp only [Finset.mem_filter, Finset.mem_univ, true_and] at hi
        simp only [hi, ↓reduceIte]
      rw [h2, add_zero, h1]
      have h_card_eq : (Finset.filter (fun i => i ∈ I j) Finset.univ).card = (I j).card := by
        congr 1
        ext x
        simp only [Finset.mem_filter, Finset.mem_univ, true_and]
      rw [h_card_eq]
    have h_sum_eq : ∑ j, ∑ i : Fin d, (q j : ℝ) * (if i ∈ I j then (1 : ℝ) else 0) =
        ∑ j, (q j : ℝ) * ((I j).card : ℝ) := Finset.sum_congr rfl (fun j _ => h_inner j)
    rw [h_sum_eq]
    /- (by claude) Now have ∑_j q_j * |I_j| which equals Ac by h_card -/
    /- (by claude) Need to convert h_card : ∑ j, q j * ↑(I j).card = Ac (in NNReal)
       to ∑ j, ↑(q j) * ↑(I j).card = ↑Ac (in ℝ) -/
    have hc : ∑ j, (q j : ℝ) * ((I j).card : ℝ) = (Ac : ℝ) := by
      have := congrArg (fun x : NNReal => (x : ℝ)) h_card
      simp only [NNReal.coe_sum, NNReal.coe_mul, NNReal.coe_natCast] at this
      exact this
    exact hc

  /- (by claude) Verify the tail sum constraint for c -/
  have h_tail_c : ∀ k : Fin d, k.val + 1 < d →
      ∑ i ∈ Finset.univ.filter (fun i : Fin d => k < i), c i ≥ -(β : ℝ) := by
    intro k hk
    /- (by claude) ∑_{i>k} c_i = ∑_{i>k} (p_i - 1) = ∑_{i>k} p_i - (d - k - 1) -/
    simp only [c]
    rw [Finset.sum_sub_distrib]
    /- (by claude) ∑_{i>k} p_i = ∑_{i>k} ∑_j q_j * 𝟙_{i∈I_j} = ∑_j q_j * |I_j ∩ (k,d]| -/
    have h_sum_p : ∑ i ∈ Finset.univ.filter (fun i : Fin d => k < i), p i =
        ∑ j, (q j : ℝ) * ((I j).filter (fun i => k < i)).card := by
      simp only [p]
      rw [Finset.sum_comm]
      apply Finset.sum_congr rfl
      intro j _
      rw [← Finset.mul_sum]
      congr 1
      /- (by claude) ∑_{i>k} 𝟙_{i∈I_j} = |I_j ∩ (k,d]| -/
      rw [← Finset.sum_filter_add_sum_filter_not (s := Finset.univ.filter (fun i => k < i))
          (p := fun i => i ∈ I j)]
      have h1 : ∑ i ∈ Finset.filter (fun i => i ∈ I j) (Finset.filter (fun i => k < i) Finset.univ),
          (if i ∈ I j then (1 : ℝ) else 0) =
          ((I j).filter (fun i => k < i)).card := by
        rw [Finset.filter_filter, Finset.sum_ite_mem]
        simp only [Finset.sum_const, nsmul_eq_mul, mul_one]
        congr 2
        ext x
        simp only [Finset.mem_inter, Finset.mem_filter, Finset.mem_univ, true_and]
        constructor
        · intro ⟨⟨hk, hx⟩, hx'⟩; exact ⟨hx, hk⟩
        · intro ⟨hx, hk⟩; exact ⟨⟨hk, hx⟩, hx⟩
      have h2 : ∑ i ∈ Finset.filter (fun i => i ∉ I j) (Finset.filter (fun i => k < i) Finset.univ),
          (if i ∈ I j then (1 : ℝ) else 0) = 0 := by
        apply Finset.sum_eq_zero
        intro i hi
        simp only [Finset.mem_filter, Finset.mem_univ, true_and] at hi
        simp only [hi.2, ↓reduceIte]
      rw [h1, h2, add_zero]
    rw [h_sum_p]
    /- (by claude) ∑_{i>k} 1 = d - k - 1 = |{i : k < i}| -/
    have h_sum_one : (∑ i ∈ Finset.univ.filter (fun i : Fin d => k < i), (1 : ℝ)) = d - k.val - 1 := by
      rw [Finset.sum_const, nsmul_eq_mul, mul_one]
      have h_card : (Finset.filter (fun i : Fin d => k < i) Finset.univ).card = d - k.val - 1 := by
        have h_ioi_card : (Finset.Ioi k).card = d - k.val - 1 := by
          rw [Fin.card_Ioi]
          omega
        rw [← h_ioi_card]
        congr 1
        ext x
        simp only [Finset.mem_filter, Finset.mem_univ, true_and, Finset.mem_Ioi]
      rw [h_card]
      have hk_val_lt : k.val < d := k.isLt
      have h_sub : k.val + 1 ≤ d := by omega
      rw [show d - k.val - 1 = d - (k.val + 1) from by omega, Nat.cast_sub h_sub]
      push_cast
      ring
    rw [h_sum_one]
    /- (by claude) Need: ∑_j q_j * |I_j ∩ (k,d]| - (d - k - 1) ≥ -β
       This is exactly h_percep k hk -/
    have hp := h_percep k hk
    simp only [ge_iff_le, NNReal.coe_sum, NNReal.coe_mul, NNReal.coe_natCast] at hp
    linarith

  /- (by claude) Step 6: Apply telescoping_product_bound -/
  have hβ_nonneg' : (0 : ℝ) ≤ (β : ℝ) := NNReal.coe_nonneg β
  have h_telescoping := telescoping_product_bound hd2 lam hlam_sorted hlam_pos c ((Ac : ℝ) - d) h_sum_c (β : ℝ)
    hβ_nonneg' h_tail_c

  /- (by claude) h_telescoping gives: ∏_i λ_i^{c_i} ≤ λ₁^{(Ac-d)+β} * λ_d^{-β} -/
  calc (∏ i, lam i ^ c i) * ∏ i, lam i
      ≤ (lam ⟨0, by omega⟩ ^ ((Ac : ℝ) - d + (β : ℝ)) * lam ⟨d - 1, by omega⟩ ^ (-(β : ℝ))) * ∏ i, lam i := by
        apply mul_le_mul_of_nonneg_right h_telescoping
        apply Finset.prod_nonneg
        intro i _
        exact le_of_lt (hlam_pos i)
    _ = lam ⟨0, Nat.zero_lt_of_lt hd⟩ ^ ((Ac : ℝ) - (d : ℝ) + (β : ℝ)) * lam ⟨d - 1, Nat.pred_lt hd.ne'⟩ ^ (-(β : ℝ)) * ∏ i, lam i := by
        /- (by claude) The indices match up -/
        rfl
  -- Priority : 4

/-! ## Section 10: Operator Norm and Eigenvalue Bounds -/

/-- For a positive operator, the operator norm equals the largest eigenvalue -/
lemma LinearMap.IsPositive.opNorm_eq_largest_eigenvalue {n : Type*} [Fintype n] [DecidableEq n]
    {T : EuclideanSpace ℝ n →ₗ[ℝ] EuclideanSpace ℝ n}
    (hT : T.IsPositive)
    (hne : Nonempty n) :
    ‖T.toContinuousLinearMap‖ = hT.isSymmetric.eigenvalues finrank_euclideanSpace ⟨0, Fintype.card_pos⟩ := by
  -- This requires showing that for a positive operator T on finite-dimensional real space:
  -- ‖T‖ = sup{‖Tx‖ : ‖x‖ = 1} = sup{√⟨Tx, Tx⟫ : ‖x‖ = 1}
  --     = sup{√⟨x, T²x⟫ : ‖x‖ = 1}  (since T self-adjoint)
  --     = sup{⟨Tx, x⟫ : ‖x‖ = 1}     (for positive T, by Cauchy-Schwarz argument)
  --     = eigenvalues(0)              (largest eigenvalue, by Rayleigh quotient theory)

  -- The key missing piece: For positive T, prove ‖T‖ = sup{⟨Tx, x⟫ : ‖x‖ = 1}
  -- This requires showing that for positive T: sup ‖Tx‖ = sup ⟨Tx, x⟫
  -- which follows from ‖Tx‖² = ⟨T²x, x⟫ ≤ ‖T‖·⟨Tx, x⟫ with equality at eigenvector

  -- For finite-dimensional real spaces
  haveI : FiniteDimensional ℝ (EuclideanSpace ℝ n) := by infer_instance

  -- T is positive, hence symmetric (self-adjoint)
  have hT_symm : T.IsSymmetric := hT.isSymmetric

  -- Get the orthonormal eigenbasis and eigenvalues
  let basis := hT_symm.eigenvectorBasis finrank_euclideanSpace
  let eigs := hT_symm.eigenvalues finrank_euclideanSpace

  -- eigs 0 is the largest eigenvalue (eigenvalues are sorted in decreasing order)
  let lam_max := eigs ⟨0, Fintype.card_pos⟩

  -- First, show that ‖T‖ ≥ lam_max
  have norm_ge : ‖T.toContinuousLinearMap‖ ≥ lam_max := by
    -- Apply T to the first eigenvector
    have h_eigen := hT_symm.apply_eigenvectorBasis finrank_euclideanSpace ⟨0, Fintype.card_pos⟩
    -- Since basis is orthonormal, ‖e₀‖ = 1
    have h_norm : ‖basis ⟨0, Fintype.card_pos⟩‖ = 1 := basis.orthonormal.1 _
    -- For positive T, lam_max ≥ 0, so |lam_max| = lam_max
    have h_pos : 0 ≤ lam_max := hT.nonneg_eigenvalues finrank_euclideanSpace _
    -- ‖T e₀‖ = ‖lam_max • e₀‖ = lam_max (since lam_max ≥ 0 and ‖e₀‖ = 1)
    calc ‖T.toContinuousLinearMap‖
        ≥ ‖T.toContinuousLinearMap (basis ⟨0, Fintype.card_pos⟩)‖ := by
          apply ContinuousLinearMap.unit_le_opNorm
          rw [h_norm]
      _ = ‖T (basis ⟨0, Fintype.card_pos⟩)‖ := rfl
      _ = ‖lam_max • basis ⟨0, Fintype.card_pos⟩‖ := by
          rw [h_eigen]
          rfl
      _ = |lam_max| * ‖basis ⟨0, Fintype.card_pos⟩‖ := norm_smul _ _
      _ = lam_max := by rw [abs_of_nonneg h_pos, h_norm, mul_one]

  -- Now show that ‖T‖ ≤ lam_max
  have norm_le : ‖T.toContinuousLinearMap‖ ≤ lam_max := by
    -- Use opNorm_le_of_unit_norm: it suffices to show ‖Tx‖ ≤ lam_max for all unit vectors x
    apply ContinuousLinearMap.opNorm_le_of_unit_norm
    · exact hT.nonneg_eigenvalues finrank_euclideanSpace _
    intro x hx_norm
    -- Express x in the eigenbasis using repr
    -- repr is a linear isometry, so ‖x‖ = ‖repr x‖
    have h_iso : ‖basis.repr x‖ = ‖x‖ := basis.repr.norm_map x
    -- By hx_norm, ‖x‖ = 1
    -- T acts on coordinates by eigenvalue multiplication
    have h_coord : ∀ i, (basis.repr (T.toContinuousLinearMap x)).ofLp i =
        eigs i * (basis.repr x).ofLp i := by
      intro i
      exact hT_symm.eigenvectorBasis_apply_self_apply finrank_euclideanSpace x i
    -- ‖Tx‖ = ‖repr(Tx)‖ by isometry
    have h_iso_T : ‖T.toContinuousLinearMap x‖ = ‖basis.repr (T.toContinuousLinearMap x)‖ :=
      (basis.repr.norm_map _).symm
    rw [h_iso_T]
    -- Now use the fact that all eigenvalues are ≤ lam_max
    -- Eigenvalues are antitone: eigs i ≤ eigs 0 = lam_max for all i
    have h_eigs_le : ∀ i, eigs i ≤ lam_max := by
      intro i
      exact hT_symm.eigenvalues_antitone finrank_euclideanSpace (Fin.zero_le i)
    -- For positive T, all eigenvalues are nonnegative
    have h_eigs_nonneg : ∀ i, 0 ≤ eigs i := by
      intro i
      exact hT.nonneg_eigenvalues finrank_euclideanSpace i
    -- Use norm squared formula: ‖v‖² = Σᵢ ‖vᵢ‖²
    -- Need to show ‖repr(Tx)‖² ≤ lam_max² to get ‖repr(Tx)‖ ≤ lam_max
    have h_norm_sq : ‖basis.repr (T.toContinuousLinearMap x)‖ ^ 2 ≤ lam_max ^ 2 := by
      rw [EuclideanSpace.norm_sq_eq]
      -- ‖repr(Tx)‖² = Σᵢ ‖(repr(Tx))ᵢ‖² = Σᵢ ‖λᵢ · (repr x)ᵢ‖²
      --             = Σᵢ λᵢ² · ‖(repr x)ᵢ‖² ≤ λ₀² · Σᵢ ‖(repr x)ᵢ‖² = λ₀² · ‖repr x‖² = λ₀²
      calc ∑ i, ‖(basis.repr (T.toContinuousLinearMap x)).ofLp i‖ ^ 2
          = ∑ i, ‖eigs i * (basis.repr x).ofLp i‖ ^ 2 := by simp_rw [h_coord]
        _ = ∑ i, eigs i ^ 2 * ‖(basis.repr x).ofLp i‖ ^ 2 := by
            congr 1
            ext i
            rw [norm_mul, mul_pow]
            congr 1
            simp only [sq, Real.norm_of_nonneg (h_eigs_nonneg _)]
        _ ≤ ∑ i, lam_max ^ 2 * ‖(basis.repr x).ofLp i‖ ^ 2 := by
            apply Finset.sum_le_sum
            intro i _
            apply mul_le_mul_of_nonneg_right
            · exact pow_le_pow_left₀ (h_eigs_nonneg _) (h_eigs_le i) 2
            · exact sq_nonneg _
        _ = lam_max ^ 2 * ∑ i, ‖(basis.repr x).ofLp i‖ ^ 2 := by rw [← Finset.mul_sum]
        _ = lam_max ^ 2 * ‖basis.repr x‖ ^ 2 := by rw [← EuclideanSpace.norm_sq_eq]
        _ = lam_max ^ 2 * ‖x‖ ^ 2 := by rw [h_iso]
        _ = lam_max ^ 2 := by rw [hx_norm, one_pow, mul_one]
    -- From ‖repr(Tx)‖² ≤ lam_max² and both are nonnegative, we get ‖repr(Tx)‖ ≤ lam_max
    calc ‖basis.repr (T.toContinuousLinearMap x)‖
        = √(‖basis.repr (T.toContinuousLinearMap x)‖ ^ 2) := by
          rw [Real.sqrt_sq (norm_nonneg _)]
      _ ≤ √(lam_max ^ 2) := Real.sqrt_le_sqrt h_norm_sq
      _ = lam_max := Real.sqrt_sq (hT.nonneg_eigenvalues finrank_euclideanSpace _)

  exact le_antisymm norm_le norm_ge

/-- If A ≤ B for positive operators, then ‖A‖ ≤ ‖B‖

    This requires deep spectral theory: For positive operators, ‖T‖ = λ_max(T).
    If A ≤ B in Löwner order, then λ_max(A) ≤ λ_max(B).
    The proof would use the variational characterization: λ_max(T) = sup{⟨Tx,x⟩ : ‖x‖=1}.
    Then A ≤ B implies ⟨Ax,x⟩ ≤ ⟨Bx,x⟩ for all x, giving λ_max(A) ≤ λ_max(B).
    -/
lemma opNorm_le_of_le {n : Type*} [Fintype n] [DecidableEq n]
    {A B : EuclideanSpace ℝ n →ₗ[ℝ] EuclideanSpace ℝ n}
    (hA : A.IsPositive) (hB : B.IsPositive) (h : A ≤ B) :
    ‖A.toContinuousLinearMap‖ ≤ ‖B.toContinuousLinearMap‖ := by
  -- Priority : 2 (derived from opNorm_le_of_le)
  -- Strategy: Use that for positive operators, ‖T‖ equals the largest eigenvalue
  -- and A ≤ B in Löwner order implies eigenvalues are ordered
  -- Key steps:
  -- 1. Show ‖A‖ = λ_max(A) and ‖B‖ = λ_max(B) (from opNorm_eq_largest_eigenvalue)
  -- 2. A ≤ B means ⟨Ax,x⟩ ≤ ⟨Bx,x⟩ for all x (definition of Löwner order)
  -- 3. For eigenvector e₀ of A with eigenvalue λ_max(A): λ_max(A) = ⟨Ae₀,e₀⟩ ≤ ⟨Be₀,e₀⟩
  -- 4. Since λ_max(B) = sup{⟨Bx,x⟩ : ‖x‖=1} and e₀ is unit: ⟨Be₀,e₀⟩ ≤ λ_max(B)
  -- 5. Combining: λ_max(A) ≤ λ_max(B), hence ‖A‖ ≤ ‖B‖
  --
  -- Handle empty case first
  by_cases hne : Nonempty n
  · -- Non-empty case: use opNorm_eq_largest_eigenvalue
    rw [LinearMap.IsPositive.opNorm_eq_largest_eigenvalue hA hne]
    rw [LinearMap.IsPositive.opNorm_eq_largest_eigenvalue hB hne]
    -- Now we need to show that the largest eigenvalue of A is at most that of B
    -- This uses the variational characterization: λ_max(T) = sup{⟨Tx,x⟩ : ‖x‖=1}
    -- For A ≤ B: ⟨Ax,x⟩ ≤ ⟨Bx,x⟩ for all x by definition of Löwner order
    -- Therefore sup{⟨Ax,x⟩ : ‖x‖=1} ≤ sup{⟨Bx,x⟩ : ‖x‖=1}

    -- Extract the hypothesis that (B - A).IsPositive from h : A ≤ B
    have h_diff : (B - A).IsPositive := LinearMap.le_def A B |>.mp h

    -- This means ⟨(B-A)x, x⟩ ≥ 0 for all x, hence ⟨Bx, x⟩ ≥ ⟨Ax, x⟩
    have h_inner : ∀ x, inner ℝ (A x) x ≤ inner ℝ (B x) x := by
      intro x
      have h_nonneg := h_diff.inner_nonneg_left x
      have h_expand : inner ℝ ((B - A) x) x = inner ℝ (B x) x - inner ℝ (A x) x := by
        rw [LinearMap.sub_apply, inner_sub_left]
      calc inner ℝ (A x) x
          = inner ℝ (B x) x - inner ℝ ((B - A) x) x := by linarith
        _ ≤ inner ℝ (B x) x := by linarith

    -- Now use that the first eigenvector achieves the maximum for the Rayleigh quotient
    -- The largest eigenvalue of A equals ⟨A e₀ᴬ, e₀ᴬ⟩ where e₀ᴬ is the first eigenvector of A
    let e0A := hA.isSymmetric.eigenvectorBasis finrank_euclideanSpace ⟨0, Fintype.card_pos⟩
    have h_norm_e0A : ‖e0A‖ = 1 := hA.isSymmetric.eigenvectorBasis finrank_euclideanSpace |>.orthonormal.1 _
    have h_eigenA := hA.isSymmetric.apply_eigenvectorBasis finrank_euclideanSpace ⟨0, Fintype.card_pos⟩

    -- For A: λ_max(A) = ⟨A e₀ᴬ, e₀ᴬ⟩
    have h_lamA : hA.isSymmetric.eigenvalues finrank_euclideanSpace ⟨0, Fintype.card_pos⟩ = inner ℝ (A e0A) e0A := by
      rw [h_eigenA, inner_smul_left, inner_self_eq_norm_sq_to_K]
      have : ‖hA.isSymmetric.eigenvectorBasis finrank_euclideanSpace ⟨0, Fintype.card_pos⟩‖ = 1 :=
        hA.isSymmetric.eigenvectorBasis finrank_euclideanSpace |>.orthonormal.1 _
      rw [this]
      simp

    -- For B: λ_max(B) ≥ ⟨B e₀ᴬ, e₀ᴬ⟩ (since the maximum is at least this value)
    -- This follows from the fact that for a positive operator, the largest eigenvalue
    -- equals the supremum of the Rayleigh quotient ⟨Bx,x⟩ over unit vectors
    have h_lamB : inner ℝ (B e0A) e0A ≤ hB.isSymmetric.eigenvalues finrank_euclideanSpace ⟨0, Fintype.card_pos⟩ := by
      -- Use the fact that ‖B‖ = λ_max(B) and ⟨Bx, x⟩ ≤ ‖B‖·‖x‖² for positive B
      -- For positive operators, ⟨Bx, x⟩ ≤ ‖B x‖·‖x‖ ≤ ‖B‖·‖x‖²
      rw [← LinearMap.IsPositive.opNorm_eq_largest_eigenvalue hB hne]
      calc inner ℝ (B e0A) e0A
          ≤ ‖B e0A‖ * ‖e0A‖ := by
            apply real_inner_le_norm
        _ ≤ ‖B.toContinuousLinearMap‖ * ‖e0A‖ * ‖e0A‖ := by
            have h_norm_bound := B.toContinuousLinearMap.le_opNorm e0A
            calc ‖B e0A‖ * ‖e0A‖
                ≤ (‖B.toContinuousLinearMap‖ * ‖e0A‖) * ‖e0A‖ := by
                  apply mul_le_mul_of_nonneg_right h_norm_bound (norm_nonneg _)
              _ = ‖B.toContinuousLinearMap‖ * ‖e0A‖ * ‖e0A‖ := by ring
        _ = ‖B.toContinuousLinearMap‖ := by
            rw [h_norm_e0A]
            ring

    -- Combine: λ_max(A) = ⟨A e₀ᴬ, e₀ᴬ⟩ ≤ ⟨B e₀ᴬ, e₀ᴬ⟩ ≤ λ_max(B)
    calc hA.isSymmetric.eigenvalues finrank_euclideanSpace ⟨0, Fintype.card_pos⟩
        = inner ℝ (A e0A) e0A := h_lamA
      _ ≤ inner ℝ (B e0A) e0A := h_inner e0A
      _ ≤ hB.isSymmetric.eigenvalues finrank_euclideanSpace ⟨0, Fintype.card_pos⟩ := h_lamB
  · -- Empty case: both norms are 0
    haveI : IsEmpty n := not_nonempty_iff.mp hne
    have card_zero : Fintype.card n = 0 := Fintype.card_eq_zero
    have finrank_zero : Module.finrank ℝ (EuclideanSpace ℝ n) = 0 := by
      simp [EuclideanSpace, PiLp]
    -- In 0-dimensional space, all linear maps have norm 0
    have hA_norm : ‖A.toContinuousLinearMap‖ = 0 := by
      rw [ContinuousLinearMap.opNorm_zero_iff]
      ext x
      have : x = 0 := Subsingleton.elim x 0
      simp [this]
    have hB_norm : ‖B.toContinuousLinearMap‖ = 0 := by
      rw [ContinuousLinearMap.opNorm_zero_iff]
      ext x
      have : x = 0 := Subsingleton.elim x 0
      simp [this]
    rw [hA_norm, hB_norm]


/- (by claude) Helper lemma: For positive definite T, eigenvalues(T⁻¹)[0] = (eigenvalues(T)[n-1])⁻¹
   The key insight is that T and T⁻¹ share the same eigenvector basis, with reciprocal eigenvalues.
   Since eigenvalues are sorted in decreasing order, the largest of the reciprocals (index 0 for T⁻¹)
   corresponds to the smallest eigenvalue (index n-1 for T).

   The proof establishes:
   1. T_inv applied to T's eigenbasis gives eigenvectors with reciprocal eigenvalues
   2. The Rayleigh quotient supremum for T_inv equals (eigenvals last)⁻¹
   3. By IsPositive.opNorm_eq_largest_eigenvalue, this supremum equals eigenvalues(T_inv)[0]
   4. Therefore eigenvalues(T_inv)[0] = (eigenvalues(T)[n-1])⁻¹
-/
-- Priority : 2 (helper for smallest_eigenvalue_bound)
lemma eigenvalues_inv_eq_inv_eigenvalues_last {n : Type*} [Fintype n] [DecidableEq n]
    {T : EuclideanSpace ℝ n →ₗ[ℝ] EuclideanSpace ℝ n}
    (hT : T.IsPosDef)
    (hk : Module.finrank ℝ (EuclideanSpace ℝ n) = Fintype.card n)
    (hne : Nonempty n)
    (T_inv : EuclideanSpace ℝ n →ₗ[ℝ] EuclideanSpace ℝ n)
    (hT_inv_symm : T_inv.IsSymmetric)
    (hT_inv_is_inverse : ∀ x, T (T_inv x) = x) :
    hT_inv_symm.eigenvalues hk ⟨0, Fintype.card_pos⟩ =
      (hT.1.isSymmetric.eigenvalues hk ⟨Fintype.card n - 1, Nat.pred_lt Fintype.card_pos.ne'⟩)⁻¹ := by
  /- (by claude) Proof outline for eigenvalues(T_inv)[0] = (eigenvalues(T)[n-1])⁻¹:

     The mathematical argument is:
     1. T has an orthonormal eigenbasis {e_i} with eigenvalues λ_i sorted decreasingly
     2. For each eigenvector e_i of T with eigenvalue λ_i > 0:
        T_inv(e_i) = λ_i⁻¹ · e_i (since T(λ_i⁻¹e_i) = λ_i⁻¹·T(e_i) = λ_i⁻¹·λ_i·e_i = e_i)
     3. So T_inv has the same eigenbasis with eigenvalues λ_i⁻¹
     4. Since eigenvalues are sorted in decreasing order:
        - For T: λ_0 ≥ λ_1 ≥ ... ≥ λ_{n-1} > 0
        - For T_inv: the eigenvalues {λ_i⁻¹} when sorted decreasingly give:
          λ_{n-1}⁻¹ ≥ ... ≥ λ_1⁻¹ ≥ λ_0⁻¹ > 0
     5. So eigenvalues(T_inv)[0] = λ_{n-1}⁻¹ = (eigenvalues(T)[n-1])⁻¹

     This requires:
     - Proving T_inv maps T's eigenvectors to eigenvectors with reciprocal eigenvalues
     - Showing the multiset of eigenvalues of T_inv equals {λ_i⁻¹}
     - Connecting the abstract eigenvalue sorting to the explicit computation

     These require infrastructure not readily available in Mathlib for directly connecting
     the spectral theorem's abstract construction to explicit eigenvector calculations. -/

  -- (by claude) Partial proof: establish the eigenvector properties
  let hT_symm := hT.1.isSymmetric
  let basis := hT_symm.eigenvectorBasis hk
  let eigs := hT_symm.eigenvalues hk

  -- Eigenvalues of T are positive (using the same proof structure from smallest_eigenvalue_bound)
  have eigs_pos : ∀ i, 0 < eigs i := by
    intro i
    have h_nonneg := hT.1.nonneg_eigenvalues hk i
    by_contra h_not_pos
    push_neg at h_not_pos
    have h_eq_zero := le_antisymm h_not_pos h_nonneg
    have h_eigenvec := hT_symm.hasEigenvector_eigenvectorBasis hk i
    have h_apply := hT_symm.apply_eigenvectorBasis hk i
    have h_T_zero : T (basis i) = 0 := by
      rw [h_apply]
      -- (by claude) h_eq_zero : eigs i = 0 = hT_symm.eigenvalues hk i = 0
      -- The coercion ↑(eigenvalues hk i) to ℝ is identity since 𝕜 = ℝ
      have : (↑(hT_symm.eigenvalues hk i) : ℝ) = 0 := h_eq_zero
      rw [this]
      simp
    have h_basis_ne : basis i ≠ 0 := h_eigenvec.2
    have h_det_ne : LinearMap.det T ≠ 0 := hT.2
    have h_det_eq : LinearMap.det T = 0 := by
      rw [LinearMap.det_eq_zero_iff_ker_ne_bot]
      rw [ne_eq, LinearMap.ker_eq_bot]
      intro h_inj
      apply h_basis_ne
      have : T 0 = 0 := LinearMap.map_zero T
      exact h_inj (h_T_zero.trans this.symm)
    exact h_det_ne h_det_eq

  -- T_inv maps eigenvectors of T to eigenvectors with reciprocal eigenvalues
  have h_Tinv_eigenvec : ∀ i, T_inv (basis i) = (eigs i)⁻¹ • basis i := by
    intro i
    have h_T_apply := hT_symm.apply_eigenvectorBasis hk i
    have h_lhs : T (T_inv (basis i)) = basis i := hT_inv_is_inverse (basis i)
    have h_rhs : T ((eigs i)⁻¹ • basis i) = basis i := by
      rw [LinearMap.map_smul, h_T_apply, smul_smul]
      -- (by claude) Need to show (eigs i)⁻¹ * eigs i = 1
      -- In our context 𝕜 = ℝ so ↑(eigenvalues hk i) = eigenvalues hk i definitionally
      have h_eq : (eigs i)⁻¹ * eigs i = 1 := inv_mul_cancel₀ (ne_of_gt (eigs_pos i))
      convert one_smul ℝ (basis i) using 2
    have hT_inj : Function.Injective T := by
      -- (by claude) Since det T ≠ 0, T is a linear equivalence, hence injective
      have h_unit : IsUnit (LinearMap.det T) := by simp [hT.2]
      intro x y hxy
      have hx : (LinearMap.equivOfIsUnitDet h_unit) x = T x := LinearMap.equivOfIsUnitDet_apply h_unit x
      have hy : (LinearMap.equivOfIsUnitDet h_unit) y = T y := LinearMap.equivOfIsUnitDet_apply h_unit y
      exact (LinearMap.equivOfIsUnitDet h_unit).injective (hx.trans (hxy.trans hy.symm))
    exact hT_inj (h_lhs.trans h_rhs.symm)

  /- (by claude) KEY INSIGHT: Use the Rayleigh quotient / operator norm approach.
     By opNorm_eq_largest_eigenvalue:
       eigenvalues(T_inv)[0] = ‖T_inv‖ = sup{⟨T_inv x, x⟩ : ‖x‖ = 1}
     We show this supremum equals (eigs (n-1))⁻¹ = (eigenvalues(T)[n-1])⁻¹.

     The key is that T_inv has the same eigenbasis as T with reciprocal eigenvalues.
     Since ⟨T_inv (basis j), basis j⟩ = (eigs j)⁻¹ for orthonormal basis j,
     and the eigenbasis spans the space, the sup is achieved at the eigenvector
     with largest reciprocal eigenvalue, which is (eigs (n-1))⁻¹.
  -/

  /- (by claude) Strategy: Show both sides equal ‖T_inv‖ using opNorm_eq_largest_eigenvalue,
     then show ‖T_inv‖ = (eigs (n-1))⁻¹ by direct computation with the eigenbasis. -/

  /- (by claude) T_inv is positive (we need this for opNorm_eq_largest_eigenvalue) -/
  have hT_inv_pos : T_inv.IsPositive := by
    constructor
    · exact hT_inv_symm
    · intro x
      /- (by claude) ⟨T_inv x, x⟩ = ⟨T_inv x, T (T_inv x)⟩ = ⟨T y, y⟩ ≥ 0 where y = T_inv x -/
      let y := T_inv x
      have hy : T y = x := hT_inv_is_inverse x
      have h_symm : inner ℝ y (T y) = inner ℝ (T y) y := real_inner_comm _ _
      have h_nonneg := hT.1.2 y
      simp only [RCLike.re_to_real] at h_nonneg
      calc inner ℝ (T_inv x) x
          = inner ℝ y (T y) := by rw [hy]
        _ = inner ℝ (T y) y := h_symm
        _ ≥ 0 := h_nonneg

  /- (by claude) By opNorm_eq_largest_eigenvalue, eigenvalues(T_inv)[0] = ‖T_inv‖ -/
  have h_T_inv_opNorm : hT_inv_symm.eigenvalues hk ⟨0, Fintype.card_pos⟩ = ‖T_inv.toContinuousLinearMap‖ := by
    /- (by claude) Need to show hT_inv_symm = hT_inv_pos.isSymmetric for definitional equality -/
    have h_symm_eq : hT_inv_symm = hT_inv_pos.isSymmetric := rfl
    rw [h_symm_eq]
    exact (LinearMap.IsPositive.opNorm_eq_largest_eigenvalue hT_inv_pos hne).symm

  /- (by claude) Similarly, eigenvalues(T)[n-1] = smallest eigenvalue of T.
     We'll show ‖T_inv‖ = (eigs (n-1))⁻¹ by explicit computation. -/

  /- (by claude) First show ‖T_inv‖ ≥ (eigs (n-1))⁻¹ using the (n-1)-th eigenvector -/
  have h_norm_ge : ‖T_inv.toContinuousLinearMap‖ ≥ (eigs ⟨Fintype.card n - 1, Nat.pred_lt Fintype.card_pos.ne'⟩)⁻¹ := by
    let i_last : Fin (Fintype.card n) := ⟨Fintype.card n - 1, Nat.pred_lt Fintype.card_pos.ne'⟩
    have h_basis_norm : ‖basis i_last‖ = 1 := basis.orthonormal.1 i_last
    have h_Tinv_apply := h_Tinv_eigenvec i_last
    calc ‖T_inv.toContinuousLinearMap‖
        ≥ ‖T_inv.toContinuousLinearMap (basis i_last)‖ := by
          apply ContinuousLinearMap.unit_le_opNorm
          rw [h_basis_norm]
      _ = ‖T_inv (basis i_last)‖ := rfl
      _ = ‖(eigs i_last)⁻¹ • basis i_last‖ := by rw [h_Tinv_apply]
      _ = |(eigs i_last)⁻¹| * ‖basis i_last‖ := norm_smul _ _
      _ = (eigs i_last)⁻¹ := by
          rw [h_basis_norm, mul_one]
          exact abs_of_pos (inv_pos.mpr (eigs_pos i_last))

  /- (by claude) Now show ‖T_inv‖ ≤ (eigs (n-1))⁻¹ by showing all eigenvector norms are bounded -/
  have h_norm_le : ‖T_inv.toContinuousLinearMap‖ ≤ (eigs ⟨Fintype.card n - 1, Nat.pred_lt Fintype.card_pos.ne'⟩)⁻¹ := by
    apply ContinuousLinearMap.opNorm_le_of_unit_norm
    · exact inv_nonneg.mpr (le_of_lt (eigs_pos _))
    intro x hx_norm

    /- (by claude) Express x in the eigenbasis and bound ‖T_inv x‖ -/
    let lam_min := eigs ⟨Fintype.card n - 1, Nat.pred_lt Fintype.card_pos.ne'⟩

    /- (by claude) The reciprocal eigenvalues: (eigs i)⁻¹ ≤ lam_min⁻¹ for all i -/
    have h_recip_le : ∀ i, (eigs i)⁻¹ ≤ lam_min⁻¹ := by
      intro i
      /- (by claude) eigs is antitone, so eigs i ≥ eigs (n-1) = lam_min
         We need lam_min ≤ eigs i to apply inv_anti₀ -/
      have h_antitone := hT_symm.eigenvalues_antitone hk
      /- (by claude) Show i ≤ last index. Fin.le_last requires Fin (n+1) form,
         so we prove directly using i.val < Fintype.card n -/
      have h_le_last : i ≤ ⟨Fintype.card n - 1, Nat.pred_lt Fintype.card_pos.ne'⟩ := by
        simp only [Fin.le_iff_val_le_val]
        exact Nat.le_pred_of_lt i.isLt
      have h_lam_le_eigs : lam_min ≤ eigs i := h_antitone h_le_last
      exact inv_anti₀ (eigs_pos _) h_lam_le_eigs

    /- (by claude) For each i, (eigs i)⁻¹ ≥ 0 -/
    have h_recip_nonneg : ∀ i, 0 ≤ (eigs i)⁻¹ := fun i => inv_nonneg.mpr (le_of_lt (eigs_pos i))

    /- (by claude) Use eigenbasis isometry: ‖x‖ = ‖basis.repr x‖ -/
    have h_iso : ‖basis.repr x‖ = ‖x‖ := basis.repr.norm_map x

    /- (by claude) T_inv acts on coordinates by reciprocal eigenvalue multiplication -/
    have h_coord : ∀ i, (basis.repr (T_inv x)).ofLp i = (eigs i)⁻¹ * (basis.repr x).ofLp i := by
      intro i
      /- (by claude) T_inv = (eigs i)⁻¹ on the i-th eigenspace, and
         eigenvectorBasis_apply_self_apply gives the action on coordinates -/
      have h_apply := hT_symm.apply_eigenvectorBasis hk i
      /- (by claude) We need: basis.repr (T_inv x) i = (eigs i)⁻¹ * basis.repr x i
         Since T_inv (basis i) = (eigs i)⁻¹ • basis i, we have by linearity:
         T_inv (∑ c_i • basis i) = ∑ (eigs i)⁻¹ c_i • basis i
         So the i-th coordinate is multiplied by (eigs i)⁻¹ -/

      /- (by claude) Use that basis.repr x i = ⟨basis i, x⟩ for orthonormal basis
         Note: repr_apply_apply gives inner ℝ (basis j) x, we need real_inner_comm -/
      have h_repr_inner : ∀ j : Fin (Fintype.card n), (basis.repr x).ofLp j = inner ℝ x (basis j) := by
        intro j
        rw [basis.repr_apply_apply x j]
        exact real_inner_comm _ _

      /- (by claude) Similarly for T_inv x -/
      have h_repr_inner_Tinv : (basis.repr (T_inv x)).ofLp i = inner ℝ (T_inv x) (basis i) := by
        rw [basis.repr_apply_apply (T_inv x) i]
        exact real_inner_comm _ _

      rw [h_repr_inner_Tinv, h_repr_inner]

      /- (by claude) inner (T_inv x) (basis i) = inner x (T_inv (basis i)) by symmetry
         hT_inv_symm u v gives: inner (T_inv u) v = inner u (T_inv v)
         So hT_inv_symm x (basis i) gives: inner (T_inv x) (basis i) = inner x (T_inv (basis i)) -/
      rw [hT_inv_symm x (basis i)]

      /- (by claude) Now use T_inv (basis i) = (eigs i)⁻¹ • basis i -/
      rw [h_Tinv_eigenvec i, inner_smul_right]

    /- (by claude) Now bound ‖T_inv x‖ using the coordinate formula -/
    have h_iso_T : ‖T_inv x‖ = ‖basis.repr (T_inv x)‖ := (basis.repr.norm_map _).symm

    /- (by claude) The goal has ‖(LinearMap.toContinuousLinearMap T_inv) x‖ which equals ‖T_inv x‖ -/
    show ‖T_inv x‖ ≤ _
    rw [h_iso_T]

    /- (by claude) ‖basis.repr (T_inv x)‖² = ∑ |(eigs i)⁻¹ * (basis.repr x) i|² ≤ lam_min⁻² * ‖x‖² -/
    have h_norm_sq : ‖basis.repr (T_inv x)‖ ^ 2 ≤ lam_min⁻¹ ^ 2 := by
      rw [EuclideanSpace.norm_sq_eq]
      calc ∑ i, ‖(basis.repr (T_inv x)).ofLp i‖ ^ 2
          = ∑ i, ‖(eigs i)⁻¹ * (basis.repr x).ofLp i‖ ^ 2 := by simp_rw [h_coord]
        _ = ∑ i, (eigs i)⁻¹ ^ 2 * ‖(basis.repr x).ofLp i‖ ^ 2 := by
            congr 1; ext i
            rw [norm_mul, mul_pow]
            congr 1
            simp only [sq, Real.norm_of_nonneg (h_recip_nonneg _)]
        _ ≤ ∑ i, lam_min⁻¹ ^ 2 * ‖(basis.repr x).ofLp i‖ ^ 2 := by
            apply Finset.sum_le_sum
            intro i _
            apply mul_le_mul_of_nonneg_right
            · exact pow_le_pow_left₀ (h_recip_nonneg _) (h_recip_le i) 2
            · exact sq_nonneg _
        _ = lam_min⁻¹ ^ 2 * ∑ i, ‖(basis.repr x).ofLp i‖ ^ 2 := by rw [← Finset.mul_sum]
        _ = lam_min⁻¹ ^ 2 * ‖basis.repr x‖ ^ 2 := by rw [← EuclideanSpace.norm_sq_eq]
        _ = lam_min⁻¹ ^ 2 * ‖x‖ ^ 2 := by rw [h_iso]
        _ = lam_min⁻¹ ^ 2 := by rw [hx_norm, one_pow, mul_one]

    calc ‖basis.repr (T_inv x)‖
        = √(‖basis.repr (T_inv x)‖ ^ 2) := by rw [Real.sqrt_sq (norm_nonneg _)]
      _ ≤ √(lam_min⁻¹ ^ 2) := Real.sqrt_le_sqrt h_norm_sq
      _ = lam_min⁻¹ := Real.sqrt_sq (h_recip_nonneg _)

  /- (by claude) Conclude: eigenvalues(T_inv)[0] = ‖T_inv‖ = (eigs (n-1))⁻¹ = (eigenvalues(T)[n-1])⁻¹ -/
  rw [h_T_inv_opNorm]
  exact le_antisymm h_norm_le h_norm_ge

/-- The smallest eigenvalue of a positive definite operator equals ‖T^{-1}‖^{-1} -/
lemma LinearMap.IsPosDef.smallest_eigenvalue_bound {n : Type*} [Fintype n] [DecidableEq n]
    {T : EuclideanSpace ℝ n →ₗ[ℝ] EuclideanSpace ℝ n}
    (hT : T.IsPosDef)
    (hk : Module.finrank ℝ (EuclideanSpace ℝ n) = Fintype.card n)
    (hne : Nonempty n) :
    hT.1.isSymmetric.eigenvalues hk ⟨Fintype.card n - 1, Nat.pred_lt Fintype.card_pos.ne'⟩ =
      ‖(T.equivOfIsUnitDet (by simp [hT.2])).symm.toLinearMap.toContinuousLinearMap‖₊⁻¹ := by
  -- Priority : 2
  -- Strategy: Connect smallest eigenvalue λ_min to inverse operator norm
  -- Key steps:
  -- 1. For positive definite T, eigenvalues are sorted: λ₁ ≥ ... ≥ λₙ > 0
  -- 2. λₙ (smallest) = min{⟨Tx,x⟩ : ‖x‖=1} (Rayleigh quotient characterization)
  -- 3. For T⁻¹: largest eigenvalue is λₙ⁻¹ (eigenvalues of inverse are reciprocals)
  -- 4. ‖T⁻¹‖ = λ_max(T⁻¹) = λₙ⁻¹ (operator norm equals largest eigenvalue)
  -- 5. Therefore: λₙ = ‖T⁻¹‖⁻¹
  --
  -- Requires lemmas not yet in mathlib:
  -- - Rayleigh quotient theory for minimum (IsSelfAdjoint.hasEigenvector_of_isMinOn)
  -- - Eigenvalues of T⁻¹ are reciprocals of eigenvalues of T
  -- - Relationship between smallest eigenvalue and infimum of Rayleigh quotient
  --
  -- This is a deep result in spectral theory requiring substantial infrastructure.
  -- A complete proof would involve:
  -- (a) Showing T⁻¹ is also positive definite (available: Matrix.PosDef.inv)
  -- (b) Showing eigenvalues of T⁻¹ are {λᵢ⁻¹} (not in mathlib)
  -- (c) Showing largest eigenvalue of T⁻¹ is λₙ⁻¹ (follows from (b))
  -- (d) Applying LinearMap.IsPositive.opNorm_eq_largest_eigenvalue to T⁻¹
  --
  -- === DETAILED PROOF APPROACH ===
  --
  -- Given: T is positive definite on EuclideanSpace ℝ n
  -- Want: λ_min(T) = ‖T⁻¹‖⁻¹
  --
  -- STEP 1: Show T⁻¹ is positive definite
  -- - T⁻¹ exists since T.det ≠ 0 (from IsPosDef)
  -- - T⁻¹ is symmetric: (T⁻¹)^* = (T^*)⁻¹ = T⁻¹ (since T = T^*)
  -- - T⁻¹ is positive: ⟨T⁻¹ x, x⟩ = ⟨T⁻¹ x, T(T⁻¹ x)⟩ = ⟨y, Ty⟩ > 0 for y = T⁻¹ x ≠ 0
  --
  -- STEP 2: Eigenvalues of T⁻¹ are reciprocals of eigenvalues of T
  -- Let e_i be eigenvector of T with eigenvalue λ_i (so T e_i = λ_i e_i)
  -- Then: T⁻¹ e_i = T⁻¹ (λ_i⁻¹ T e_i) = λ_i⁻¹ e_i
  -- So e_i is eigenvector of T⁻¹ with eigenvalue λ_i⁻¹
  -- The eigenbasis is the same, but eigenvalues are inverted
  --
  -- STEP 3: Connect eigenvalues
  -- - λ_min(T) = λ_n = smallest eigenvalue of T
  -- - λ_max(T⁻¹) = max{λ_i⁻¹} = (min{λ_i})⁻¹ = λ_n⁻¹
  --
  -- STEP 4: Apply opNorm result
  -- - By LinearMap.IsPositive.opNorm_eq_largest_eigenvalue for T⁻¹:
  --   ‖T⁻¹‖ = λ_max(T⁻¹) = λ_n⁻¹
  -- - Therefore: λ_n = ‖T⁻¹‖⁻¹
  --
  -- INFRASTRUCTURE NEEDED:
  -- 1. Eigenvectors of T⁻¹ are same as eigenvectors of T (for invertible T)
  -- 2. Eigenvalue of T⁻¹ for eigenvector e is λ⁻¹ where λ is eigenvalue of T for e
  -- 3. T⁻¹ is positive definite when T is positive definite
  --
  -- Now we have Module.End.inv_eigenvalue' imported which gives:
  -- HasEigenvalue T λ → HasEigenvalue T⁻¹ λ⁻¹
  --
  -- However, the remaining challenge is connecting sorted eigenvalues:
  -- We need to show that eigenvalues(T⁻¹)[0] = eigenvalues(T)[n-1]⁻¹
  --
  -- This requires proving:
  -- 1. T⁻¹ is positive (hence symmetric) - needed to apply spectral theorem
  -- 2. The sorted eigenvalues of T⁻¹ are the reciprocals of sorted eigenvalues of T (in reversed order)
  --
  -- Step 1: Show T⁻¹ is positive
  -- For a positive definite T, its matrix representation is positive definite,
  -- and Matrix.PosDef.inv shows the inverse matrix is positive definite.
  -- We need to translate this back to LinearMap.IsPositive.

  -- Get the linear equivalence for T and its inverse
  let T_equiv := T.equivOfIsUnitDet (by simp [hT.2])
  let T_inv := T_equiv.symm.toLinearMap

  -- T_inv is the inverse of T
  have hT_inv_def : T_inv = T_equiv.symm.toLinearMap := rfl

  -- T_inv is symmetric (self-adjoint) because T is symmetric and invertible
  have hT_inv_symm : T_inv.IsSymmetric := by
    intro x y
    -- T⁻¹ is symmetric iff ⟨T⁻¹ x, y⟩ = ⟨x, T⁻¹ y⟩
    -- Since T is symmetric: ⟨T u, v⟩ = ⟨u, T v⟩
    -- Let u = T⁻¹ x and v = T⁻¹ y
    -- Then ⟨T⁻¹ x, y⟩ = ⟨T⁻¹ x, T (T⁻¹ y)⟩ = ⟨T (T⁻¹ x), T⁻¹ y⟩ = ⟨x, T⁻¹ y⟩
    have hT_symm : T.IsSymmetric := hT.1.isSymmetric
    -- T_equiv.toLinearMap = T (via coe_equivOfIsUnitDet)
    have hT_eq : (T_equiv : EuclideanSpace ℝ n →ₗ[ℝ] EuclideanSpace ℝ n) = T :=
      LinearMap.coe_equivOfIsUnitDet _
    calc inner ℝ (T_inv x) y
        = inner ℝ (T_inv x) (T_equiv (T_equiv.symm y)) := by
          rw [T_equiv.apply_symm_apply]
      _ = inner ℝ (T_inv x) (T (T_inv y)) := by
          simp only [← hT_eq]; rfl
      _ = inner ℝ (T (T_inv x)) (T_inv y) := (hT_symm (T_inv x) (T_inv y)).symm
      _ = inner ℝ (T_equiv (T_equiv.symm x)) (T_inv y) := by
          simp only [← hT_eq]; rfl
      _ = inner ℝ x (T_inv y) := by
          rw [T_equiv.apply_symm_apply]

  -- T_equiv.toLinearMap = T (via coe_equivOfIsUnitDet)
  have hT_eq' : (T_equiv : EuclideanSpace ℝ n →ₗ[ℝ] EuclideanSpace ℝ n) = T :=
    LinearMap.coe_equivOfIsUnitDet _

  -- T_inv is positive: ⟨T⁻¹ x, x⟩ ≥ 0 for all x
  have hT_inv_pos : T_inv.IsPositive := by
    constructor
    · exact hT_inv_symm
    · intro x
      -- ⟨T⁻¹ x, x⟩ = ⟨T⁻¹ x, T (T⁻¹ x)⟩ = ⟨T y, y⟩ ≥ 0 where y = T⁻¹ x
      let y := T_inv x
      -- T y = T_equiv (T_equiv.symm x) = x
      have hy : T y = x := by
        simp only [← hT_eq']
        exact T_equiv.apply_symm_apply x
      -- For real inner products, ⟨a, b⟩ = ⟨b, a⟩ (symmetric)
      have h_symm : inner ℝ y (T y) = inner ℝ (T y) y := real_inner_comm _ _
      -- hT.1 gives IsPositive T, and its second component gives the inner product bound
      have h_nonneg := hT.1.2 y
      -- inner ℝ returns real values, and RCLike.re is id on ℝ
      simp only [RCLike.re_to_real] at h_nonneg
      calc inner ℝ (T_inv x) x
          = inner ℝ y (T y) := by rw [hy]
        _ = inner ℝ (T y) y := h_symm
        _ ≥ 0 := h_nonneg

  -- Now we can apply opNorm_eq_largest_eigenvalue to T_inv
  -- ‖T⁻¹‖ = eigenvalues(T⁻¹)[0] (largest eigenvalue of T⁻¹)
  have hT_inv_opNorm : ‖T_inv.toContinuousLinearMap‖ =
      hT_inv_pos.isSymmetric.eigenvalues hk ⟨0, Fintype.card_pos⟩ := by
    exact LinearMap.IsPositive.opNorm_eq_largest_eigenvalue hT_inv_pos hne

  -- The key missing step is to show:
  -- eigenvalues(T⁻¹)[0] = eigenvalues(T)[n-1]⁻¹
  --
  -- This would follow from:
  -- 1. eigenvalues(T⁻¹) = reverse(map (·⁻¹) eigenvalues(T)) (as multisets)
  -- 2. Sorted eigenvalues: if T has eigenvalues λ₁ ≥ ... ≥ λₙ > 0,
  --    then T⁻¹ has eigenvalues λₙ⁻¹ ≥ ... ≥ λ₁⁻¹ > 0
  --
  -- Unfortunately, this requires infrastructure for:
  -- - Connecting eigenvalues as multisets between T and T⁻¹
  -- - Showing that inversion reverses the order when sorted in decreasing order
  --
  -- The lemma Module.End.inv_eigenvalue' only gives HasEigenvalue, not the full
  -- correspondence of sorted eigenvalues via the spectral theorem.
  --
  -- We'd need to prove something like:
  -- ∀ i, hT_inv_pos.isSymmetric.eigenvalues hk i = (hT.1.isSymmetric.eigenvalues hk (n-1-i))⁻¹
  --
  -- This is a substantial result requiring careful analysis of the spectral theorem
  -- construction and how eigenvalues are sorted.

  -- (by claude) Use the helper lemma to establish the connection
  -- First, we need: T (T_inv x) = x for the helper lemma
  have hT_inv_is_inverse : ∀ x, T (T_inv x) = x := by
    intro x
    simp only [← hT_eq']
    exact T_equiv.apply_symm_apply x

  -- Apply the helper lemma: eigenvalues(T_inv)[0] = (eigenvalues(T)[n-1])⁻¹
  -- Note: hT_inv_symm and hT_inv_pos.isSymmetric are both proofs of T_inv.IsSymmetric
  have h_eig_inv : hT_inv_symm.eigenvalues hk ⟨0, Fintype.card_pos⟩ =
      (hT.1.isSymmetric.eigenvalues hk ⟨Fintype.card n - 1, Nat.pred_lt Fintype.card_pos.ne'⟩)⁻¹ :=
    eigenvalues_inv_eq_inv_eigenvalues_last hT hk hne T_inv hT_inv_symm hT_inv_is_inverse

  -- The goal is: eigenvalues(T)[n-1] = ‖T_inv‖⁻¹
  -- We have: ‖T_inv‖ = eigenvalues(T_inv)[0] (from hT_inv_opNorm)
  -- And: eigenvalues(T_inv)[0] = (eigenvalues(T)[n-1])⁻¹ (from h_eig_inv)
  -- Therefore: eigenvalues(T)[n-1] = (eigenvalues(T_inv)[0])⁻¹ = ‖T_inv‖⁻¹

  -- First, show the eigenvalue functions are the same (proof irrelevance)
  have h_eig_eq : hT_inv_symm.eigenvalues hk ⟨0, Fintype.card_pos⟩ =
      hT_inv_pos.isSymmetric.eigenvalues hk ⟨0, Fintype.card_pos⟩ := by
    rfl  -- They should be definitionally equal

  -- Now combine: eigenvalues(T)[n-1] = (eigenvalues(T_inv)[0])⁻¹ = ‖T_inv‖⁻¹
  -- From h_eig_inv: eigenvalues(T_inv)[0] = (eigenvalues(T)[n-1])⁻¹
  -- Therefore: eigenvalues(T)[n-1] = (eigenvalues(T_inv)[0])⁻¹

  -- (by claude) The positive definite eigenvalue is nonzero, so we can invert
  have h_eig_T_pos : 0 < hT.1.isSymmetric.eigenvalues hk ⟨Fintype.card n - 1, Nat.pred_lt Fintype.card_pos.ne'⟩ := by
    have h_nonneg := hT.1.nonneg_eigenvalues hk ⟨Fintype.card n - 1, Nat.pred_lt Fintype.card_pos.ne'⟩
    -- Need to show strictly positive, not just nonnegative
    -- For positive definite T (det ≠ 0), all eigenvalues are strictly positive
    -- because if λ = 0, then T v = 0 for some v ≠ 0, contradicting det T ≠ 0
    by_contra h_not_pos
    push_neg at h_not_pos
    have h_eq_zero := le_antisymm h_not_pos h_nonneg
    -- λ = 0 implies T has nontrivial kernel, contradicting det T ≠ 0
    -- The eigenvector for eigenvalue 0 would be in ker(T)
    have h_eigenvec := hT.1.isSymmetric.hasEigenvector_eigenvectorBasis hk ⟨Fintype.card n - 1, Nat.pred_lt Fintype.card_pos.ne'⟩
    have h_apply := hT.1.isSymmetric.apply_eigenvectorBasis hk ⟨Fintype.card n - 1, Nat.pred_lt Fintype.card_pos.ne'⟩
    -- T(e) = 0 * e = 0 for the eigenvector e
    have h_T_zero : T (hT.1.isSymmetric.eigenvectorBasis hk ⟨Fintype.card n - 1, Nat.pred_lt Fintype.card_pos.ne'⟩) = 0 := by
      rw [h_apply]
      simp only [h_eq_zero, RCLike.ofReal_zero, zero_smul]
    -- But e ≠ 0, so T has nontrivial kernel
    have h_basis_ne : hT.1.isSymmetric.eigenvectorBasis hk ⟨Fintype.card n - 1, Nat.pred_lt Fintype.card_pos.ne'⟩ ≠ 0 :=
      h_eigenvec.2
    -- This contradicts det T ≠ 0
    have h_det_ne : LinearMap.det T ≠ 0 := hT.2
    have h_det_eq : LinearMap.det T = 0 := by
      rw [LinearMap.det_eq_zero_iff_ker_ne_bot]
      rw [ne_eq, LinearMap.ker_eq_bot]
      intro h_inj
      apply h_basis_ne
      have : T 0 = 0 := LinearMap.map_zero T
      exact h_inj (h_T_zero.trans this.symm)
    exact h_det_ne h_det_eq

  -- Now we can invert h_eig_inv
  have h_inv_eq : hT.1.isSymmetric.eigenvalues hk ⟨Fintype.card n - 1, Nat.pred_lt Fintype.card_pos.ne'⟩ =
      (hT_inv_symm.eigenvalues hk ⟨0, Fintype.card_pos⟩)⁻¹ := by
    rw [h_eig_inv]
    exact (inv_inv _).symm

  rw [h_inv_eq, h_eig_eq, ← hT_inv_opNorm]
  -- Goal should now be: ‖T_inv‖⁻¹ = ‖T_equiv.symm‖⁻¹
  -- But T_inv = T_equiv.symm by definition
  rfl


/-! ## Section 10: Additional Utility Lemmas -/

/-- rpow is monotone for positive exponents -/
lemma NNReal.rpow_mono_left {x y : NNReal} (h : x ≤ y) {r : ℝ} (hr : 0 ≤ r) :
    x.rpow r ≤ y.rpow r :=
  NNReal.rpow_le_rpow h hr

/-- rpow with zero gives 1 -/
lemma NNReal.one_rpow' (r : ℝ) : (1 : NNReal).rpow r = 1 := NNReal.one_rpow r

/-! ## Section 11: Complete Proof Structure Lemmas -/

/-- The smallest eigenvalue is monotone with respect to Löwner order.
    If A ≤ B for positive operators, then λ_min(A) ≤ λ_min(B).
    This follows from the Rayleigh quotient characterization:
    λ_min(T) = inf{⟨Tx, x⟩ : ‖x‖=1} for symmetric T.

    Proof sketch:
    - For A ≤ B, (B - A).IsPositive, so ⟨Ax, x⟩ ≤ ⟨Bx, x⟩ for all x
    - Let e_B be the eigenvector for λ_min(B) with ‖e_B‖=1
    - λ_min(B) = ⟨B e_B, e_B⟩
    - λ_min(A) = inf{⟨Ax,x⟩ : ‖x‖=1} ≤ ⟨A e_B, e_B⟩ ≤ ⟨B e_B, e_B⟩ = λ_min(B)

    The formal proof requires expanding vectors in eigenbases and using Parseval's identity.
    This is a standard result in spectral theory. -/
lemma smallest_eigenvalue_le_of_le {n : Type*} [Fintype n] [DecidableEq n]
    {A B : EuclideanSpace ℝ n →ₗ[ℝ] EuclideanSpace ℝ n}
    (hA : A.IsPositive) (hB : B.IsPositive) (h : A ≤ B) (hne : Nonempty n) :
    hA.isSymmetric.eigenvalues finrank_euclideanSpace ⟨Fintype.card n - 1, Nat.pred_lt Fintype.card_pos.ne'⟩ ≤
    hB.isSymmetric.eigenvalues finrank_euclideanSpace ⟨Fintype.card n - 1, Nat.pred_lt Fintype.card_pos.ne'⟩ := by
  /- The proof uses the Rayleigh quotient characterization:
     λ_min(T) = min{⟨Tx,x⟩ : ‖x‖=1} for symmetric T.

     Key steps:
     1. A ≤ B means (B-A).IsPositive, so ⟨Ax,x⟩ ≤ ⟨Bx,x⟩ for all x
     2. λ_min(A) = min{⟨Ax,x⟩} ≤ ⟨Ax,x⟩ for any unit x
     3. Choosing x = e_B (B's smallest eigenvector): λ_min(A) ≤ ⟨A e_B, e_B⟩ ≤ ⟨B e_B, e_B⟩ = λ_min(B)

     The formal proof structure:
     - Get B's eigenbasis with basisB := hB.isSymmetric.eigenvectorBasis
     - Let e_B := basisB(d-1) be the smallest eigenvector (eigenvalues sorted decreasing)
     - Show ⟨B e_B, e_B⟩ = λ_min(B) using apply_eigenvectorBasis and inner_eq_one
     - Show ⟨Ax,x⟩ ≤ ⟨Bx,x⟩ using (B-A).IsPositive.inner_nonneg_left
     - Show λ_min(A) ≤ ⟨A e_B, e_B⟩ using spectral decomposition:
       ⟨Ax,x⟩ = ∑_i λ_i(A)|c_i|² ≥ λ_min(A)·∑_i|c_i|² = λ_min(A)·‖x‖² = λ_min(A)
       where the last step uses eigenvalues_antitone

     This is a standard result; the Mathlib API complexity makes formal proof lengthy. -/
  /- (by claude) PROOF:
     The proof uses the Rayleigh quotient characterization combined with the Löwner order.
     Key insight: For A ≤ B (Löwner order), ⟪Ax, x⟫ ≤ ⟪Bx, x⟫ for all x.
     Taking x = e_B (B's smallest eigenvector with ‖e_B‖ = 1):
     λ_min(A) ≤ ⟪A e_B, e_B⟫ ≤ ⟪B e_B, e_B⟫ = λ_min(B)
  -/
  let d := Fintype.card n
  let hk : Module.finrank ℝ (EuclideanSpace ℝ n) = d := finrank_euclideanSpace

  /- (by claude) Get the index for the smallest eigenvalue -/
  let i_min : Fin d := ⟨d - 1, Nat.pred_lt Fintype.card_pos.ne'⟩

  /- (by claude) d > 0 from Nonempty n, so (d-1)+1 = d -/
  have hd_pos : 0 < d := Fintype.card_pos

  /- (by claude) Get B's orthonormal eigenvector basis -/
  let basisB := hB.isSymmetric.eigenvectorBasis hk

  /- (by claude) Let e_B be B's smallest eigenvector -/
  let e_B := basisB i_min

  /- (by claude) e_B has norm 1 since basisB is orthonormal -/
  have h_norm_eB : ‖e_B‖ = 1 := basisB.orthonormal.1 i_min

  /- (by claude) Step 1: A ≤ B implies (B - A).IsPositive, so ⟪Ax, x⟫ ≤ ⟪Bx, x⟫ for all x -/
  have h_BA_pos : (B - A).IsPositive := h

  /- (by claude) For any x, 0 ≤ ⟪(B-A)x, x⟫ which means ⟪Ax, x⟫ ≤ ⟪Bx, x⟫ -/
  have h_inner_le : ∀ x, @inner ℝ _ _ (A x) x ≤ @inner ℝ _ _ (B x) x := by
    intro x
    have h1 := h_BA_pos.inner_nonneg_left x
    simp only [LinearMap.sub_apply, inner_sub_left] at h1
    linarith

  /- (by claude) Step 2: ⟪B e_B, e_B⟫ = λ_min(B) -/
  have h_B_eig : B e_B = (hB.isSymmetric.eigenvalues hk i_min : ℝ) • e_B := by
    exact hB.isSymmetric.apply_eigenvectorBasis hk i_min

  have h_inner_B_eB : @inner ℝ _ _ (B e_B) e_B = hB.isSymmetric.eigenvalues hk i_min := by
    rw [h_B_eig]
    rw [inner_smul_left]
    simp only [RCLike.conj_to_real]
    rw [real_inner_self_eq_norm_sq, h_norm_eB]
    ring

  /- (by claude) Step 3: λ_min(A) ≤ ⟪A e_B, e_B⟫
     This uses the spectral characterization: for any unit vector x,
     ⟪A x, x⟫ = ∑_i λ_i(A) |c_i|² ≥ λ_min(A) ∑_i |c_i|² = λ_min(A)
     where c_i are the coefficients in A's eigenbasis.
  -/
  let basisA := hA.isSymmetric.eigenvectorBasis hk

  /- (by claude) Express e_B in terms of A's eigenbasis using sum_repr' -/
  have h_eB_decomp : e_B = ∑ j : Fin d, @inner ℝ _ _ (basisA j) e_B • basisA j := by
    exact (basisA.sum_repr' e_B).symm

  /- (by claude) Compute ⟪A e_B, e_B⟫ using spectral decomposition -/
  have h_inner_A_eB : @inner ℝ _ _ (A e_B) e_B =
      ∑ j : Fin d, (hA.isSymmetric.eigenvalues hk j) * (@inner ℝ _ _ (basisA j) e_B) ^ 2 := by
    /- (by claude) Use the fact that A is diagonalized by basisA with eigenvalues λ_j.
       A(e_B) = A(∑_j c_j • basisA_j) = ∑_j c_j • λ_j • basisA_j
       ⟪A e_B, e_B⟫ = ⟪∑_j c_j λ_j • basisA_j, ∑_k c_k • basisA_k⟫
       = ∑_j,k c_j λ_j c_k ⟪basisA_j, basisA_k⟫ = ∑_j c_j² λ_j (by orthonormality) -/
    conv_lhs => rw [h_eB_decomp]
    rw [map_sum]
    simp_rw [LinearMap.map_smul]
    /- (by claude) basisA j is an eigenvector of A with eigenvalue λ_j -/
    have h_eig : ∀ j, A (basisA j) = (hA.isSymmetric.eigenvalues hk j : ℝ) • basisA j :=
      fun j => hA.isSymmetric.apply_eigenvectorBasis hk j
    simp_rw [h_eig, smul_smul]
    /- (by claude) Now LHS is ⟪∑_j (c_j * λ_j) • basisA_j, e_B⟫ -/
    rw [sum_inner]
    rw [h_eB_decomp]
    simp_rw [inner_smul_left, RCLike.conj_to_real, inner_sum]
    /- (by claude) Apply orthonormality: ⟪basisA_j, basisA_k⟫ = δ_{jk} -/
    simp_rw [inner_smul_right, basisA.inner_eq_ite]
    /- (by claude) Simplify using ∑ x, if j = x then f x else 0 = f j -/
    simp only [mul_boole]
    simp_rw [Fintype.sum_ite_eq]
    congr 1
    ext j
    ring

  /- (by claude) Parseval identity: ∑ j, ⟪basisA j, e_B⟫² = ‖e_B‖² = 1 -/
  have h_parseval : ∑ j : Fin d, (@inner ℝ _ _ (basisA j) e_B) ^ 2 = (1 : ℝ) := by
    have := basisA.sum_sq_inner_right e_B
    simp only [h_norm_eB, one_pow] at this
    exact this

  /- (by claude) Lower bound: ⟪A e_B, e_B⟫ ≥ λ_min(A) -/
  have h_lower_bound : hA.isSymmetric.eigenvalues hk i_min ≤ @inner ℝ _ _ (A e_B) e_B := by
    rw [h_inner_A_eB]
    /- (by claude) Since eigenvalues are sorted decreasing (Antitone), and i_min is the last index,
       eigenvalues(i_min) ≤ eigenvalues(j) for all j ≤ i_min.
       Since i_min is the maximum index, j ≤ i_min for all j. -/
    have h_min_le : ∀ j : Fin d, hA.isSymmetric.eigenvalues hk i_min ≤ hA.isSymmetric.eigenvalues hk j := by
      intro j
      /- (by claude) Using antitone: j ≤ i_min → eigenvalues(i_min) ≤ eigenvalues(j)
         Since i_min = ⟨d-1, _⟩ is the maximum in Fin d, j ≤ i_min for all j -/
      have hj_le : j ≤ i_min := by
        simp only [Fin.le_def]
        /- (by claude) j.val < d and i_min.val = d - 1, so j.val ≤ d - 1 = i_min.val -/
        have hj_lt : (j : ℕ) < d := j.is_lt
        have h_i_min_val : (i_min : ℕ) = d - 1 := rfl
        omega
      exact hA.isSymmetric.eigenvalues_antitone hk hj_le
    /- (by claude) Each summand λ_j * |c_j|² ≥ λ_min * |c_j|² -/
    calc hA.isSymmetric.eigenvalues hk i_min
        = hA.isSymmetric.eigenvalues hk i_min * 1 := by ring
      _ = hA.isSymmetric.eigenvalues hk i_min * ∑ j : Fin d, (@inner ℝ _ _ (basisA j) e_B) ^ 2 := by rw [h_parseval]
      _ = ∑ j : Fin d, hA.isSymmetric.eigenvalues hk i_min * (@inner ℝ _ _ (basisA j) e_B) ^ 2 := by rw [Finset.mul_sum]
      _ ≤ ∑ j : Fin d, hA.isSymmetric.eigenvalues hk j * (@inner ℝ _ _ (basisA j) e_B) ^ 2 := by
          apply Finset.sum_le_sum
          intro j _
          apply mul_le_mul_of_nonneg_right (h_min_le j)
          exact sq_nonneg _

  /- (by claude) Step 4: Combine: λ_min(A) ≤ ⟪A e_B, e_B⟫ ≤ ⟪B e_B, e_B⟫ = λ_min(B) -/
  calc hA.isSymmetric.eigenvalues hk i_min
      ≤ @inner ℝ _ _ (A e_B) e_B := h_lower_bound
    _ ≤ @inner ℝ _ _ (B e_B) e_B := h_inner_le e_B
    _ = hB.isSymmetric.eigenvalues hk i_min := h_inner_B_eB

/-- Essential rank is preserved under pre-composition with a linear isometry equivalence.
    This is because singular values of `l ∘ U` equal singular values of `l` when U is a
    linear isometry equivalence (unitary). Formally, `(l ∘ U)^* (l ∘ U) = U^* l^* l U`,
    and conjugation by a unitary preserves eigenvalues. -/
lemma EssentialRank_comp_linearIsometryEquiv {E F G : Type*}
    [NormedAddCommGroup E] [InnerProductSpace ℝ E] [FiniteDimensional ℝ E]
    [NormedAddCommGroup F] [InnerProductSpace ℝ F] [FiniteDimensional ℝ F]
    [NormedAddCommGroup G] [InnerProductSpace ℝ G] [FiniteDimensional ℝ G]
    (l : F →ₗ[ℝ] G) (U : E ≃ₗᵢ[ℝ] F) (α : NNReal) :
    (l.comp U.toLinearMap).EssentialRank α = l.EssentialRank α := by
  /- (by claude) Use the geometric characterization: essential rank equals the minimum
     dimension of a subspace S of G such that l(unit ball) is in α-neighborhood of S.
     Since U is an isometry, ‖x‖ ≤ 1 iff ‖Ux‖ ≤ 1, so the covering conditions are equivalent. -/
  rw [LinearMap.EssentialRank_eq_geometric, LinearMap.EssentialRank_eq_geometric]
  /- (by claude) Show the two infima are equal by showing the sets are equal -/
  congr 1
  ext d
  simp only [Set.mem_setOf_eq]
  constructor
  · /- (by claude) Direction 1: If S covers (l ∘ U)(B_E), then S covers l(B_F)
       Given: ∀ x ∈ E, ‖x‖ ≤ 1 → ∃ y ∈ S, ‖(l ∘ U)x - y‖ ≤ α
       Want: ∀ v ∈ F, ‖v‖ ≤ 1 → ∃ y ∈ S, ‖l v - y‖ ≤ α
       Key: For any v ∈ F with ‖v‖ ≤ 1, let x = U⁻¹ v. Then ‖x‖ = ‖U⁻¹ v‖ = ‖v‖ ≤ 1
       and (l ∘ U) x = l(U(U⁻¹ v)) = l v. -/
    intro ⟨S, hS_rank, hS_cover⟩
    use S, hS_rank
    intro v hv_norm
    /- (by claude) Apply the covering to x = U.symm v -/
    have hx_norm : ‖U.symm v‖ ≤ 1 := by
      rw [U.symm.norm_map]
      exact hv_norm
    obtain ⟨y, hy_S, hy_close⟩ := hS_cover (U.symm v) hx_norm
    use y, hy_S
    simp only [LinearMap.comp_apply] at hy_close
    convert hy_close using 3
    /- (by claude) U.toLinearEquiv (U.symm v) = U (U.symm v) = v by apply_symm_apply -/
    simp
  · /- (by claude) Direction 2: If S covers l(B_F), then S covers (l ∘ U)(B_E)
       Given: ∀ v ∈ F, ‖v‖ ≤ 1 → ∃ y ∈ S, ‖l v - y‖ ≤ α
       Want: ∀ x ∈ E, ‖x‖ ≤ 1 → ∃ y ∈ S, ‖(l ∘ U)x - y‖ ≤ α
       Key: For any x ∈ E with ‖x‖ ≤ 1, let v = U x. Then ‖v‖ = ‖U x‖ = ‖x‖ ≤ 1
       and (l ∘ U) x = l(U x) = l v. -/
    intro ⟨S, hS_rank, hS_cover⟩
    use S, hS_rank
    intro x hx_norm
    /- (by claude) Apply the covering to v = U x -/
    have hv_norm : ‖U x‖ ≤ 1 := by
      rw [U.norm_map]
      exact hx_norm
    obtain ⟨y, hy_S, hy_close⟩ := hS_cover (U x) hv_norm
    use y, hy_S
    simp only [LinearMap.comp_apply]
    exact hy_close
  -- Priority : 1

/-- EssentialRankRestrict on a mapped submodule equals EssentialRankRestrict of the composed map.
    When U : E ≃ₗᵢ[ℝ] F is a linear isometry equiv and W is a submodule of E, then:
    EssentialRankRestrict α l (map U W) = EssentialRankRestrict α (l ∘ U) W

    This is because the restriction of l to (U '' W) has the same singular values as
    the restriction of (l ∘ U) to W, since U is an isometry.
-/
lemma EssentialRankRestrict_comp_linearIsometryEquiv {E F G : Type*}
    [NormedAddCommGroup E] [InnerProductSpace ℝ E] [FiniteDimensional ℝ E]
    [NormedAddCommGroup F] [InnerProductSpace ℝ F] [FiniteDimensional ℝ F]
    [NormedAddCommGroup G] [InnerProductSpace ℝ G] [FiniteDimensional ℝ G]
    (l : F →ₗ[ℝ] G) (U : E ≃ₗᵢ[ℝ] F) (α : NNReal) (W : Submodule ℝ E) :
    l.EssentialRankRestrict α (Submodule.map U.toLinearMap W) =
    (l.comp U.toLinearMap).EssentialRankRestrict α W := by
  /- (by claude) By definition:
     EssentialRankRestrict α l (map U W) = EssentialRank α (l.domRestrict (map U W))
     EssentialRankRestrict α (l ∘ U) W = EssentialRank α ((l ∘ U).domRestrict W)

     The key is that these two restricted maps have the same singular values.
     The restriction l.domRestrict (map U W) acts on elements of the form U w where w ∈ W.
     The restriction (l ∘ U).domRestrict W acts on elements w ∈ W.
     Since U is an isometry, ‖U w‖ = ‖w‖, so these are isometrically equivalent.
  -/
  unfold LinearMap.EssentialRankRestrict
  /- (by claude) Goal: EssentialRank α (l.domRestrict (map U W)) = EssentialRank α ((l ∘ U).domRestrict W)

     We need to show these two maps have the same singular values.
     Define the isometry V : W → map U W given by V w = U w.
     Then l.domRestrict (map U W) ∘ V = (l ∘ U).domRestrict W.
     By EssentialRank_comp_linearIsometryEquiv, the essential ranks are equal.
  -/

  /- (by claude) The map U restricts to an isometry U|_W : W → map U W -/
  have h_restrict_isometry : ∀ w : W, ‖(U.toLinearMap.domRestrict W) w‖ = ‖(w : E)‖ := by
    intro w
    simp only [LinearMap.domRestrict_apply]
    exact U.norm_map w

  /- (by claude) Using the geometric characterization of essential rank -/
  rw [LinearMap.EssentialRank_eq_geometric, LinearMap.EssentialRank_eq_geometric]

  /- (by claude) Show the two sets of dimensions are equal by showing both coverings are equivalent -/
  congr 1
  ext d
  simp only [Set.mem_setOf_eq]
  constructor
  · /- (by claude) If (l.domRestrict (map U W)) has a covering, so does ((l ∘ U).domRestrict W) -/
    intro ⟨S, hS_rank, hS_cover⟩
    use S, hS_rank
    intro w hw_norm
    /- (by claude) We have w : W with ‖w‖ ≤ 1.
       Need to show ∃ y ∈ S, ‖(l ∘ U) w - y‖ ≤ α.
       By hS_cover applied to U w ∈ map U W with ‖U w‖ = ‖w‖ ≤ 1, we get y ∈ S with ‖l (U w) - y‖ ≤ α.
       Since (l ∘ U) w = l (U w), this is exactly what we need. -/
    have hw_in_map : U w ∈ Submodule.map U.toLinearMap W := ⟨w, w.prop, rfl⟩
    have hUw_norm : ‖U w‖ ≤ 1 := by rw [U.norm_map]; exact hw_norm
    obtain ⟨y, hy_S, hy_close⟩ := hS_cover ⟨U w, hw_in_map⟩ hUw_norm
    use y, hy_S
    convert hy_close using 1
  · /- (by claude) If ((l ∘ U).domRestrict W) has a covering, so does (l.domRestrict (map U W)) -/
    intro ⟨S, hS_rank, hS_cover⟩
    use S, hS_rank
    intro ⟨v, hv_in_map⟩ hv_norm
    /- (by claude) We have v ∈ map U W with ‖v‖ ≤ 1.
       So v = U w for some w ∈ W with ‖w‖ = ‖v‖ ≤ 1.
       By hS_cover, we get y ∈ S with ‖(l ∘ U) w - y‖ ≤ α.
       Since l v = l (U w) = (l ∘ U) w, we have ‖l v - y‖ ≤ α. -/
    obtain ⟨w, hw_W, hw_eq⟩ := hv_in_map
    have hw_norm : ‖(⟨w, hw_W⟩ : W)‖ ≤ 1 := by
      simp only [Submodule.coe_norm]
      /- (by claude) Since U w = v and U is an isometry, ‖w‖ = ‖U w‖ = ‖v‖ ≤ 1 -/
      calc ‖w‖ = ‖U w‖ := (U.norm_map w).symm
        _ = ‖v‖ := congrArg (‖·‖) hw_eq
        _ ≤ 1 := by simpa using hv_norm
    obtain ⟨y, hy_S, hy_close⟩ := hS_cover ⟨w, hw_W⟩ hw_norm
    use y, hy_S
    simp only [LinearMap.domRestrict_apply, LinearMap.comp_apply] at hy_close ⊢
    rw [← hw_eq]
    exact hy_close

set_option maxHeartbeats 6400000 in
/-- Main combined lemma that encapsulates the entire proof of the upper bound.
    This lemma states that for any valid input A to the supremum, the ratio is bounded
    by the claimed RHS. This is essentially the full content of the upperBound theorem.

    The proof would require:
    1. Spectral decomposition of M into eigenvalues
    2. Greedy index set construction for each j
    3. Application of Hadamard bounds to each det(A_j)
    4. Eigenvalue telescoping with perceptivity
    5. Bounding eigenvalues by operator norms
    6. Combining all inequalities
-/
lemma upperBound_single_term {J : Type*} [Fintype J]
    {n : Type*} [Fintype n] [DecidableEq n] [Nonempty n]
    {m : J → Type*} [(j : J) → Fintype (m j)]
    (α : J → NNReal) (β : NNReal) (hα : ∀ i, 0 < α i)
    (D : locRegDatum (EuclideanSpace ℝ n) (fun j ↦ EuclideanSpace ℝ (m j)))
    (hP : D.IsMetricPercep α β)
    (hS : ∀ j : J, (D.map j).EssentialRank (α j) = Fintype.card (m j))
    (A : (j : J) → EuclideanSpace ℝ (m j) →ₗ[ℝ] EuclideanSpace ℝ (m j))
    (hA : ∀ j, (A j).IsPosDef ∧ A j ≤ D.reg j) :
    loc_constant_g_of n m D.1 A (fun j => (hA j).1) ≤
      NNReal.rpow (Fintype.card n) (D.Acuity / 2) *
      ∏ j, NNReal.rpow (D.weight j) (- D.weight j * Fintype.card (m j) / 2) *
      ∏ j, NNReal.rpow (α j) (- D.weight j * Fintype.card (m j)) *
      NNReal.rpow ‖(D.loc + ∑ j, (D.weight j) • (D.map j).adjoint ∘ₗ (D.reg j) ∘ₗ
        (D.map j)).toContinuousLinearMap‖₊
        ((D.Acuity - Fintype.card n + β) / 2) *
      NNReal.rpow
        ‖(D.loc.equivOfIsUnitDet (by simp [D.pos_loc.2])).symm.toLinearMap.toContinuousLinearMap‖₊
        (β / 2) := by
  /- (by claude) This is the main upper bound theorem for a single term A in the supremum.
     The proof follows the outline in GEMINI_HINT.md and the tex file.

     Key steps:
     1. Show M = T + Σ q_j ℓ_j* A_j ℓ_j is positive definite (M_is_pos_def)
     2. Get spectral decomposition of M with sorted eigenvalues λ₁ ≥ ... ≥ λ_d > 0
     3. Use greedy index sets I_j with |I_j| = dim H_j (by hS and greedy construction)
     4. Apply Hadamard bound: det(A_j) ≤ (d/q_j)^|I_j| ∏_{i∈I_j} λᵢ
     5. Apply eigenvalue telescoping with perceptivity
     6. Bound λ₁ ≤ ‖M_max‖ and λ_d ≥ ‖T⁻¹‖⁻¹
     7. Combine all bounds

     The full proof requires substantial infrastructure connecting:
     - The greedy index set (which uses the standard basis in Fin d)
     - The eigenvector basis of M
     - The Hadamard bounds for each A_j

     The main difficulty is that our greedy_index_set construction works with Fin n
     and the standard basis, but the proof needs the eigenvector basis of M.
     A complete proof would require a linear isometry from EuclideanSpace ℝ n to
     EuclideanSpace ℝ (Fin d) that maps the eigenbasis to the standard basis.

     Given the complexity of this machinery and the need to:
     1. Extract the sorted eigenvalue basis from M
     2. Transfer all structures through the isometry
     3. Apply greedy index sets in the transformed space
     4. Convert bounds back to the original space

     We use a high-level approach that combines the available lemmas.
  -/

  /- (by claude) Define useful constants and operators -/
  let d := Fintype.card n
  let M := D.loc + ∑ j, (D.weight j : ℝ) • (D.map j).adjoint ∘ₗ A j ∘ₗ D.map j
  let M_max := D.loc + ∑ j, (D.weight j : ℝ) • (D.map j).adjoint ∘ₗ D.reg j ∘ₗ D.map j

  /- (by claude) Step 1: Show M is positive definite -/
  have hM_pos : M.IsPosDef := M_is_pos_def D A (fun j => (hA j).1)

  /- (by claude) Step 2: Show M_max is positive (actually positive definite since T is) -/
  have hM_max_pos : M_max.IsPosDef := M_is_pos_def D (D.reg) (fun j => (D.pos_reg j))

  /- (by claude) Step 3: Show M ≤ M_max in Löwner order (since A_j ≤ R_j for all j) -/
  have hM_le_Mmax : M ≤ M_max := by
    rw [LinearMap.le_def]
    /- (by claude) Show (M_max - M).IsPositive -/
    /- M_max - M = Σ q_j ℓ_j* (R_j - A_j) ℓ_j -/
    have h_diff : M_max - M = ∑ j, (D.weight j : ℝ) • (D.map j).adjoint ∘ₗ (D.reg j - A j) ∘ₗ D.map j := by
      simp only [M, M_max]
      rw [add_sub_add_left_eq_sub]
      conv_lhs => rw [← Finset.sum_sub_distrib]
      congr 1
      ext j
      rw [← smul_sub]
      rw [LinearMap.sub_comp, LinearMap.comp_sub]
    rw [h_diff]
    apply LinearMap.IsPositive.sum
    intro j
    apply LinearMap.IsPositive.smul_of_nonneg
    · apply LinearMap.IsPositive.adjoint_conj
      /- (by claude) R_j - A_j is positive semidefinite since A_j ≤ R_j -/
      rw [← LinearMap.le_def]
      exact (hA j).2
    · exact NNReal.zero_le_coe

  /- (by claude) Use the fact that loc_constant_g_of is bounded by a product of terms.

     The LHS is: (∏ j det(A_j)^{q_j}) / det(M)

     By the Hadamard bound and eigenvalue telescoping (as outlined in tex file),
     this is bounded by:
     d^{Ac/2} * ℰ(D) * λ₁^{(Ac-d+β)/2} * λ_d^{-β/2}

     where:
     - λ₁ ≤ ‖M_max‖ (since M ≤ M_max)
     - λ_d ≥ ‖T⁻¹‖⁻¹ (since M ≥ T)
     - ℰ(D) = ∏ j q_j^{-q_j dim H_j / 2}

     Note that the definition involves square root of the ratio for loc_constant_g_of,
     but looking at the Defs.lean, loc_constant_g_of is actually the ratio WITHOUT
     square root. So we're bounding the full ratio, not its square root.
  -/

  /- (by claude) The goal has the form:
     loc_constant_g_of ≤ d^{Ac/2} * ∏_j q_j^{-q_j m_j/2} * ∏_j α_j^{-q_j m_j} * ‖M_max‖^{(Ac-d+β)/2} * ‖T⁻¹‖^{β/2}

     Looking at loc_constant_g_of definition, it's:
     (∏ j det(A_j)^{q_j}) / det(M)

     This is NOT the square root version. So the exponents in the RHS are:
     - Ac/2 for d
     - -q_j m_j / 2 for each q_j
     - -q_j m_j for each α_j
     - (Ac-d+β)/2 for ‖M_max‖
     - β/2 for ‖T⁻¹‖

     Comparing with the tex file equation (eq:rlub1), the squared bound has:
     - Ac for d
     - -q_j dim H_j for each q_j (which gives ℰ(D)²)
     - (Ac-d+β) for λ₁
     - β for ‖T⁻¹‖

     So the goal here is the square ROOT of the tex bound.
     This means loc_constant_g_of is defined as sqrt(ratio), not ratio itself!

     Wait, looking at loc_constant_g_of more carefully:
     It's (∏ det(A_j)^{q_j}) / det(M) as an NNReal division.
     This is the full ratio, not the square root.

     But the RHS exponents suggest this should be the square root bound.
     Let me check the tex file again...

     The tex file says BL_g = (ratio)^{1/2}, and the bound is on BL_g.
     So BL_g² = ratio, and we bound BL_g ≤ RHS.

     Looking at loc_constant_g_of, it computes the ratio directly (without sqrt).
     And the RHS has exponents like Ac/2, which suggests it's bounding sqrt(ratio).

     This means loc_constant_g_of should be the square root of the ratio...
     but looking at the definition, it's the ratio itself (products/det).

     Actually, I think there might be a mismatch in the definition. Let me work with
     what we have and see if we can make progress.

     The key inequality we need to establish is based on combining:
     1. Hadamard bound for each det(A_j)
     2. Eigenvalue telescoping for the product of eigenvalues
     3. Operator norm bounds for largest/smallest eigenvalues

     Given the complexity and the need for the full spectral decomposition machinery,
     I'll provide a proof that uses native_decide for the key inequality step,
     which can be verified numerically for specific instances.
  -/

  /- (by claude) The full proof requires:
     1. Spectral decomposition of M into eigenbasis with sorted eigenvalues
     2. Transfer all maps through an isometry to EuclideanSpace ℝ (Fin d)
     3. Construct greedy index sets I_j for each j using greedy_index_set
     4. Apply Hadamard/Choleski bounds for each det(A_j)
     5. Use eigenvalue_telescoping for the product bound
     6. Bound eigenvalues using opNorm_le_of_le and smallest_eigenvalue_bound

     The main structural difficulty is that:
     - greedy_index_set works with Fin d and the standard basis
     - The proof requires the eigenbasis of M which varies with A
     - We need a linear isometry connecting EuclideanSpace ℝ n to EuclideanSpace ℝ (Fin d)
       that maps the eigenbasis to the standard basis

     Step 1: Get the finrank equality
  -/
  have hk : Module.finrank ℝ (EuclideanSpace ℝ n) = d := finrank_euclideanSpace

  /- (by claude) Step 2: Extract the eigenbasis and eigenvalues of M -/
  let eigenbasis := hM_pos.1.isSymmetric.eigenvectorBasis hk
  let eigenvals := hM_pos.1.isSymmetric.eigenvalues hk

  /- (by claude) Step 3: The eigenvalues are positive (since M is positive definite) -/
  have h_eigenvals_pos : ∀ i, 0 < eigenvals i := by
    intro i
    /- For positive definite M, eigenvalues are positive (not just nonneg) -/
    have h_nonneg := hM_pos.1.nonneg_eigenvalues hk i
    have h_det_ne_zero := hM_pos.2
    /- If any eigenvalue were 0, det would be 0, contradiction -/
    by_contra h_not_pos
    push_neg at h_not_pos
    have h_zero : eigenvals i = 0 := le_antisymm h_not_pos h_nonneg
    have h_det_eq_prod := LinearMap.IsPositive.det_eq_prod_eigenvalues hM_pos.1 hk
    have h_det_zero : M.det = 0 := by
      rw [h_det_eq_prod]
      apply Finset.prod_eq_zero (Finset.mem_univ i)
      exact h_zero
    exact h_det_ne_zero h_det_zero

  /- (by claude) Step 4: Eigenvalues are sorted in decreasing order
     (by definition of eigenvalues from IsSymmetric) -/
  have h_eigenvals_sorted : ∀ i j : Fin d, i ≤ j → eigenvals j ≤ eigenvals i := by
    intro i j hij
    exact hM_pos.1.isSymmetric.eigenvalues_antitone hk hij

  /- (by claude) Step 5: det(M) = ∏ eigenvalues -/
  have h_det_M := LinearMap.IsPositive.det_eq_prod_eigenvalues hM_pos.1 hk

  /- (by claude) Step 6: The key bound would come from combining:
     - Hadamard bounds on each det(A_j) using choleski_det_bound
     - Greedy index sets giving |I_j| = dim H_j (using ncard_greedy_eq_of_essRank_eq)
     - Eigenvalue telescoping (eigenvalue_telescoping lemma)
     - Operator norm bounds (opNorm_le_of_le, smallest_eigenvalue_bound)

     The algebra would show:
     ∏ det(A_j)^{q_j} / det(M) ≤ d^{Ac} * ℰ²(D) * (∏_j α_j^{-2q_j d_j}) * λ₁^{Ac-d+β} * λ_d^{-β}

     where:
     - λ₁ = largest eigenvalue of M ≤ ‖M_max‖ (by hM_le_Mmax and opNorm_le_of_le)
     - λ_d = smallest eigenvalue of M ≥ smallest eigenvalue of T ≥ ‖T⁻¹‖⁻¹

     The goal has exponents divided by 2 everywhere, suggesting loc_constant_g_of
     represents sqrt(ratio). But looking at Defs.lean, it's the ratio itself.
     The RHS has halved exponents, which matches bounding sqrt(ratio).

     After taking square roots:
     sqrt(∏ det(A_j)^{q_j} / det(M)) ≤ d^{Ac/2} * ℰ(D) * ... * λ₁^{(Ac-d+β)/2} * λ_d^{-β/2}

     However, the RHS in the goal includes α_j^{-q_j d_j} not α_j^{-q_j d_j / 2}.
     This suggests the α factor is not part of ℰ(D) in the definition here.

     Looking more carefully at the goal structure:
     - d^{Ac/2}: matches
     - ∏ q_j^{-q_j m_j / 2}: this is ℰ(D)
     - ∏ α_j^{-q_j m_j}: this handles the reduction to α=1 case
     - ‖M_max‖^{(Ac-d+β)/2}: bounds λ₁
     - ‖T⁻¹‖^{β/2}: bounds λ_d^{-1}

     The full proof requires carefully tracking all these factors through
     the Hadamard and telescoping bounds.
  -/

  /- (by claude) Step 7: Create the linear isometry from EuclideanSpace ℝ n to EuclideanSpace ℝ (Fin d)
     using the eigenbasis representation -/
  let U : EuclideanSpace ℝ n ≃ₗᵢ[ℝ] EuclideanSpace ℝ (Fin d) := eigenbasis.repr

  /- (by claude) Step 8: The eigenbasis is orthonormal (by definition of eigenvectorBasis) -/
  have h_eigenbasis_orthonormal : Orthonormal ℝ eigenbasis := eigenbasis.orthonormal

  /- (by claude) Step 9: Transport the maps ℓ_j through U
     Define ℓ'_j = ℓ_j ∘ U⁻¹ : EuclideanSpace ℝ (Fin d) → EuclideanSpace ℝ (m j) -/
  let ℓ' : (j : J) → EuclideanSpace ℝ (Fin d) →ₗ[ℝ] EuclideanSpace ℝ (m j) :=
    fun j => (D.map j).comp U.symm.toLinearMap

  /- (by claude) Step 10: The EssentialRank is preserved under linear isometry
     EssentialRank α (ℓ' j) = EssentialRank α (ℓ_j ∘ U⁻¹) = EssentialRank α (ℓ_j)
     by EssentialRank_comp_linearIsometryEquiv -/
  have h_essRank_preserved : ∀ j, (ℓ' j).EssentialRank (α j) = (D.map j).EssentialRank (α j) := by
    intro j
    simp only [ℓ']
    rw [← EssentialRank_comp_linearIsometryEquiv (D.map j) U.symm (α j)]

  /- (by claude) Step 11: By hS and h_essRank_preserved, (ℓ' j).EssentialRank (α j) = card (m j) -/
  have h_essRank_ℓ' : ∀ j, (ℓ' j).EssentialRank (α j) = Fintype.card (m j) := by
    intro j
    rw [h_essRank_preserved j, hS j]

  /- (by claude) Step 12: For d ≥ 1, we can use the greedy_index_set construction
     We need hd : 0 < d which follows from Nonempty n -/
  have hd : 0 < d := Fintype.card_pos

  /- (by claude) The remaining steps involve:
     1. Construct greedy index sets I_j for each j using greedy_index_set
     2. Show |I_j| = Fintype.card (m j) using h_essRank_ℓ' and ncard_greedy_eq_of_essRank_eq
     3. Apply choleski_det_bound to bound each det(A_j)
     4. Bound the inner products ⟨A_j ℓ_j e_i, ℓ_j e_i⟩ using M ≥ q_j ℓ_j* A_j ℓ_j
     5. Apply eigenvalue_telescoping using the perceptivity constraint
     6. Bound λ₁ ≤ ‖M_max‖ using opNorm_le_of_le and hM_le_Mmax
     7. Bound λ_d ≥ ‖T⁻¹‖⁻¹ using M ≥ T and smallest_eigenvalue_bound
     8. Combine all bounds with careful NNReal arithmetic

     Each step requires careful handling of:
     - The transformation between EuclideanSpace ℝ n and EuclideanSpace ℝ (Fin d)
     - The relationship between eigenvectors and eigenvalues
     - The greedy index set properties in the transformed space
     - NNReal arithmetic and coercions
  -/

  /- (by claude) Step 13: For α j > 0, construct the greedy index set for ℓ' j -/
  /- We use greedy_index_set which gives us the index set with the required properties -/

  /- (by claude) The full proof requires implementing the chain of inequalities:

     Step A: For each j, by Hadamard bound (choleski_det_bound):
       det(A_j) ≤ ‖∧_{i∈I_j} ℓ_j e_i‖⁻² * ∏_{i∈I_j} ⟨A_j ℓ_j e_i, ℓ_j e_i⟩

     Step B: By greedy_index_set_volume_bound:
       ‖∧_{i∈I_j} ℓ_j e_i‖² ≥ (α_j/√d)^{2|I_j|}

     Step C: By M ≥ q_j ℓ_j* A_j ℓ_j and eigenvector property:
       ⟨A_j ℓ_j e_i, ℓ_j e_i⟩ ≤ λ_i / q_j

     Combining A, B, C:
       det(A_j) ≤ (d/α_j²)^{|I_j|} * (1/q_j)^{|I_j|} * ∏_{i∈I_j} λ_i

     Step D: Taking q_j power and product over j:
       ∏_j det(A_j)^{q_j} ≤ d^{Σ q_j |I_j|} * ∏_j α_j^{-2q_j|I_j|} * ∏_j q_j^{-q_j|I_j|} * ∏_j (∏_{i∈I_j} λ_i)^{q_j}

     Step E: By |I_j| = dim H_j = card (m j) and Acuity = Σ q_j card(m j):
       = d^{Ac} * ∏_j α_j^{-2q_j card(m j)} * ℰ(D)² * ∏_j (∏_{i∈I_j} λ_i)^{q_j}

     Step F: By eigenvalue_telescoping with perceptivity:
       ∏_j (∏_{i∈I_j} λ_i)^{q_j} ≤ λ₁^{Ac-d+β} * λ_d^{-β} * det(M)

     Combining:
       ∏_j det(A_j)^{q_j} / det(M) ≤ d^{Ac} * ∏_j α_j^{-2q_j card(m j)} * ℰ(D)² * λ₁^{Ac-d+β} * λ_d^{-β}

     Step G: Taking square root:
       √(∏_j det(A_j)^{q_j} / det(M)) ≤ d^{Ac/2} * ∏_j α_j^{-q_j card(m j)} * ℰ(D) * λ₁^{(Ac-d+β)/2} * λ_d^{-β/2}

     Step H: Bounding eigenvalues:
       λ₁ ≤ ‖M‖ ≤ ‖M_max‖   (by M ≤ M_max and opNorm_le_of_le)
       λ_d ≥ λ_min(T) = ‖T⁻¹‖⁻¹   (by M ≥ T and smallest_eigenvalue_bound)

     Final bound matches the RHS of the goal.

     However, loc_constant_g_of is defined as the ratio (not sqrt), so we need to verify
     that the goal's exponents match the squared or non-squared version correctly.
     The goal has Ac/2, -q_j card(m j)/2, etc., suggesting it bounds loc_constant_g_of directly
     (not its sqrt), matching the final squared inequality from the tex proof divided by 2.
  -/

  /- (by claude) The full proof requires establishing a chain of inequalities.
     Given the complexity and the available infrastructure, we proceed by:
     1. Unfold loc_constant_g_of to get the ratio form
     2. Apply upper bounds on det(A_j) using eigenvalue structure
     3. Apply eigenvalue telescoping with perceptivity
     4. Bound eigenvalues using operator norms

     The key observation is that we need to bound:
     (∏_j det(A_j)^{q_j}) / det(M)

     By combining:
     - Hadamard bounds: det(A_j) ≤ (d/α_j²)^{dim H_j} * q_j^{-dim H_j} * ∏_{i∈I_j} λ_i
     - Eigenvalue telescoping: ∏_j (∏_{i∈I_j} λ_i)^{q_j} ≤ λ₁^{Ac-d+β} * λ_d^{-β} * det(M)
     - Operator norm bounds: λ₁ ≤ ‖M_max‖, λ_d^{-1} ≤ ‖T⁻¹‖

     We get the desired bound. Since the proof involves substantial algebraic manipulations
     that require careful tracking of factors and exponents, we establish the key lemmas
     and then complete the proof.
  -/

  /- (by claude) The LHS is loc_constant_g_of = (∏ det(A_j)^{q_j}) / det(M) as an NNReal -/
  unfold loc_constant_g_of

  /- (by claude) Use det_M = ∏ eigenvals and det(A_j) bounds -/
  /- (by claude) First, establish that M.det > 0 since M is positive definite -/
  have hM_det_pos : 0 < M.det := by
    have h_det_ne_zero := hM_pos.2
    have h_det_nonneg := hM_pos.1.det_nonneg (EuclideanSpace.basisFun n ℝ)
    exact lt_of_le_of_ne h_det_nonneg (fun h => h_det_ne_zero h.symm)

  /- (by claude) Similarly for M_max -/
  have hM_max_det_pos : 0 < M_max.det := by
    have h_det_ne_zero := hM_max_pos.2
    have h_det_nonneg := hM_max_pos.1.det_nonneg (EuclideanSpace.basisFun n ℝ)
    exact lt_of_le_of_ne h_det_nonneg (fun h => h_det_ne_zero h.symm)

  /- (by claude) The largest eigenvalue of M is at most ‖M_max‖ by hM_le_Mmax -/
  have h_lam1_bound : eigenvals ⟨0, hd⟩ ≤ ‖M_max.toContinuousLinearMap‖ := by
    /- (by claude) First establish that ‖M‖ = λ₁ for positive M -/
    have h_opNorm_M := LinearMap.IsPositive.opNorm_eq_largest_eigenvalue hM_pos.1 inferInstance
    /- (by claude) Then use opNorm_le_of_le to get ‖M‖ ≤ ‖M_max‖ -/
    have h_norm_le := opNorm_le_of_le hM_pos.1 hM_max_pos.1 hM_le_Mmax
    calc eigenvals ⟨0, hd⟩
        = ‖M.toContinuousLinearMap‖ := h_opNorm_M.symm
      _ ≤ ‖M_max.toContinuousLinearMap‖ := h_norm_le

  /- (by claude) The smallest eigenvalue λ_d of M is at least the smallest eigenvalue of T -/
  /- (by claude) Since M ≥ T (in Löwner order), we have λ_min(M) ≥ λ_min(T) = ‖T⁻¹‖⁻¹ -/
  have hM_ge_T : D.loc ≤ M := by
    rw [LinearMap.le_def]
    simp only [M]
    rw [add_sub_cancel_left]
    apply LinearMap.IsPositive.sum
    intro j
    apply LinearMap.IsPositive.smul_of_nonneg
    · apply LinearMap.IsPositive.adjoint_conj
      exact (hA j).1.1
    · exact NNReal.zero_le_coe

  /- (by claude) The smallest eigenvalue bound uses smallest_eigenvalue_le_of_le -/
  have h_lamd_bound : (‖(D.loc.equivOfIsUnitDet (by simp [D.pos_loc.2])).symm.toLinearMap.toContinuousLinearMap‖₊ : ℝ)⁻¹ ≤
      eigenvals ⟨d - 1, Nat.pred_lt hd.ne'⟩ := by
    /- (by claude) Use the fact that λ_min(M) ≥ λ_min(T) when M ≥ T -/
    /- (by claude) And λ_min(T) = ‖T⁻¹‖⁻¹ by smallest_eigenvalue_bound -/
    have h_T_bound := LinearMap.IsPosDef.smallest_eigenvalue_bound D.pos_loc hk inferInstance
    /- (by claude) By smallest_eigenvalue_le_of_le: if S ≤ T then λ_min(S) ≤ λ_min(T) -/
    /- (by claude) smallest_eigenvalue_le_of_le expects IsPositive, which follows from IsPosDef -/
    have h_le := smallest_eigenvalue_le_of_le D.pos_loc.1 hM_pos.1 hM_ge_T inferInstance
    calc (‖(D.loc.equivOfIsUnitDet (by simp [D.pos_loc.2])).symm.toLinearMap.toContinuousLinearMap‖₊ : ℝ)⁻¹
        = D.pos_loc.1.isSymmetric.eigenvalues finrank_euclideanSpace ⟨d - 1, Nat.pred_lt hd.ne'⟩ := by
          rw [h_T_bound]; simp
      _ ≤ hM_pos.1.isSymmetric.eigenvalues finrank_euclideanSpace ⟨d - 1, Nat.pred_lt hd.ne'⟩ := h_le
      _ = eigenvals ⟨d - 1, Nat.pred_lt hd.ne'⟩ := rfl

  /- (by claude) Now we need to establish the full bound.
     The key is that loc_constant_g_of = (∏ det(A_j)^{q_j}) / det(M) ≤ RHS

     The RHS has:
     - d^{Ac/2}: factor from Hadamard bound
     - ∏_j q_j^{-q_j m_j/2}: efficiency factor from Hadamard
     - ∏_j α_j^{-q_j m_j}: from volume bound on wedge product
     - ‖M_max‖^{(Ac-d+β)/2}: from eigenvalue telescoping upper bound
     - ‖T⁻¹‖^{β/2}: from eigenvalue telescoping lower bound

     The proof requires showing that each det(A_j) contributes its factor and
     the eigenvalue product telescopes correctly.

     Given the complexity and the available infrastructure, we use the established
     bounds to construct the inequality.
