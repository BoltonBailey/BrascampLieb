     The key is that all our bounds are in ℝ and we need to lift to NNReal. -/

  /- (by claude) The denominator of loc_constant_g_of is exactly det(M) -/
  have h_denom_eq : (D.loc + ∑ j, (D.weight j : ℝ) • ((D.map j).adjoint ∘ₗ A j ∘ₗ D.map j)).det = M.det := rfl

  /- (by claude) We now proceed with a direct comparison of the ratio.
     The mathematical argument shows:
     (∏ det(A_j)^{q_j}) / det(M) ≤ d^{Ac/2} * ℰ(D) * ∏_j α_j^{-q_j m_j} * ‖M_max‖^{(Ac-d+β)/2} * ‖T⁻¹‖^{β/2}

     where ℰ(D) = ∏_j q_j^{-q_j m_j/2}

     The proof uses:
     1. Hadamard bound on each det(A_j)
     2. Eigenvalue telescoping
     3. Operator norm bounds on eigenvalues

