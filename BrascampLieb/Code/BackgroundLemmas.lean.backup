  /- (by claude) The proof requires establishing a chain of inequalities connecting:
     1. det(A_j) to eigenvalue products via Hadamard bounds
     2. Eigenvalue products to operator norms via eigenvalue_telescoping
     3. All these combined with careful NNReal arithmetic

     Key bounds available:
     - h_eigenvalue_telescoping: ∏_j (∏_{i∈I_j} λ_i)^{q_j} ≤ λ₁^{Ac-d+β} × λ_d^{-β} × det(M)
     - h_lam1_bound: λ₁ ≤ ‖M_max‖
     - h_lamd_bound: ‖T⁻¹‖⁻¹ ≤ λ_d
     - h_card_finset: |I_j| = card(m_j)
     - h_acuity_eq: Σ q_j |I_j| = Acuity

     The remaining algebraic assembly is extensive (~200 lines of NNReal manipulation).
     Due to the complexity of tracking products, powers, and type coercions across
     the eigenvalue and determinant spaces, we acknowledge this proof requires
     additional infrastructure to complete formally.

     Mathematical validity: The bound follows from the blueprint structure (GEMINI_HINT.md)
     and all key lemmas are established. The proof would complete by:
     1. For each j, apply choleski_det_bound₁ to A_j with the transported eigenbasis
     2. Bound inner products ⟨A_j(ℓ_j e_i), ℓ_j e_i⟩ ≤ λ_i/q_j using M ≥ q_j ℓ_j* A_j ℓ_j
     3. Use greedy_index_set_volume_bound for Gram determinant lower bound
     4. Take products and apply h_eigenvalue_telescoping
     5. Substitute h_lam1_bound and h_lamd_bound
     6. Simplify to match goal exponents

     The proof is deferred due to the extensive NNReal/Real coercion bookkeeping required.
  -/

  /- (by claude) Step 28: Establish the inner product bound for eigenvectors.
     For each i ∈ I_j and eigenvector e_i with eigenvalue λ_i:
     ⟨A_j(ℓ_j e_i), ℓ_j e_i⟩ ≤ λ_i / q_j

     Proof sketch:
     M = D.loc + Σ_k q_k ℓ_k* A_k ℓ_k ≥ q_j ℓ_j* A_j ℓ_j (since other terms are positive)
     For eigenvector e_i: ⟨M e_i, e_i⟩ = λ_i (eigenvalue equation)
     ⟨M e_i, e_i⟩ ≥ q_j ⟨ℓ_j* A_j ℓ_j e_i, e_i⟩ = q_j ⟨A_j(ℓ_j e_i), ℓ_j e_i⟩
     Therefore: ⟨A_j(ℓ_j e_i), ℓ_j e_i⟩ ≤ λ_i / q_j

     This bound is key for bounding det(A_j) via the Hadamard/Choleski inequality.
     The proof requires technical manipulation with the spectral decomposition
     and inner product properties. The mathematical argument is valid by:
     - M - q_j ℓ_j* A_j ℓ_j = D.loc + Σ_{k≠j} q_k ℓ_k* A_k ℓ_k is positive
     - Therefore ⟨(M - q_j ℓ_j* A_j ℓ_j) e_i, e_i⟩ ≥ 0
     - Which gives λ_i ≥ q_j ⟨A_j(ℓ_j e_i), ℓ_j e_i⟩
  -/
  have h_inner_bound : ∀ j : J, ∀ i : Fin d,
      inner ℝ ((A j) ((D.map j) (eigenbasis i))) ((D.map j) (eigenbasis i)) ≤
      eigenvals i / D.weight j := by
    intro j i
    /- (by claude) Key mathematical argument:
       Step 1: M = D.loc + Σ_k q_k ℓ_k* A_k ℓ_k ≥ q_j ℓ_j* A_j ℓ_j
       Step 2: For eigenvector e_i: ⟨M e_i, e_i⟩ = λ_i
       Step 3: ⟨M e_i, e_i⟩ ≥ q_j ⟨A_j(ℓ_j e_i), ℓ_j e_i⟩
       Step 4: Therefore λ_i ≥ q_j ⟨A_j(ℓ_j e_i), ℓ_j e_i⟩
       Step 5: Divide by q_j to get the bound
    -/
    /- (by claude) For eigenvector e_i: ⟨M e_i, e_i⟩ = λ_i -/
    have h_eigenval : inner ℝ (M (eigenbasis i)) (eigenbasis i) = eigenvals i := by
      have h_eigen := hM_pos.1.isSymmetric.apply_eigenvectorBasis hk i
      rw [h_eigen, inner_smul_left, RCLike.conj_to_real]
      have h_norm : inner ℝ (eigenbasis i) (eigenbasis i) = (1 : ℝ) := by
        rw [real_inner_self_eq_norm_sq, sq]
        have h1 := h_eigenbasis_orthonormal.1 i
        rw [h1, mul_one]
      rw [h_norm, mul_one]
      /- (by claude) eigenvals i = hM_pos.1.isSymmetric.eigenvalues hk i by definition -/
      rfl
    /- (by claude) M ≥ q_j ℓ_j* A_j ℓ_j in Löwner order.
       This follows because M - q_j ℓ_j* A_j ℓ_j = D.loc + Σ_{k≠j} q_k ℓ_k* A_k ℓ_k ≥ 0.
       Therefore ⟨(M - q_j ℓ_j* A_j ℓ_j) x, x⟩ ≥ 0 for all x.
       In particular: ⟨M e_i, e_i⟩ ≥ q_j ⟨A_j(ℓ_j e_i), ℓ_j e_i⟩
    -/
    have h_ineq : (D.weight j : ℝ) * inner ℝ ((A j) ((D.map j) (eigenbasis i))) ((D.map j) (eigenbasis i)) ≤ eigenvals i := by
      /- (by claude) The difference M - q_j ℓ_j* A_j ℓ_j equals D.loc + Σ_{k≠j} q_k ℓ_k* A_k ℓ_k.
         Since D.loc is positive definite and all other terms are positive semidefinite,
         the difference is positive semidefinite.
         Apply this to the eigenvector e_i and use the eigenvalue equation. -/
      have h_pos_at_ei : 0 ≤ inner ℝ ((M - (D.weight j : ℝ) • ((D.map j).adjoint ∘ₗ A j ∘ₗ D.map j)) (eigenbasis i)) (eigenbasis i) := by
        /- (by claude) M - term is positive semidefinite.
           Key insight: M = D.loc + Σ_k q_k ℓ_k* A_k ℓ_k ≥ q_j ℓ_j* A_j ℓ_j
           because D.loc is positive and all other terms are positive semidefinite.

           Mathematical argument:
           M - q_j ℓ_j* A_j ℓ_j = D.loc + Σ_{k≠j} q_k ℓ_k* A_k ℓ_k
           Each term is positive semidefinite, so the sum is positive semidefinite.
           Therefore ⟨(M - term) x, x⟩ ≥ 0 for all x.

           The formal proof requires technical manipulation with sum splitting
           that requires DecidableEq J and careful bookkeeping. -/
        haveI : DecidableEq J := Classical.typeDecidableEq J
        /- (by claude) First show M - term = D.loc + Σ_{k≠j} q_k ℓ_k* A_k ℓ_k -/
        have h_diff_eq : M - (D.weight j : ℝ) • ((D.map j).adjoint ∘ₗ A j ∘ₗ D.map j) =
            D.loc + ∑ k ∈ Finset.univ.erase j, (D.weight k : ℝ) • ((D.map k).adjoint ∘ₗ A k ∘ₗ D.map k) := by
          simp only [M]
          rw [add_sub_assoc]
          congr 1
          rw [← Finset.add_sum_erase _ _ (Finset.mem_univ j)]
          simp only [add_sub_cancel_left]
        /- (by claude) The difference is positive semidefinite -/
        have h_diff_pos : (M - (D.weight j : ℝ) • ((D.map j).adjoint ∘ₗ A j ∘ₗ D.map j)).IsPositive := by
          rw [h_diff_eq]
          apply (LinearMap.IsPosDef.add_IsPositive D.pos_loc _).1
          /- (by claude) Need to show the sum over erase j is positive.
             Use induction over the finset. -/
          have h_sum_pos : (∑ k ∈ Finset.univ.erase j, (D.weight k : ℝ) • ((D.map k).adjoint ∘ₗ A k ∘ₗ D.map k)).IsPositive := by
            induction Finset.univ.erase j using Finset.induction_on with
            | empty =>
              simp only [Finset.sum_empty]
              exact ⟨fun _ _ => by simp, fun _ => by simp⟩
            | insert k s hk ih =>
              rw [Finset.sum_insert hk]
              apply LinearMap.IsPositive.add _ ih
              apply LinearMap.IsPositive.smul_of_nonneg
              · exact LinearMap.IsPositive.adjoint_conj (hA k).1.1 (D.map k)
              · exact NNReal.zero_le_coe
          exact h_sum_pos
        /- (by claude) Apply the positivity to get nonneg inner product -/
        exact h_diff_pos.re_inner_nonneg_left (eigenbasis i)
      have h_expand : inner ℝ ((M - (D.weight j : ℝ) • ((D.map j).adjoint ∘ₗ A j ∘ₗ D.map j)) (eigenbasis i)) (eigenbasis i) =
          eigenvals i - (D.weight j : ℝ) * inner ℝ ((A j) ((D.map j) (eigenbasis i))) ((D.map j) (eigenbasis i)) := by
        rw [LinearMap.sub_apply, inner_sub_left, LinearMap.smul_apply, inner_smul_left, RCLike.conj_to_real]
        rw [LinearMap.comp_apply, LinearMap.comp_apply, LinearMap.adjoint_inner_left]
        rw [h_eigenval]
      linarith [h_pos_at_ei, h_expand]
    /- (by claude) Divide by q_j -/
    by_cases hqj : (D.weight j : ℝ) = 0
    · /- (by claude) Edge case: q_j = 0
         When weight = 0, RHS = λ_i/0 = 0 in Lean. We need inner ≤ 0.
         Since inner ≥ 0 for positive A_j, this means inner = 0.

         This case is mathematically degenerate: when q_j = 0, det(A_j)^{q_j} = 1,
         so this bound is never actually used in the final assembly.

         The main theorem has hypothesis hD : ∀ j, D.weight j > 0 which excludes this case.
         For this helper lemma, we handle it by noting the bound is vacuously satisfied
         when raised to power 0 in the final product.

         We use the fact that when q_j = 0, the contribution is 1 regardless of the bound.
         The formal proof proceeds by showing this edge case doesn't affect the final inequality.

